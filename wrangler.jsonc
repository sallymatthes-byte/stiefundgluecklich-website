{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "stiefundgluecklich-website",
  "compatibility_date": "2026-04-20",
  "kv_namespaces": [
    {
      "binding": "SESSION",
      "id": "REPLACE_WITH_CLOUDFLARE_KV_NAMESPACE_ID"
    }
  ],
  "r2_buckets": [
    {
      "binding": "MEMBERS_MEDIA",
      "bucket_name": "stiefundgluecklich-members-media",
      "preview_bucket_name": "stiefundgluecklich-members-media",
      "jurisdiction": "eu"
    }
  ]
}
