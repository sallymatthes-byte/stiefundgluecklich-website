---
import Layout from './Layout.astro'

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<Layout title={title} description={description}>
  <section class="pt-28 md:pt-32 pb-16 md:pb-20">
    <div class="container mx-auto px-5 md:px-6">
      <div class="max-w-[700px] mx-auto prose prose-neutral">
        <slot />
      </div>
    </div>
  </section>
</Layout>

<style is:global>
  .prose h1 { font-family: var(--font-serif); margin-bottom: 2.5rem; padding-bottom: 1.5rem; border-bottom: 1px solid hsl(0,0%,88%); font-size: 2rem; }
  .prose h2 { font-family: var(--font-serif); margin-top: 3rem; margin-bottom: 1.25rem; font-size: 1.3rem; padding-top: 2rem; border-top: 1px solid hsl(0,0%,90%); color: hsl(0,0%,15%); }
  .prose h2:first-of-type { border-top: none; padding-top: 0; }
  .prose h3 { font-family: var(--font-serif); margin-top: 2rem; margin-bottom: 0.75rem; font-size: 1.125rem; color: hsl(0,0%,20%); }
  .prose p { margin-bottom: 1.25rem; line-height: 1.85; color: hsl(0,0%,35%); font-size: 0.95rem; }
  .prose strong { color: hsl(0,0%,10%); }
  .prose a { color: hsl(107,57%,21%); text-decoration: underline; }
  .prose a:hover { opacity: 0.8; }
  .prose ul { list-style: disc; padding-left: 1.5rem; margin-bottom: 1.25rem; margin-top: 0.75rem; }
  .prose ul ul { margin-top: 0.5rem; margin-bottom: 0.5rem; }
  .prose li { margin-bottom: 0.6rem; line-height: 1.75; color: hsl(0,0%,35%); font-size: 0.95rem; }
  .prose li:last-child { margin-bottom: 0; }
</style>
