---
import Layout from '../layouts/Layout.astro'
---

<Layout title="Seite nicht gefunden" description="Diese Seite existiert leider nicht." canonical="https://stiefundgluecklich.de/404/">
  <section class="pt-28 md:pt-32 pb-16 md:pb-24 min-h-[60vh] flex items-center">
    <div class="container mx-auto px-5 md:px-6 text-center">
      <h1 class="font-serif text-4xl md:text-5xl font-semibold text-foreground mb-6">
        Seite nicht gefunden
      </h1>
      <p class="text-lg text-muted-foreground mb-8 max-w-md mx-auto">
        Die Seite, die du suchst, gibt es leider nicht (mehr). Vielleicht findest du hier, was du brauchst:
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/blog/" class="inline-flex items-center justify-center px-6 py-3 rounded-none bg-primary text-white font-medium hover:opacity-90 transition-opacity">
          Zum Blog
        </a>
        <a href="/" class="inline-flex items-center justify-center px-6 py-3 rounded-none border border-primary text-primary font-medium hover:bg-primary/5 transition-colors">
          Zur Startseite
        </a>
      </div>
    </div>
  </section>
</Layout>
