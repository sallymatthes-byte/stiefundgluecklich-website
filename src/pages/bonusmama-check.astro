// === STATE ===
let introAnswer = '';
let currentStatement = 0;
let scores = new Array(26).fill(0);
let contactId = null;
let patternId = null;

// === HELPERS ===
function showStep(id) {
  document.querySelectorAll('.check-step').forEach(el => el.classList.add('hidden'));
  const step = document.getElementById(id);
  step.classList.remove('hidden');
  step.style.animation = 'none';
  step.offsetHeight;
  step.style.animation = '';
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function getAreaForStatement(idx) {
  let sum = 0;
  for (let i = 0; i < AREAS.length; i++) {
    sum += AREAS[i].count;
    if (idx < sum) return i;
  }
  return AREAS.length - 1;
}

function getAreaStartIndex(areaIdx) {
  let sum = 0;
  for (let i = 0; i < areaIdx; i++) sum += AREAS[i].count;
  return sum;
}

function updateProgress() {
  const bar = document.getElementById('progress-bar');
  const fill = document.getElementById('progress-fill');
  const label = document.getElementById('progress-label');
  const percent = document.getElementById('progress-percent');
  const areaIdx = getAreaForStatement(currentStatement);
  const pct = Math.round((currentStatement / 26) * 100);

  bar.classList.remove('hidden');
  fill.style.width = pct + '%';
  label.textContent = 'Bereich ' + (areaIdx + 1) + ' von 5';
  percent.textContent = pct + '%';

  // Update area dots
  document.querySelectorAll('.area-dot').forEach((dot, i) => {
    if (i < areaIdx) {
      dot.style.color = 'hsl(107, 57%, 21%)';
      dot.style.fontWeight = '600';
    } else if (i === areaIdx) {
      dot.style.color = 'hsl(0, 0%, 0%)';
      dot.style.fontWeight = '600';
    } else {
      dot.style.color = '';
      dot.style.fontWeight = '';
    }
  });
}

function showStatement() {
  const areaIdx = getAreaForStatement(currentStatement);
  document.getElementById('area-label').textContent = 'Bereich: ' + AREAS[areaIdx].name;
  document.getElementById('statement-text').textContent = STATEMENTS[currentStatement];
  document.getElementById('statement-counter').textContent = 'Frage ' + (currentStatement + 1) + ' von 26';
  updateProgress();
}

// === SCORING ===
function calculateResults() {
  const areaScores = [];
  let idx = 0;
  for (const area of AREAS) {
    let sum = 0;
    for (let i = 0; i < area.count; i++) {
      sum += scores[idx++];
    }
    const maxPoints = area.count * 4;
    const pct = Math.round((sum / maxPoints) * 100);
    areaScores.push({ ...area, sum, maxPoints, pct });
  }

  const totalSum = scores.reduce((a, b) => a + b, 0);
  const totalPct = Math.round((totalSum / 104) * 100);

  // Find 2 weakest areas
  const sorted = areaScores.map((a, i) => ({ ...a, idx: i })).sort((a, b) => a.pct - b.pct);
  const weak1 = sorted[0].idx;
  const weak2 = sorted[1].idx;

  // Map to pattern
  const key1 = Math.min(weak1, weak2) + '-' + Math.max(weak1, weak2);
  const key2 = weak1 + '-' + weak2;
  patternId = PATTERN_MAP[key1] || PATTERN_MAP[key2] || 1;

  return { areaScores, totalSum, totalPct, weak1, weak2, patternId };
}

function renderRadarChart(areaScores) {
  const ctx = document.getElementById('radar-chart').getContext('2d');
  new Chart(ctx, {
    type: 'radar',
    data: {
      labels: areaScores.map(a => a.name.split(' & ')[0]),
      datasets: [{
        data: areaScores.map(a => a.pct),
        backgroundColor: 'hsla(107, 57%, 21%, 0.15)',
        borderColor: 'hsl(107, 57%, 21%)',
        borderWidth: 2,
        pointBackgroundColor: 'hsl(107, 57%, 21%)',
        pointBorderColor: '#fff',
        pointBorderWidth: 2,
        pointRadius: 5,
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      plugins: {
        legend: { display: false },
      },
      scales: {
        r: {
          beginAtZero: true,
          max: 100,
          ticks: {
            stepSize: 25,
            font: { family: 'Raleway', size: 10 },
            backdropColor: 'transparent',
            color: 'hsl(0, 0%, 70%)',
          },
          pointLabels: {
            font: { family: 'Raleway', size: 12, weight: '500' },
            color: 'hsl(0, 0%, 20%)',
          },
          grid: {
            color: 'hsl(45, 25%, 88%)',
          },
          angleLines: {
            color: 'hsl(45, 25%, 88%)',
          },
        }
      }
    }
  });
}

function renderScoreSummary(areaScores, totalPct) {
  document.getElementById('total-score').textContent = totalPct + ' %';

  const container = document.getElementById('area-scores');
  container.innerHTML = areaScores.map(a => {
    const color = a.pct <= 45 ? 'hsl(0, 65%, 55%)' : a.pct <= 70 ? 'hsl(42, 75%, 50%)' : 'hsl(107, 57%, 35%)';
    const label = a.pct <= 45 ? 'Dein größter Hebel' : a.pct <= 70 ? 'Auf dem Weg' : 'Deine Stärke';
    return `
      <div class="flex items-center gap-3">
        <span class="text-sm w-28 flex-shrink-0">${a.name.split(' & ')[0]}</span>
        <div class="flex-1 area-bar-bg">
          <div class="area-bar" style="width: ${a.pct}%; background: ${color};"></div>
        </div>
        <span class="text-sm font-medium w-10 text-right">${a.pct}%</span>
        <span class="text-xs w-28 text-right" style="color: ${color}">${label}</span>
      </div>
    `;
  }).join('');
}

function renderPattern(id) {
  const p = PATTERNS[id];
  document.getElementById('pattern-title').textContent = p.title;
  document.getElementById('pattern-body').innerHTML = p.body;
  
  const prescribeEl = document.getElementById('pattern-prescribe');
  prescribeEl.innerHTML = '<p class="font-medium text-foreground mb-2">In deiner persönlichen Auswertung bekommst du:</p>' +
    p.prescribe.map(item => `<p>✓ ${item}</p>`).join('');
}

// === FLOW ===
function startCheck() {
  showStep('step-intro');
  // Track start
  if (typeof gtag === 'function') gtag('event', 'check_started', { event_category: 'bonusmama_check' });
  if (typeof posthog !== 'undefined') posthog.capture('check_started');
}

function answerIntro(value) {
  introAnswer = value;
  currentStatement = 0;
  showStep('step-statements');
  showStatement();
}

function rate(value) {
  scores[currentStatement] = value;
  currentStatement++;

  if (currentStatement < 26) {
    // Animate transition
    const stmtEl = document.getElementById('statement-text');
    stmtEl.style.opacity = '0';
    stmtEl.style.transform = 'translateY(8px)';
    setTimeout(() => {
      showStatement();
      stmtEl.style.opacity = '1';
      stmtEl.style.transform = 'translateY(0)';
    }, 150);
  } else {
    // Done — show results
    const results = calculateResults();
    document.getElementById('progress-bar').classList.add('hidden');
    showStep('step-result');
    
    // Small delay for animation
    setTimeout(() => {
      renderRadarChart(results.areaScores);
      renderScoreSummary(results.areaScores, results.totalPct);
      renderPattern(results.patternId);
    }, 100);

    // Track completion
    if (typeof gtag === 'function') gtag('event', 'check_completed', { 
      event_category: 'bonusmama_check',
      event_label: 'pattern_' + results.patternId,
      value: results.totalPct
    });
    if (typeof posthog !== 'undefined') posthog.capture('check_completed', { 
      pattern: results.patternId, 
      total_pct: results.totalPct,
      intro_answer: introAnswer
    });
  }
}

async function submitEmail(e) {
  e.preventDefault();

  const btn = document.getElementById('submit-btn');
  btn.textContent = 'Wird gesendet...';
  btn.disabled = true;

  const firstname = document.getElementById('firstname').value;
  const email = document.getElementById('email').value;

  // Build area scores for AC
  const results = calculateResults();
  const areaData = {};
  results.areaScores.forEach(a => {
    areaData[a.id] = a.pct;
  });

  try {
    const response = await fetch('/api/bonusmama-check', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        firstname,
        email,
        pattern: patternId,
        totalPct: results.totalPct,
        areaScores: areaData,
        introAnswer,
      })
    });

    if (!response.ok) {
      console.error('AC submission failed');
    }
  } catch (err) {
    console.error('AC error:', err);
  }

  // Track
  if (typeof gtag === 'function') gtag('event', 'check_email_submitted', { event_category: 'bonusmama_check' });
  if (typeof posthog !== 'undefined') posthog.capture('check_email_submitted', { pattern: patternId });
  if (typeof fbq === 'function') fbq('track', 'Lead', { content_name: 'bonusmama_check' });

  showStep('step-wonder');
}

async function submitWonder() {
  const answer = document.getElementById('wonder-answer').value.trim();
  if (!answer) { skipWonder(); return; }

  const btn = document.getElementById('wonder-btn');
  btn.textContent = 'Wird gesendet...';
  btn.disabled = true;

  const email = document.getElementById('email').value;

  try {
    await fetch('/api/bonusmama-check-wonder', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email, wonderAnswer: answer })
    });
  } catch (err) {
    console.error('Wonder submission error:', err);
  }

  if (typeof posthog !== 'undefined') posthog.capture('check_wonder_answered');

  showStep('step-thanks');
}

function skipWonder() {
  if (typeof posthog !== 'undefined') posthog.capture('check_wonder_skipped');
  showStep('step-thanks');
}
</script>
