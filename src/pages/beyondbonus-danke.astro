---
import Layout from '../layouts/Layout.astro'
---

<Layout title="Willkommen bei Beyond Bonus!" canonical="https://stiefundgluecklich.de/beyondbonus-danke/" description="Dein Zugang zu Beyond Bonus ist freigeschaltet." noHeader={true}>
  <section class="pt-28 md:pt-32 pb-20 md:pb-28 min-h-[70vh] flex items-center">
    <div class="container mx-auto px-5 md:px-6">
      <div class="max-w-2xl mx-auto text-center">
        <div class="text-6xl mb-8">🎉</div>
        <h1 class="text-3xl md:text-4xl lg:text-5xl mb-6">Willkommen bei Beyond Bonus!</h1>
        <p class="text-xl text-muted-foreground leading-relaxed mb-6">
          Du hast den wichtigsten Schritt gemacht. Ab jetzt verändert sich etwas – Schritt für Schritt, in deinem Tempo.
        </p>
        <div class="bg-secondary border border-border p-6 mb-8 text-left max-w-md mx-auto">
          <h3 class="font-serif text-lg mb-3">Deine nächsten Schritte:</h3>
          <ol class="space-y-2 text-muted-foreground">
            <li class="flex gap-3"><span class="text-primary font-bold">1.</span> Check deinen Posteingang — dein Zugang zur Kursplattform ist unterwegs</li>
            <li class="flex gap-3"><span class="text-primary font-bold">2.</span> Logge dich auf Memberspot ein und starte mit Modul 1</li>
            <li class="flex gap-3"><span class="text-primary font-bold">3.</span> Deine E-Mail-Begleitung startet automatisch — jede Woche ein klarer nächster Schritt</li>
          </ol>
        </div>
        <p class="text-muted-foreground mb-8">
          Fragen? Schreib mir an <a href="mailto:willkommen@sallymatthes.com" class="text-primary hover:underline">willkommen@sallymatthes.com</a>
        </p>
        <a href="/" class="inline-block text-primary hover:underline">← Zurück zur Startseite</a>
      </div>
    </div>
  </section>
</Layout>
