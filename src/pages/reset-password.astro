---
export const prerender = false;

import Layout from '../layouts/Layout.astro';

const error = Astro.url.searchParams.get('error');
const hasSession = Boolean(Astro.locals.user);
const nextPath = Astro.url.searchParams.get('next') || '/members';
const safeNextPath = nextPath.startsWith('/') ? nextPath : '/members';
---

<Layout
  title="Neues Passwort vergeben"
  canonical="https://stiefundgluecklich.de/reset-password/"
  description="Neues Passwort für den Mitgliederbereich vergeben."
  noHeader={true}
>
  <section class="py-20 md:py-28">
    <div class="container mx-auto px-5 md:px-6 max-w-xl">
      <div class="bg-background border border-border p-8 md:p-10">
        <p class="text-sm uppercase tracking-[0.2em] text-muted-foreground mb-4">Mitgliederbereich</p>
        <h1 class="font-serif text-3xl md:text-4xl mb-4">Neues Passwort vergeben</h1>
        <p class="text-base text-muted-foreground mb-8 leading-relaxed">
          Lege hier ein neues Passwort fest, mit dem du dich künftig in deinen Mitgliederbereich einloggen kannst.
        </p>

        {error && (
          <div class="mb-6 border border-red-200 p-4 bg-red-50 text-sm leading-relaxed">
            {error === 'missing-password'
              ? 'Bitte gib ein neues Passwort ein.'
              : error === 'password-too-short'
                ? 'Bitte wähle ein Passwort mit mindestens 10 Zeichen.'
                : error === 'password-mismatch'
                  ? 'Die beiden Passwörter stimmen nicht überein.'
                  : error === 'supabase-config'
                    ? 'Die Passwortvergabe ist gerade noch nicht vollständig verbunden. Bitte versuche es gleich nochmal.'
                    : `Passwort gerade nicht sauber aktualisierbar: ${error}`}
          </div>
        )}

        {hasSession ? (
          <form method="POST" action="/api/auth/update-password" class="space-y-4">
            <input type="hidden" name="next" value={safeNextPath} />
            <label class="block">
              <span class="block text-sm mb-2">Neues Passwort</span>
              <input
                type="password"
                name="password"
                required
                autocomplete="new-password"
                placeholder="Neues Passwort"
                class="w-full border border-border bg-white px-4 py-3 focus:outline-none focus:border-primary"
              />
            </label>

            <label class="block">
              <span class="block text-sm mb-2">Neues Passwort wiederholen</span>
              <input
                type="password"
                name="password_repeat"
                required
                autocomplete="new-password"
                placeholder="Passwort wiederholen"
                class="w-full border border-border bg-white px-4 py-3 focus:outline-none focus:border-primary"
              />
            </label>

            <button
              type="submit"
              class="w-full bg-primary text-primary-foreground px-6 py-3 font-medium hover:opacity-90 transition-opacity"
            >
              Passwort speichern
            </button>
          </form>
        ) : (
          <div class="border border-border p-5 bg-secondary/40 text-sm leading-relaxed space-y-3">
            <p>Dein Wiederherstellungslink ist abgelaufen oder die Sitzung ist nicht mehr aktiv.</p>
            <p class="text-muted-foreground">Bitte starte den Vorgang einfach noch einmal über „Passwort vergessen?“ auf der Login-Seite.</p>
            <a href="/login" class="inline-flex px-5 py-3 bg-primary text-primary-foreground font-medium hover:opacity-90 transition-opacity">Zurück zum Login</a>
          </div>
        )}
      </div>
    </div>
  </section>
</Layout>
