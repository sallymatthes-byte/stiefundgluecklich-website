---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import StructuredData from '../../components/StructuredData.astro';
import FAQSchema from '../../components/FAQSchema.astro';
import FAQAccordion from '../../components/FAQAccordion.astro';
import fs from 'node:fs';
import path from 'node:path';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

// Extract FAQs from markdown content for schema
const mdPath = path.join(process.cwd(), 'src/content/blog', `${post.slug}.md`);
const mdContent = fs.existsSync(mdPath) ? fs.readFileSync(mdPath, 'utf-8') : '';
const faqSection = mdContent.split('## Häufige Fragen')[1] || '';
const faqMatches = [...faqSection.matchAll(/### (.+)\n([\s\S]*?)(?=\n###|\n## |$)/g)];
const faqs = faqMatches.map(m => ({
  question: m[1].trim(),
  answer: m[2].trim().replace(/<!--[\s\S]*?-->/g, '').replace(/\[([^\]]+)\]\([^)]+\)/g, '$1').replace(/\*\*/g, '').replace(/\*/g, '').trim()
}));

// Format date to German
const formatDate = (date: Date) => {
  const months = ['Januar', 'Februar', 'März', 'April', 'Mai', 'Juni', 'Juli', 'August', 'September', 'Oktober', 'November', 'Dezember'];
  return `${date.getDate()}. ${months[date.getMonth()]} ${date.getFullYear()}`;
};

// Category display names
const categoryLabels: Record<string, string> = {
  'rolle-identitaet': 'Rolle & Identität',
  'partnerschaft': 'Partnerschaft',
  'ex-und-system': 'Die Ex & das System',
  'kinder-bindung': 'Kinder & Bindung',
};

// Related posts: same category, max 3
const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter((p) => p.slug !== post.slug)
  .sort((a, b) => {
    if (a.data.category === post.data.category && b.data.category !== post.data.category) return -1;
    if (b.data.category === post.data.category && a.data.category !== post.data.category) return 1;
    return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
  })
  .slice(0, 3);
---

<Layout 
  title={post.data.metaTitle || post.data.title}
  description={post.data.metaDescription || post.data.excerpt}
  canonical={`https://stiefundgluecklich.de/blog/${post.slug}`}
>
  <StructuredData 
    type="article"
    title={post.data.title}
    description={post.data.metaDescription || post.data.description}
    date={post.data.date}
    updated={post.data.updated}
    image={post.data.heroImage}
    slug={post.slug}
    category={post.data.category}
  />
  <StructuredData 
    type="breadcrumb"
    title={post.data.title}
    slug={post.slug}
    category={post.data.category}
  />
  {faqs.length > 0 && <FAQSchema faqs={faqs} />}
  <article class="pt-28 md:pt-32 pb-16">
    <div class="container mx-auto px-5 md:px-6">
      <!-- Back Link -->
      <a href="/blog" class="inline-flex items-center text-muted-foreground hover:text-primary transition-colors mb-8 md:mb-10">
        <svg class="mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Zurück zum Blog
      </a>

      <div class="max-w-[700px] mx-auto">
        <!-- Category Badge -->
        <span class="text-sm font-medium text-primary bg-primary/10 px-4 py-1.5">
          {categoryLabels[post.data.category] || post.data.category}
        </span>

        <!-- Title -->
        <h1 class="font-serif text-3xl md:text-4xl lg:text-5xl text-foreground mt-6 mb-4">
          {post.data.title}
        </h1>

        <!-- Meta -->
        <div class="flex items-center gap-4 text-muted-foreground text-sm mb-8 md:mb-12">
          {post.data.readingTime && (
            <span class="flex items-center gap-1.5">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="10" /><path d="M12 6v6l4 2" />
              </svg>
              {post.data.readingTime} Lesezeit
            </span>
          )}
          <span>·</span>
          <span>{formatDate(new Date(post.data.date))}</span>
        </div>

        <!-- Hero Image -->
        {post.data.image && (
          <figure class="mb-10 md:mb-12">
            <img 
              src={post.data.image} 
              alt={post.data.imageAlt || post.data.title}
              class="w-full shadow-lg"
              loading="eager"
            />
          </figure>
        )}

        <!-- Article Content -->
        <div class="prose-custom">
          <Content />
        </div>

        <!-- Quiz CTA -->
        <div class="mt-16 bg-[#D9E4D3] text-foreground py-12 px-6 md:px-14 text-center">
          <h2 class="font-serif text-xl md:text-2xl lg:text-3xl font-semibold mb-3">
            Nicht sicher, was jetzt dein nächster Schritt ist?
          </h2>
          <p class="text-foreground/70 mb-6 md:mb-8 max-w-lg mx-auto">
            Das Quiz zeigt's dir — in 2 Minuten.
          </p>
          <a href="/quiz" class="inline-flex items-center justify-center bg-primary text-primary-foreground hover:bg-primary/90 px-8 py-3 text-base font-medium transition-colors">
            Finde deinen nächsten Schritt →
          </a>
        </div>

        {faqs.length > 0 && <FAQAccordion faqs={faqs} />}
      </div>
    </div>
  </article>

  <!-- Related Articles -->
  {relatedPosts.length > 0 && (
    <section class="py-16 md:py-20 bg-secondary/20">
      <div class="container mx-auto px-5 md:px-6">
        <h2 class="font-serif text-2xl md:text-3xl text-foreground mb-8 md:mb-10">
          Das könnte dich auch <span class="italic text-gold-bright">interessieren</span>
        </h2>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
          {relatedPosts.map((related) => (
            <a href={`/blog/${related.slug}`} class="group">
              <div class="border border-border overflow-hidden hover:shadow-xl transition-all duration-300 cursor-pointer h-full flex flex-col">
                {related.data.image && (
                  <div class="aspect-[16/10] overflow-hidden bg-secondary">
                    <img 
                      src={related.data.image} 
                      alt={related.data.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                      loading="lazy"
                    />
                  </div>
                )}
                <div class="p-5 md:p-6 flex flex-col flex-1">
                  <div class="flex items-center gap-3 mb-3">
                    <span class="text-xs font-medium text-primary bg-primary/10 px-3 py-1">{categoryLabels[related.data.category] || related.data.category}</span>
                    {related.data.readingTime && (
                      <span class="text-xs text-muted-foreground">🕐 {related.data.readingTime}</span>
                    )}
                  </div>
                  <h3 class="font-serif text-lg md:text-xl font-semibold text-foreground mb-2 group-hover:text-primary transition-colors">
                    {related.data.title}
                  </h3>
                  <p class="text-muted-foreground text-sm leading-relaxed mb-4 flex-1">{related.data.description || related.data.excerpt}</p>
                  <div class="flex items-center text-primary text-sm font-medium group-hover:gap-2 transition-all">
                    Artikel lesen
                    <svg class="ml-1 h-4 w-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>

        <div class="text-center mt-10 md:mt-12">
          <a href="/blog" class="inline-flex items-center justify-center border border-primary text-primary hover:bg-primary/10 px-6 py-2.5 font-medium transition-colors">
            Alle Artikel ansehen
            <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </section>
  )}
</Layout>

<style is:global>
  .prose-custom h2 {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    color: hsl(var(--foreground));
    margin-top: 3rem;
    margin-bottom: 1rem;
  }
  @media (min-width: 768px) {
    .prose-custom h2 { font-size: 1.875rem; }
  }
  .prose-custom h3 {
    font-family: var(--font-serif);
    font-size: 1.375rem;
    font-weight: 600;
    color: hsl(var(--foreground));
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }
  @media (min-width: 768px) {
    .prose-custom h3 { font-size: 1.75rem; }
  }
  .prose-custom h4 {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 600;
    color: hsl(var(--foreground));
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }
  @media (min-width: 768px) {
    .prose-custom h4 { font-size: 1.375rem; }
  }
  .prose-custom p {
    color: hsl(var(--foreground) / 0.9);
    line-height: 1.75;
    font-size: 1.125rem;
    margin-bottom: 1.5rem;
  }
  .prose-custom strong {
    color: hsl(var(--foreground));
    font-weight: 600;
  }
  .prose-custom em { font-style: italic; }
  .prose-custom ul {
    list-style-type: '–  ';
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
    color: hsl(var(--foreground) / 0.9);
    font-size: 1.125rem;
  }
  .prose-custom ul li {
    line-height: 1.75;
    margin-bottom: 0.5rem;
  }
  .prose-custom ol {
    list-style-type: decimal;
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
    color: hsl(var(--foreground) / 0.9);
    font-size: 1.125rem;
  }
  .prose-custom ol li {
    line-height: 1.75;
    margin-bottom: 0.5rem;
  }
  .prose-custom blockquote {
    background: hsl(45, 48%, 88%);
    border-left: 5px solid hsl(var(--primary));
    border-radius: 0;
    padding: 1.5rem 2rem;
    margin: 2.5rem 0;
    color: hsl(var(--foreground) / 0.9);
    font-style: italic;
    font-size: 1.125rem;
    line-height: 1.8;
    position: relative;
    box-shadow: 0 2px 8px rgb(0 0 0 / 0.06);
  }
  .prose-custom blockquote::before {
    content: '\201E';
    position: absolute;
    top: -8px;
    left: 16px;
    font-size: 3.5rem;
    color: hsl(var(--primary) / 0.25);
    font-family: var(--font-serif);
    line-height: 1;
  }
  .prose-custom blockquote p {
    margin-bottom: 0.5rem !important;
    font-size: 1.125rem !important;
  }
  .prose-custom blockquote p:last-child {
    margin-bottom: 0 !important;
  }
  .prose-custom img {
    width: 100%;
    box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1);
    margin: 2.5rem 0;
  }
  .prose-custom a {
    color: hsl(var(--primary));
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: opacity 0.2s;
  }
  .prose-custom a:hover { opacity: 0.8; }
  .prose-custom figure { margin: 2.5rem 0; }
  .prose-custom hr {
    margin: 2.5rem 0;
    border-color: hsl(var(--border));
  }

  /* WhatsApp-style testimonial bubbles — dark bubbles on white */
  .prose-custom .testimonial-wrapper {
    padding: 0.5rem 0;
    margin: 2rem 0;
  }
  .prose-custom .testimonial-bubble {
    background: #202C33;
    color: #E9EDEF;
    padding: 0.625rem 0.75rem 0.5rem;
    border-radius: 0 8px 8px 8px;
    margin: 0.75rem 0;
    position: relative;
    max-width: 88%;
    box-shadow: 0 1px 1px rgb(0 0 0 / 0.2);
  }
  .prose-custom .testimonial-bubble::before {
    content: '';
    position: absolute;
    top: 0;
    left: -8px;
    width: 0;
    height: 0;
    border-top: 0 solid transparent;
    border-right: 8px solid #202C33;
    filter: drop-shadow(0 1px 2px rgb(0 0 0 / 0.08));
    border-bottom: 8px solid transparent;
  }
  .prose-custom .testimonial-text {
    color: #E9EDEF !important;
    font-style: normal;
    font-size: 0.9375rem !important;
    line-height: 1.55 !important;
    margin-bottom: 0.25rem !important;
  }
  .prose-custom .testimonial-author {
    color: #8696A0 !important;
    font-size: 0.75rem !important;
    font-style: normal;
    margin-bottom: 0 !important;
  }
</style>
