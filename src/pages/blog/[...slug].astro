---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

// Format date to German
const formatDate = (date: Date) => {
  const months = ['Januar', 'Februar', 'März', 'April', 'Mai', 'Juni', 'Juli', 'August', 'September', 'Oktober', 'November', 'Dezember'];
  return `${date.getDate()}. ${months[date.getMonth()]} ${date.getFullYear()}`;
};

// Category display names
const categoryLabels: Record<string, string> = {
  'rolle-identitaet': 'Rolle & Identität',
  'partnerschaft': 'Partnerschaft',
  'ex-und-system': 'Die Ex & das System',
  'kinder-bindung': 'Kinder & Bindung',
};

// Related posts: same category, max 3
const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter((p) => p.slug !== post.slug)
  .sort((a, b) => {
    if (a.data.category === post.data.category && b.data.category !== post.data.category) return -1;
    if (b.data.category === post.data.category && a.data.category !== post.data.category) return 1;
    return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
  })
  .slice(0, 3);
---

<Layout 
  title={post.data.metaTitle || post.data.title}
  description={post.data.metaDescription || post.data.excerpt}
  canonical={`https://stiefundgluecklich.de/blog/${post.slug}`}
>
  <article class="pt-28 md:pt-32 pb-16">
    <div class="container mx-auto px-5 md:px-6">
      <!-- Back Link -->
      <a href="/blog" class="inline-flex items-center text-muted-foreground hover:text-primary transition-colors mb-8 md:mb-10">
        <svg class="mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Zurück zum Blog
      </a>

      <div class="max-w-[700px] mx-auto">
        <!-- Category Badge -->
        <span class="text-sm font-medium text-primary bg-primary/10 px-4 py-1.5">
          {categoryLabels[post.data.category] || post.data.category}
        </span>

        <!-- Title -->
        <h1 class="font-serif text-3xl md:text-4xl lg:text-5xl text-foreground mt-6 mb-4">
          {post.data.title}
        </h1>

        <!-- Meta -->
        <div class="flex items-center gap-4 text-muted-foreground text-sm mb-8 md:mb-12">
          {post.data.readingTime && (
            <span class="flex items-center gap-1.5">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="10" /><path d="M12 6v6l4 2" />
              </svg>
              {post.data.readingTime} Lesezeit
            </span>
          )}
          <span>·</span>
          <span>{formatDate(new Date(post.data.date))}</span>
        </div>

        <!-- Hero Image -->
        {post.data.image && (
          <figure class="mb-10 md:mb-12">
            <img 
              src={post.data.image} 
              alt={post.data.imageAlt || post.data.title}
              class="w-full shadow-lg"
              loading="eager"
            />
          </figure>
        )}

        <!-- Article Content -->
        <div class="prose-custom">
          <Content />
        </div>

        <!-- Podcast Reference -->
        {post.data.podcastEpisode && (
          <div class="mt-16 p-6 md:p-8 bg-secondary/50 border border-border">
            <div class="flex items-center gap-2 text-primary mb-3">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.536 8.464a5 5 0 010 7.072M12 12h.01M18.364 5.636a9 9 0 010 12.728M6 15H4a1 1 0 01-1-1V10a1 1 0 011-1h2l3.5-4.5A.5.5 0 0110 4.8v14.4a.5.5 0 01-.832.374L5.668 15" />
              </svg>
              <span class="font-medium text-sm uppercase tracking-wide">Mehr dazu im Podcast</span>
            </div>
            {post.data.podcastTitle && (
              <h3 class="font-serif text-xl text-foreground mb-2">{post.data.podcastTitle}</h3>
            )}
            {post.data.podcastDescription && (
              <p class="text-muted-foreground text-sm leading-relaxed mb-4">{post.data.podcastDescription}</p>
            )}
            <a
              href={post.data.podcastEpisode}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center text-primary font-medium text-sm hover:opacity-80 transition-opacity"
            >
              Auf Spotify anhören
              <svg class="ml-1.5 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        )}

        <!-- Quiz CTA -->
        <div class="mt-16 bg-primary text-primary-foreground py-12 px-6 md:px-14 text-center shadow-lg">
          <h2 class="font-serif text-xl md:text-2xl lg:text-3xl font-semibold mb-3">
            Nicht sicher, was jetzt dein nächster Schritt ist?
          </h2>
          <p class="text-primary-foreground/80 mb-6 md:mb-8 max-w-lg mx-auto">
            Das Quiz zeigt's dir — in 2 Minuten.
          </p>
          <a href="/quiz" class="inline-flex items-center justify-center bg-background text-foreground hover:bg-background/90 px-8 py-3 text-base font-medium transition-colors">
            Finde deinen nächsten Schritt →
          </a>
        </div>
      </div>
    </div>
  </article>

  <!-- Related Articles -->
  {relatedPosts.length > 0 && (
    <section class="py-16 md:py-20 bg-secondary/20">
      <div class="container mx-auto px-5 md:px-6">
        <h2 class="font-serif text-2xl md:text-3xl text-foreground mb-8 md:mb-10">
          Das könnte dich auch <span class="italic text-gold-bright">interessieren</span>
        </h2>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
          {relatedPosts.map((related) => (
            <a href={`/blog/${related.slug}`} class="group">
              <div class="border border-border overflow-hidden hover:shadow-xl transition-all duration-300 cursor-pointer h-full flex flex-col">
                {related.data.image && (
                  <div class="aspect-[16/10] overflow-hidden bg-secondary">
                    <img 
                      src={related.data.image} 
                      alt={related.data.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                      loading="lazy"
                    />
                  </div>
                )}
                <div class="p-5 md:p-6 flex flex-col flex-1">
                  <div class="flex items-center gap-3 mb-3">
                    <span class="text-xs font-medium text-primary bg-primary/10 px-3 py-1">{categoryLabels[related.data.category] || related.data.category}</span>
                    {related.data.readingTime && (
                      <span class="text-xs text-muted-foreground">🕐 {related.data.readingTime}</span>
                    )}
                  </div>
                  <h3 class="font-serif text-lg md:text-xl font-semibold text-foreground mb-2 group-hover:text-primary transition-colors">
                    {related.data.title}
                  </h3>
                  <p class="text-muted-foreground text-sm leading-relaxed mb-4 flex-1">{related.data.excerpt}</p>
                  <div class="flex items-center text-primary text-sm font-medium group-hover:gap-2 transition-all">
                    Artikel lesen
                    <svg class="ml-1 h-4 w-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>

        <div class="text-center mt-10 md:mt-12">
          <a href="/blog" class="inline-flex items-center justify-center border border-primary text-primary hover:bg-primary/10 px-6 py-2.5 font-medium transition-colors">
            Alle Artikel ansehen
            <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </section>
  )}
</Layout>

<style is:global>
  .prose-custom h2 {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    color: hsl(var(--foreground));
    margin-top: 3rem;
    margin-bottom: 1rem;
  }
  @media (min-width: 768px) {
    .prose-custom h2 { font-size: 1.875rem; }
  }
  .prose-custom h3 {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    color: hsl(var(--foreground));
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  @media (min-width: 768px) {
    .prose-custom h3 { font-size: 1.5rem; }
  }
  .prose-custom p {
    color: hsl(var(--foreground) / 0.9);
    line-height: 1.75;
    font-size: 1.125rem;
    margin-bottom: 1.5rem;
  }
  .prose-custom strong {
    color: hsl(var(--foreground));
    font-weight: 600;
  }
  .prose-custom em { font-style: italic; }
  .prose-custom ul {
    list-style-type: disc;
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
    color: hsl(var(--foreground) / 0.9);
    font-size: 1.125rem;
  }
  .prose-custom ul li {
    line-height: 1.75;
    margin-bottom: 0.5rem;
  }
  .prose-custom ol {
    list-style-type: decimal;
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
    color: hsl(var(--foreground) / 0.9);
    font-size: 1.125rem;
  }
  .prose-custom ol li {
    line-height: 1.75;
    margin-bottom: 0.5rem;
  }
  .prose-custom blockquote {
    background: hsl(var(--secondary));
    border-left: 4px solid hsl(var(--primary));
    border-radius: 0 12px 12px 0;
    padding: 1.25rem 1.5rem;
    margin: 2rem 0;
    color: hsl(var(--foreground) / 0.85);
    font-style: italic;
    font-size: 1.0625rem;
    line-height: 1.7;
    position: relative;
  }
  .prose-custom blockquote p {
    margin-bottom: 0.5rem !important;
    font-size: 1.0625rem !important;
  }
  .prose-custom blockquote p:last-child {
    margin-bottom: 0 !important;
  }
  .prose-custom img {
    width: 100%;
    box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1);
    margin: 2.5rem 0;
  }
  .prose-custom a {
    color: hsl(var(--primary));
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: opacity 0.2s;
  }
  .prose-custom a:hover { opacity: 0.8; }
  .prose-custom figure { margin: 2.5rem 0; }
  .prose-custom hr {
    margin: 2.5rem 0;
    border-color: hsl(var(--border));
  }
</style>
