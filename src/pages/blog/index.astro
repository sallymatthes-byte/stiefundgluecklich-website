---
import Layout from '../../layouts/Layout.astro'
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');

// Sort by date descending
const blogPosts = allPosts.sort((a, b) => 
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const categories = ["Alle", "Rolle & Identität", "Partnerschaft", "Die Ex & das System", "Kinder & Bindung"];

const categoryLabels: Record<string, string> = {
  'rolle-identitaet': 'Rolle & Identität',
  'partnerschaft': 'Partnerschaft',
  'ex-und-system': 'Die Ex & das System',
  'kinder-bindung': 'Kinder & Bindung',
};
---

<Layout 
  title="Blog"
  description="Klartext für Bonusmamas — Artikel, die aussprechen was du schon weißt und dir zeigen, was du tun kannst."
  canonical="https://stiefundgluecklich.de/blog"
>
  <!-- Hero -->
  <section class="pt-28 md:pt-32 pb-12 md:pb-16 bg-secondary/30">
    <div class="container mx-auto px-5 md:px-6">
      <div class="max-w-3xl">
        <p class="text-primary font-medium mb-3 md:mb-4 text-sm md:text-base">Blog</p>
        <h1 class="font-serif text-3xl md:text-5xl lg:text-6xl text-foreground mb-4 md:mb-6">
          <span class="italic text-gold-bright">Klartext</span> für Bonusmamas
        </h1>
        <p class="text-base md:text-lg text-muted-foreground leading-relaxed">
          Kein Aufmuntern, kein Schönreden. Artikel, die aussprechen was du schon weißt — und dir zeigen, was du tun kannst.
        </p>
      </div>
    </div>
  </section>

  <!-- Category Filter -->
  <section class="py-6 md:py-8 border-b border-border sticky top-[65px] bg-background/95 backdrop-blur-sm z-40">
    <div class="container mx-auto px-5 md:px-6">
      <div class="flex flex-wrap gap-2 md:gap-3" id="category-filters">
        {categories.map((cat, i) => (
          <button
            class={`category-btn px-3 md:px-4 py-1.5 md:py-2 text-sm font-medium transition-colors ${
              i === 0 ? 'bg-primary text-primary-foreground' : 'border border-border text-muted-foreground hover:text-foreground hover:border-primary'
            }`}
            data-category={cat}
          >
            {cat}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Blog Grid -->
  <section class="py-12 md:py-16">
    <div class="container mx-auto px-5 md:px-6">
      {blogPosts.length === 0 ? (
        <div class="text-center py-16">
          <p class="text-muted-foreground text-lg">Noch keine Artikel vorhanden.</p>
        </div>
      ) : (
        <>
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8" id="blog-grid">
            {blogPosts.map((post, index) => (
              <a href={`/blog/${post.slug}`} class="blog-card group" data-category={categoryLabels[post.data.category] || post.data.category} data-index={index}>
                <div class="border border-border overflow-hidden hover:shadow-xl transition-all duration-300 cursor-pointer h-full flex flex-col">
                  {post.data.image && (
                    <div class="aspect-[16/10] overflow-hidden bg-secondary">
                      <img 
                        src={post.data.image} 
                        alt={post.data.title} 
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" 
                        loading="lazy" 
                      />
                    </div>
                  )}
                  <div class="p-5 md:p-6 flex flex-col flex-1">
                    <div class="flex items-center gap-3 md:gap-4 mb-3">
                      <span class="text-xs font-medium text-primary bg-primary/10 px-3 py-1">{categoryLabels[post.data.category] || post.data.category}</span>
                      {post.data.readingTime && (
                        <span class="text-xs text-muted-foreground">🕐 {post.data.readingTime}</span>
                      )}
                    </div>
                    <h2 class="font-serif text-lg md:text-xl font-semibold text-foreground mb-2 group-hover:text-primary transition-colors">
                      {post.data.title}
                    </h2>
                    <p class="text-muted-foreground text-sm leading-relaxed mb-4 flex-1">{post.data.description || post.data.excerpt}</p>
                    <div class="flex items-center text-primary text-sm font-medium group-hover:gap-2 transition-all">
                      Artikel lesen
                      <svg class="ml-1 h-4 w-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                      </svg>
                    </div>
                  </div>
                </div>
              </a>
            ))}
          </div>
          <div class="text-center mt-10" id="show-more-wrapper" style="display:none;">
            <button id="show-more-btn" class="inline-flex items-center justify-center border border-primary text-primary hover:bg-primary/10 px-6 py-2.5 font-medium transition-colors">
              Weitere Artikel anzeigen
              <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
          </div>
        </>
      )}
    </div>
  </section>

  <!-- Quiz CTA -->
  <section class="py-12 md:py-16 bg-secondary/30">
    <div class="container mx-auto px-5 md:px-6">
      <div class="max-w-3xl mx-auto bg-primary text-primary-foreground py-10 md:py-12 px-6 md:px-14 text-center shadow-lg">
        <h2 class="font-serif text-xl md:text-2xl lg:text-3xl font-semibold mb-3">
          Nicht sicher, was jetzt dein nächster Schritt ist?
        </h2>
        <p class="text-primary-foreground/80 mb-6 md:mb-8 max-w-lg mx-auto">
          Das Quiz zeigt's dir — in 2 Minuten.
        </p>
        <a href="/quiz"
          class="inline-flex items-center justify-center bg-background text-foreground hover:bg-background/90 px-8 py-3 text-base font-medium transition-colors">
          Zum Quiz →
        </a>
      </div>
    </div>
  </section>
</Layout>

<script>
  const INITIAL_SHOW = 3;
  let expanded = false;
  let currentCat = 'Alle';

  function applyFilter() {
    const cards = document.querySelectorAll('.blog-card') as NodeListOf<HTMLElement>;
    let visibleCount = 0;
    let totalVisible = 0;

    cards.forEach(card => {
      const cardCat = card.dataset.category;
      const matches = currentCat === 'Alle' || cardCat === currentCat;
      
      if (matches) {
        totalVisible++;
        if (expanded || visibleCount < INITIAL_SHOW) {
          card.style.display = '';
          visibleCount++;
        } else {
          card.style.display = 'none';
        }
      } else {
        card.style.display = 'none';
      }
    });

    const wrapper = document.getElementById('show-more-wrapper') as HTMLElement;
    const btn = document.getElementById('show-more-btn') as HTMLElement;
    if (totalVisible > INITIAL_SHOW && !expanded) {
      wrapper.style.display = '';
      btn.textContent = `Weitere ${totalVisible - INITIAL_SHOW} Artikel anzeigen`;
    } else {
      wrapper.style.display = 'none';
    }
  }

  document.querySelectorAll('.category-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      currentCat = (btn as HTMLElement).dataset.category || 'Alle';
      expanded = false;
      
      document.querySelectorAll('.category-btn').forEach(b => {
        b.className = 'category-btn px-3 md:px-4 py-1.5 md:py-2 text-sm font-medium transition-colors border border-border text-muted-foreground hover:text-foreground hover:border-primary';
      });
      btn.className = 'category-btn px-3 md:px-4 py-1.5 md:py-2 text-sm font-medium transition-colors bg-primary text-primary-foreground';
      
      applyFilter();
    });
  });

  document.getElementById('show-more-btn')?.addEventListener('click', () => {
    expanded = true;
    applyFilter();
  });

  // Initial state: show 3
  applyFilter();
</script>
