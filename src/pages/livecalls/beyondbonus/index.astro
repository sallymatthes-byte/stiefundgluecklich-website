---
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import { getAccessSnapshot } from '../../../lib/auth/grants';
import { loadUserGrants } from '../../../lib/auth/load-grants';

const grants = await loadUserGrants(Astro);
const access = getAccessSnapshot(grants, 'beyondbonus');

if (!access.livecalls) {
  return Astro.redirect('/members?error=no-access');
}

const recordings: string[] = [];
---

<Layout
  title="BeyondBonus Livecalls"
  canonical="https://stiefundgluecklich.de/livecalls/beyondbonus/"
  description="Geschützter Livecall- und Aufzeichnungsbereich für BeyondBonus."
  noHeader={true}
>
  <section class="py-20 md:py-28">
    <div class="container mx-auto px-5 md:px-6 max-w-5xl">
      <a href="/members" class="inline-flex items-center text-sm text-muted-foreground hover:text-primary transition-colors mb-6">
        ← Zurück zum Mitgliederbereich
      </a>

      <p class="text-sm uppercase tracking-[0.2em] text-muted-foreground mb-4">BeyondBonus</p>
      <h1 class="font-serif text-3xl md:text-4xl mb-4">Livecalls & Aufzeichnungen</h1>
      <p class="text-base text-muted-foreground mb-8 leading-relaxed max-w-3xl">
        Hier sammeln wir die Aufzeichnungen deiner freigeschalteten BeyondBonus-Livecalls. Wenn eine neue Aufzeichnung bereitsteht, findest du sie künftig direkt hier.
      </p>

      {recordings.length === 0 ? (
        <div class="border border-border p-7 md:p-8 bg-secondary/25 space-y-3 max-w-3xl">
          <p class="text-xs uppercase tracking-[0.18em] text-muted-foreground">Noch keine Aufzeichnung hinterlegt</p>
          <h2 class="font-serif text-2xl">Die Livecall-Aufzeichnungen werden gerade vorbereitet.</h2>
          <p class="text-sm text-muted-foreground leading-relaxed">
            Dein Zugang ist aktiv. Sobald die Aufzeichnungen im Mitgliederbereich ergänzt sind, erscheinen sie an dieser Stelle.
          </p>
        </div>
      ) : (
        <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          {recordings.map((recording, index) => (
            <div class="border border-border p-5 bg-background space-y-3">
              <p class="text-xs uppercase tracking-[0.18em] text-muted-foreground">Aufzeichnung {String(index + 1).padStart(2, '0')}</p>
              <h2 class="font-serif text-xl">{recording}</h2>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>
</Layout>
