---
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import { getAccessSnapshot } from '../../../lib/auth/grants';
import { loadUserGrants } from '../../../lib/auth/load-grants';
import { livecallCoverImage } from '../../../lib/beyondbonus/livecalls';
import { loadBeyondBonusLivecalls } from '../../../lib/beyondbonus/admin-content';

const runtimeEnv = (Astro.locals as any).runtime?.env;
const grants = await loadUserGrants(Astro);
const access = getAccessSnapshot(grants, 'beyondbonus');

if (!access.livecalls) {
  return Astro.redirect('/members?error=no-access');
}

const recordings = await loadBeyondBonusLivecalls(runtimeEnv);
const totalMinutes = recordings.reduce((sum, recording) => sum + Number(recording.durationLabel.match(/\d+/)?.[0] || 0), 0);
---

<Layout
  title="BeyondBonus Livecalls"
  canonical="https://stiefundgluecklich.de/livecalls/beyondbonus/"
  description="Geschützter Livecall- und Aufzeichnungsbereich für BeyondBonus."
  noHeader={true}
>
  <section class="py-14 md:py-24">
    <div class="container mx-auto px-4 sm:px-5 md:px-6 max-w-5xl">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between mb-7">
        <a href="/members" class="inline-flex items-center text-sm text-muted-foreground hover:text-primary transition-colors">
          ← Zurück zum Mitgliederbereich
        </a>
        <a href="/members/app" class="inline-flex w-fit px-4 py-2 text-sm font-medium border border-border hover:bg-secondary/40 transition-colors">
          Auf dem Handy wie eine App nutzen
        </a>
      </div>

      <header class="relative overflow-hidden border border-border bg-foreground text-background mb-8 shadow-[0_16px_38px_rgba(0,0,0,0.08)]">
        <div class="absolute inset-0 opacity-25">
          <img src={livecallCoverImage} alt="" class="h-full w-full object-cover blur-sm scale-105" />
        </div>
        <div class="relative grid gap-6 p-5 sm:p-7 md:grid-cols-[170px_minmax(0,1fr)] md:items-center md:p-8">
          <img src={livecallCoverImage} alt="Livecalls" class="w-full max-w-[180px] border border-background/25 shadow-[0_12px_32px_rgba(0,0,0,0.25)]" />
          <div class="space-y-3">
            <p class="text-xs uppercase tracking-[0.22em] text-background/65">BeyondBonus</p>
            <h1 class="font-serif text-3xl md:text-4xl leading-tight">Livecalls & Aufzeichnungen</h1>
            <p class="text-sm md:text-base text-background/78 leading-relaxed max-w-2xl">
              Hier findest du deine freigeschalteten Livecall-Aufzeichnungen mit den wichtigsten Themen auf einen Blick.
            </p>
            <p class="text-sm text-background/70">{recordings.length} Aufzeichnungen · ca. {totalMinutes} Minuten</p>
          </div>
        </div>
      </header>

      {recordings.length === 0 ? (
        <div class="border border-border p-7 md:p-8 bg-secondary/25 space-y-3 max-w-3xl">
          <p class="text-xs uppercase tracking-[0.18em] text-muted-foreground">Noch keine Aufzeichnung hinterlegt</p>
          <h2 class="font-serif text-2xl">Die Livecall-Aufzeichnungen werden gerade vorbereitet.</h2>
          <p class="text-sm text-muted-foreground leading-relaxed">
            Dein Zugang ist aktiv. Sobald die Aufzeichnungen im Mitgliederbereich ergänzt sind, erscheinen sie an dieser Stelle.
          </p>
        </div>
      ) : (
        <div class="border border-border bg-background p-4 sm:p-6 md:p-7 shadow-[0_10px_24px_rgba(0,0,0,0.03)]">
          <div class="flex items-center gap-3 mb-6">
            <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-primary/12 text-primary">
              <span aria-hidden="true">▶</span>
            </div>
            <div>
              <h2 class="font-serif text-2xl leading-tight">Aufzeichnungen</h2>
              <p class="text-sm text-muted-foreground">Öffne genau den Call, der gerade zu deiner Situation passt.</p>
            </div>
          </div>

          <div class="space-y-3">
            {recordings.map((recording, index) => (
              <a
                href={`/livecalls/beyondbonus/${recording.slug}`}
                class="group grid gap-4 border border-border/80 bg-background p-3 transition-colors hover:bg-secondary/25 sm:grid-cols-[96px_minmax(0,1fr)_auto] sm:items-center sm:p-4"
              >
                <img src={livecallCoverImage} alt="" class="h-20 w-full object-cover sm:h-16 sm:w-24 border border-border/60" />
                <div class="min-w-0 space-y-1">
                  <p class="text-xs uppercase tracking-[0.16em] text-muted-foreground">Aufzeichnung {String(index + 1).padStart(2, '0')} · {recording.dateLabel}</p>
                  <h3 class="font-serif text-xl leading-tight group-hover:text-primary transition-colors">{recording.title}</h3>
                  <p class="text-sm text-muted-foreground leading-relaxed line-clamp-2">{recording.description}</p>
                  <p class="text-xs text-muted-foreground">{recording.durationLabel}</p>
                </div>
                <span class="hidden sm:inline-flex text-sm text-muted-foreground group-hover:text-primary transition-colors">Öffnen →</span>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>
</Layout>
