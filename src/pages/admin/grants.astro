---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { isAdminEmail } from '../../lib/admin/access';
import { createSupabaseAdminClient } from '../../lib/supabase/admin';
import { beyondBonusModules } from '../../lib/beyondbonus/content';

const runtimeEnv = (Astro.locals as any).runtime?.env;

if (!isAdminEmail(Astro.locals.user?.email, runtimeEnv)) {
  return Astro.redirect('/members?error=no-access');
}

const admin = createSupabaseAdminClient(runtimeEnv);
const saved = Astro.url.searchParams.get('saved') === '1';
const created = Astro.url.searchParams.get('created') === '1';
const resetSent = Astro.url.searchParams.get('reset') === 'sent';
const deleted = Astro.url.searchParams.get('deleted') === '1';
const savedEmail = Astro.url.searchParams.get('email');
const error = Astro.url.searchParams.get('error');
const query = Astro.url.searchParams.get('q')?.trim() || '';

let profiles: any[] = [];
let grants: any[] = [];
let usersById: Record<string, any> = {};
let progressByUser: Record<string, number> = {};

const totalBeyondBonusLessons = beyondBonusModules.reduce((sum, module) => sum + module.lessons.length, 0);

if (admin) {
  let profileQuery = admin
    .from('profiles')
    .select('id, email, full_name, created_at')
    .order('created_at', { ascending: false })
    .limit(25);

  if (query) {
    profileQuery = profileQuery.or(`email.ilike.%${query}%,full_name.ilike.%${query}%`);
  }

  const { data: profileData } = await profileQuery;
  profiles = profileData || [];

  if (profiles.length > 0) {
    const { data: grantData } = await admin
      .from('access_grants')
      .select('id, user_id, product_key, area, status, starts_at, ends_at, source, note, updated_at')
      .in('user_id', profiles.map((profile) => profile.id))
      .order('updated_at', { ascending: false });
    grants = grantData || [];

    const { data: progressData } = await admin
      .from('member_lesson_progress')
      .select('user_id, lesson_key, completed')
      .in('user_id', profiles.map((profile) => profile.id))
      .eq('product_key', 'beyondbonus')
      .eq('completed', true);

    progressByUser = (progressData || []).reduce((acc: Record<string, number>, entry: any) => {
      acc[entry.user_id] = (acc[entry.user_id] || 0) + 1;
      return acc;
    }, {});
  }

  const { data: users } = await admin.auth.admin.listUsers({ page: 1, perPage: 1000 });
  usersById = (users?.users || []).reduce((acc: Record<string, any>, user: any) => {
    acc[user.id] = user;
    return acc;
  }, {});
}

const grantsByUser = grants.reduce((acc: Record<string, any[]>, grant: any) => {
  acc[grant.user_id] ||= [];
  acc[grant.user_id].push(grant);
  return acc;
}, {});

const today = new Date().toISOString().slice(0, 10);
const sixMonths = new Date();
sixMonths.setMonth(sixMonths.getMonth() + 6);
const twelveMonths = new Date();
twelveMonths.setMonth(twelveMonths.getMonth() + 12);
---

<Layout title="Admin · Zugänge" canonical="https://stiefundgluecklich.de/admin/grants/" noHeader={true}>
  <section class="py-14 md:py-20">
    <div class="container mx-auto px-5 md:px-6 max-w-[1080px] space-y-10">
      <header class="space-y-3">
        <p class="text-sm uppercase tracking-[0.2em] text-muted-foreground">Admin</p>
        <h1 class="font-serif text-4xl md:text-5xl leading-none">Zugänge verwalten</h1>
        <p class="text-muted-foreground max-w-2xl leading-relaxed">
          Hier kannst du Kundinnen manuell anlegen, Kurszugänge freischalten, pausieren oder löschen.
        </p>
      </header>

      {!admin && (
        <div class="border border-red-200 bg-red-50 p-5 text-sm leading-relaxed">
          Supabase Admin ist noch nicht konfiguriert. Es fehlt `SUPABASE_SECRET_KEY` oder `SUPABASE_SERVICE_ROLE_KEY` in der Server-Umgebung.
        </div>
      )}

      {saved && (
        <div class="border border-border bg-secondary/30 p-5 text-sm leading-relaxed">
          Zugang für <strong>{savedEmail}</strong> wurde gespeichert.{created ? ' Der Account wurde neu angelegt.' : ''}
        </div>
      )}

      {resetSent && (
        <div class="border border-border bg-secondary/30 p-5 text-sm leading-relaxed">
          Passwort-Mail für <strong>{savedEmail}</strong> wurde gesendet.
        </div>
      )}

      {deleted && (
        <div class="border border-border bg-secondary/30 p-5 text-sm leading-relaxed">
          Zugang für <strong>{savedEmail}</strong> wurde gelöscht.
        </div>
      )}

      {error && (
        <div class="border border-red-200 bg-red-50 p-5 text-sm leading-relaxed">
          Speichern nicht möglich: {error}
        </div>
      )}

      <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_360px] lg:items-start">
        <section class="border border-border bg-background p-6 md:p-7 space-y-6 shadow-[0_10px_24px_rgba(0,0,0,0.02)]">
          <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4">
            <div>
              <h2 class="font-serif text-3xl leading-tight">Aktuelle Zugänge</h2>
              <p class="text-sm text-muted-foreground mt-1">Letzte Profile, optional nach Name oder E-Mail gefiltert.</p>
            </div>
            <form method="GET" action="/admin/grants" class="flex gap-2">
              <input name="q" value={query} placeholder="Suchen ..." class="border border-border bg-white px-3 py-2 text-sm focus:outline-none focus:border-primary" />
              <button class="border border-border px-4 py-2 text-sm hover:bg-secondary/40">Suchen</button>
            </form>
          </div>

          <div class="space-y-3">
            {profiles.length === 0 ? (
              <p class="text-sm text-muted-foreground">Noch keine Profile gefunden.</p>
            ) : profiles.map((profile) => {
              const user = usersById[profile.id];
              const userGrants = grantsByUser[profile.id] || [];
              const activeCount = userGrants.filter((grant) => grant.status === 'active').length;
              const pausedCount = userGrants.filter((grant) => grant.status === 'paused').length;
              const expiredCount = userGrants.filter((grant) => grant.status === 'expired').length;
              const completedLessons = progressByUser[profile.id] || 0;
              const progressPercent = totalBeyondBonusLessons ? Math.round((completedLessons / totalBeyondBonusLessons) * 100) : 0;
              const lastLogin = user?.last_sign_in_at ? new Date(user.last_sign_in_at).toLocaleString('de-DE') : 'Noch nie';
              const mailto = `mailto:${profile.email}?subject=${encodeURIComponent('Frage zu deinem BeyondBonus-Zugang')}`;

              return (
                <details class="group border border-border/80 bg-background shadow-[0_6px_16px_rgba(0,0,0,0.015)]">
                  <summary class="cursor-pointer list-none p-4 hover:bg-secondary/20 transition-colors">
                    <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
                      <div class="min-w-0">
                        <div class="flex flex-wrap items-center gap-2">
                          <h3 class="font-serif text-xl leading-tight">{profile.full_name || 'Ohne Namen'}</h3>
                          <span class="text-[0.7rem] uppercase tracking-[0.14em] text-muted-foreground">Details öffnen</span>
                        </div>
                        <p class="text-sm text-muted-foreground break-all">{profile.email}</p>
                      </div>

                      <div class="grid grid-cols-2 gap-2 text-xs md:grid-cols-3 md:min-w-[360px]">
                        <div class="border border-border/70 bg-secondary/20 px-3 py-2">
                          <p class="uppercase tracking-[0.12em] text-muted-foreground">Status</p>
                          <p>{activeCount} aktiv · {pausedCount} pausiert</p>
                        </div>
                        <div class="border border-border/70 bg-secondary/20 px-3 py-2">
                          <p class="uppercase tracking-[0.12em] text-muted-foreground">Login</p>
                          <p>{lastLogin}</p>
                        </div>
                        <div class="border border-border/70 bg-secondary/20 px-3 py-2 col-span-2 md:col-span-1">
                          <p class="uppercase tracking-[0.12em] text-muted-foreground">Fortschritt</p>
                          <p>{progressPercent}% · {completedLessons}/{totalBeyondBonusLessons}</p>
                          <div class="mt-1 h-1.5 bg-background overflow-hidden"><div class="h-full bg-primary" style={`width:${progressPercent}%`}></div></div>
                        </div>
                      </div>
                    </div>
                  </summary>

                  <div class="border-t border-border/70 p-4 space-y-4 bg-secondary/5">
                    <div class="flex flex-wrap gap-2 text-xs">
                      <a href={`/admin/grants?q=${encodeURIComponent(profile.email || '')}`} class="border border-border bg-white px-3 py-2 hover:bg-secondary/40">Nur diese Kundin anzeigen</a>
                      <form method="POST" action="/api/admin/grants/action">
                        <input type="hidden" name="action" value="reset-password" />
                        <input type="hidden" name="email" value={profile.email} />
                        <button class="border border-border bg-white px-3 py-2 hover:bg-secondary/40">Passwort-Mail senden</button>
                      </form>
                      <a href={mailto} class="border border-border bg-white px-3 py-2 hover:bg-secondary/40">E-Mail schreiben</a>
                      <a href="/login" class="border border-border bg-white px-3 py-2 hover:bg-secondary/40">Login-Link öffnen</a>
                    </div>

                    {userGrants.length > 0 ? (
                      <div class="space-y-2 text-sm">
                        <p class="text-xs uppercase tracking-[0.14em] text-muted-foreground">Zugänge</p>
                        {userGrants.map((grant) => (
                          <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-2 border border-border/70 bg-white p-3">
                            <span>{grant.product_key} · {grant.area} · {grant.source} · bis {grant.ends_at ? new Date(grant.ends_at).toLocaleDateString('de-DE') : 'ohne Ende'}</span>
                            <form method="POST" action="/api/admin/grants/action" class="flex items-center gap-2">
                              <input type="hidden" name="action" value="update-grant-status" />
                              <input type="hidden" name="grant_id" value={grant.id} />
                              <input type="hidden" name="email" value={profile.email} />
                              <select name="status" class="border border-border bg-white px-2 py-1 text-xs">
                                <option value="active" selected={grant.status === 'active'}>aktiv</option>
                                <option value="paused" selected={grant.status === 'paused'}>pausiert</option>
                                <option value="expired" selected={grant.status === 'expired'}>abgelaufen</option>
                              </select>
                              <button class="border border-border px-2 py-1 text-xs hover:bg-secondary/40">Speichern</button>
                            </form>
                          </div>
                        ))}
                      </div>
                    ) : (
                      <p class="text-sm text-muted-foreground">Keine Grants sichtbar.</p>
                    )}

                    <details class="border border-red-200 bg-red-50/50 p-3 text-xs">
                      <summary class="cursor-pointer text-red-800">Zugang dauerhaft löschen</summary>
                      <form method="POST" action="/api/admin/grants/action" class="mt-3 space-y-2">
                        <input type="hidden" name="action" value="delete-user" />
                        <input type="hidden" name="user_id" value={profile.id} />
                        <input type="hidden" name="email" value={profile.email} />
                        <p class="text-red-800">Löscht Profil, Grants, Fortschritt und Login dauerhaft.</p>
                        <input name="confirm_email" placeholder="E-Mail zur Bestätigung exakt eingeben" class="w-full border border-red-200 bg-white px-3 py-2" />
                        <button class="border border-red-300 bg-white px-3 py-2 text-red-800 hover:bg-red-100">Dauerhaft löschen</button>
                      </form>
                    </details>
                  </div>
                </details>
              );
            })}
          </div>
        </section>

        <form method="POST" action="/api/admin/grants/upsert" class="border border-border bg-background p-6 md:p-7 space-y-5 shadow-[0_10px_24px_rgba(0,0,0,0.02)]">
          <div>
            <h2 class="font-serif text-3xl leading-tight">Freischalten</h2>
            <p class="text-sm text-muted-foreground mt-1">Bestehende aktive Grants werden verlängert, sonst neu angelegt.</p>
          </div>

          <label class="block">
            <span class="block text-sm mb-2">E-Mail</span>
            <input name="email" type="email" required class="w-full border border-border bg-white px-4 py-3 focus:outline-none focus:border-primary" />
          </label>

          <label class="block">
            <span class="block text-sm mb-2">Name</span>
            <input name="full_name" class="w-full border border-border bg-white px-4 py-3 focus:outline-none focus:border-primary" />
          </label>

          <label class="block">
            <span class="block text-sm mb-2">Produkt</span>
            <select name="product_key" class="w-full border border-border bg-white px-4 py-3 focus:outline-none focus:border-primary">
              <option value="beyondbonus">BeyondBonus</option>
              <option value="its-bundle">ITS Bundle</option>
              <option value="beyondblended">BeyondBlended</option>
            </select>
          </label>

          <div class="grid gap-4 md:grid-cols-2">
            <label class="block">
              <span class="block text-sm mb-2">Kurs bis</span>
              <input name="course_ends_at" type="date" value={twelveMonths.toISOString().slice(0, 10)} min={today} class="w-full border border-border bg-white px-4 py-3 focus:outline-none focus:border-primary" />
            </label>
            <label class="block">
              <span class="block text-sm mb-2">Quelle</span>
              <select name="source" class="w-full border border-border bg-white px-4 py-3 focus:outline-none focus:border-primary">
                <option value="manual">Manuell</option>
                <option value="migration">Migration</option>
                <option value="stripe">Stripe</option>
              </select>
            </label>
          </div>

          <label class="flex items-center gap-2 text-sm">
            <input type="checkbox" name="livecalls_enabled" class="h-4 w-4" />
            Livecalls separat freischalten
          </label>

          <label class="block">
            <span class="block text-sm mb-2">Livecalls bis</span>
            <input name="livecalls_ends_at" type="date" value={sixMonths.toISOString().slice(0, 10)} min={today} class="w-full border border-border bg-white px-4 py-3 focus:outline-none focus:border-primary" />
          </label>

          <label class="block">
            <span class="block text-sm mb-2">Interne Notiz</span>
            <textarea name="note" class="w-full min-h-28 border border-border bg-white px-4 py-3 focus:outline-none focus:border-primary"></textarea>
          </label>

          <button type="submit" class="w-full bg-primary text-primary-foreground px-5 py-3 text-sm font-medium hover:opacity-90">
            Zugang speichern
          </button>
        </form>
      </div>
    </div>
  </section>
</Layout>
