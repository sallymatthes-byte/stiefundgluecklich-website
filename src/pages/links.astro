---
import Layout from '../layouts/Layout.astro'
---

<Layout 
  title="Links — StiefundGlücklich"
  description="Alle wichtigen Links von Sally Matthes — Coach für Bonusmamas in Patchworkfamilien."
  canonical="https://stiefundgluecklich.de/links/"
  noHeader={true}
>
  <section class="min-h-screen bg-secondary py-10 md:py-14">
    <div class="mx-auto px-5 max-w-[480px]">
      <div class="text-center mb-8">
        <img 
          src="/images/sally-biolink.jpg" 
          alt="Sally Matthes — Coach für Bonusmamas" 
          class="w-20 h-20 md:w-24 md:h-24 rounded-full mx-auto mb-4 object-cover shadow-md"
          loading="eager"
        />
        <h1 class="font-serif text-xl md:text-2xl text-primary mb-1">StiefundGlücklich</h1>
        <p class="text-sm text-muted-foreground">Sally Matthes · Bonusmama & systemischer Coach</p>
      </div>

      <div class="text-center mb-8">
        <h2 class="font-serif text-xl md:text-2xl leading-tight text-foreground mb-4">
          Du strengst dich an, reflektierst dich, gibst dein Bestes und trotzdem hängt ihr immer wieder an derselben Stelle fest?
        </h2>
        <p class="text-sm md:text-base text-muted-foreground leading-relaxed">
          Hier findest du raus, welches Muster in dir und eurer Paarbeziehung gerade wirklich wirkt, damit du nicht länger im Nebel stochern musst.
        </p>
      </div>

      <div class="mb-6">
        <a href="/bonusmama-check" 
          class="block w-full bg-primary hover:bg-primary/90 text-primary-foreground text-center px-6 py-3.5 md:py-4 rounded-full font-semibold transition-colors text-base">
          Ja, ich will wissen, woran es liegt
        </a>
      </div>

      <div class="text-center mb-5">
        <p class="text-sm md:text-base text-muted-foreground">
          Lieber erstmal hören statt direkt starten?
        </p>
      </div>

      <div class="mb-8">
        <a 
          href="https://open.spotify.com/episode/6BKfFvylBRAbkptxvqshX6?si=I7jYgTXpTKqtAgOvOFXr0A" 
          target="_blank"
          rel="noopener noreferrer"
          class="block w-full border border-primary text-primary hover:bg-primary/5 text-center px-6 py-3.5 md:py-4 rounded-full font-semibold transition-colors text-base"
        >
          Dann hör hier in den Podcast
        </a>
      </div>

      <div class="text-center">
        <p class="text-sm text-muted-foreground mb-2">
          Über 800 Bonusmamas hören jede Woche <span class="text-foreground font-medium">Bonusgeflüster</span>.
        </p>
        <p class="text-sm text-muted-foreground mb-1">Das ist ihre Lieblingsepisode:</p>
        <a 
          href="https://open.spotify.com/episode/6BKfFvylBRAbkptxvqshX6?si=I7jYgTXpTKqtAgOvOFXr0A"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm font-medium text-foreground hover:text-primary transition-colors underline underline-offset-2"
        >
          „Sind Ex-Partner wirklich Teil der Patchworkfamilie?"
        </a>
      </div>
    </div>
  </section>
</Layout>
