---
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import MembersSidebar from '../../../components/MembersSidebar.astro';
import { getAccessSnapshot } from '../../../lib/auth/grants';
import { loadUserGrants } from '../../../lib/auth/load-grants';
import { beyondBonusModules } from '../../../lib/beyondbonus/content';

const grants = await loadUserGrants(Astro);
const access = getAccessSnapshot(grants, 'beyondbonus');

if (!access.course) {
  return Astro.redirect('/members?error=no-access');
}
---

<Layout
  title="BeyondBonus Kursbereich"
  canonical="https://stiefundgluecklich.de/members/beyondbonus/"
  description="Geschützter Kursbereich für BeyondBonus."
  noHeader={true}
>
  <section class="py-20 md:py-28">
    <div class="container mx-auto px-5 md:px-6 max-w-6xl">
      <div class="grid gap-8 lg:grid-cols-[280px,1fr]">
        <MembersSidebar
          title="BeyondBonus"
          subtitle="Dein Kurs"
          currentPath={Astro.url.pathname}
          topItems={[
            { href: '/members', label: 'Dashboard' },
            { href: '/members/beyondbonus', label: 'Kursübersicht' },
            { href: '/members/beyondbonus/workbook', label: 'Workbook' },
            { href: '/livecalls/beyondbonus', label: 'Livecalls' },
          ]}
          bottomItems={[
            { href: '/members/settings/account', label: 'Account' },
            { href: '/members/settings/notifications', label: 'Benachrichtigungen' },
            { href: 'mailto:willkommen@sallymatthes.com?subject=Frage%20zu%20BeyondBonus', label: 'Support' },
          ]}
        />

        <div>
          <p class="text-sm uppercase tracking-[0.2em] text-muted-foreground mb-4">BeyondBonus</p>
          <h1 class="font-serif text-3xl md:text-4xl mb-4">Kursbereich</h1>
          <p class="text-base text-muted-foreground mb-10 leading-relaxed max-w-3xl">
            Hier findest du alle Module von BeyondBonus in einer klaren Reihenfolge und kannst direkt dort weitermachen, wo du zuletzt aufgehört hast.
          </p>

          <div class="space-y-5">
            {beyondBonusModules.map((module) => (
              <a href={`/members/beyondbonus/${module.slug}`} class="block border border-border bg-background p-6 hover:border-primary transition-colors" data-module-card data-lesson-keys={module.lessons.map((lesson) => `${module.slug}::${lesson.slug}`).join('|')}>
                <div class="flex items-start justify-between gap-6 mb-4">
                  <div class="space-y-2">
                    <p class="text-xs uppercase tracking-[0.18em] text-muted-foreground">Modul {module.number}</p>
                    <h2 class="font-serif text-2xl">{module.title}</h2>
                    <p class="text-sm text-muted-foreground max-w-2xl">{module.shortDescription}</p>
                  </div>
                  <p class="text-xs text-primary whitespace-nowrap">Öffnen →</p>
                </div>

                <div class="space-y-2 mb-4">
                  <div class="h-2 bg-secondary overflow-hidden">
                    <div class="h-full bg-primary w-0 transition-all" data-progress-bar></div>
                  </div>
                  <p class="text-xs text-muted-foreground" data-progress-label>0 von {module.lessons.length} abgeschlossen</p>
                </div>

                <div class="space-y-2 text-sm text-muted-foreground">
                  {module.lessons.slice(0, 5).map((lesson, index) => (
                    <div class="flex items-center justify-between gap-4 border-t border-border/70 pt-2 first:border-t-0 first:pt-0">
                      <span>{index + 1}. {lesson.title}</span>
                      <span>→</span>
                    </div>
                  ))}
                  {module.lessons.length > 5 && <p class="text-xs">+ {module.lessons.length - 5} weitere Lektionen</p>}
                </div>
              </a>
            ))}
          </div>

          <div class="border border-border p-6 bg-background mt-8 space-y-3">
            <p class="text-xs uppercase tracking-[0.18em] text-muted-foreground">Workbook</p>
            <h2 class="font-serif text-2xl">Zentrales BeyondBonus Workbook</h2>
            <p class="text-sm text-muted-foreground">Alle Übungen, Reflexionsfragen und Materialien an einem Ort.</p>
            <a href="/members/beyondbonus/workbook" class="text-sm text-primary hover:opacity-80 transition-opacity">Workbook öffnen →</a>
          </div>
        </div>
      </div>

      <script is:inline>
        const readProgress = () => {
          try {
            return JSON.parse(localStorage.getItem('bb-progress-v1') || '{}');
          } catch {
            return {};
          }
        };

        const progress = readProgress();
        document.querySelectorAll('[data-module-card]').forEach((card) => {
          const keys = (card.getAttribute('data-lesson-keys') || '').split('|').filter(Boolean);
          const done = keys.filter((key) => progress[key]).length;
          const percent = keys.length ? Math.round((done / keys.length) * 100) : 0;
          const bar = card.querySelector('[data-progress-bar]');
          const label = card.querySelector('[data-progress-label]');
          if (bar) bar.style.width = `${percent}%`;
          if (label) label.textContent = `${done} von ${keys.length} Lektionen abgeschlossen`;
        });
      </script>
    </div>
  </section>
</Layout>
