---
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import { getAccessSnapshot } from '../../../lib/auth/grants';
import { loadUserGrants } from '../../../lib/auth/load-grants';
import { beyondBonusModules } from '../../../lib/beyondbonus/content';

const grants = await loadUserGrants(Astro);
const access = getAccessSnapshot(grants, 'beyondbonus');

if (!access.course) {
  return Astro.redirect('/members?error=no-access');
}
---

<Layout
  title="BeyondBonus Kursbereich"
  canonical="https://stiefundgluecklich.de/members/beyondbonus/"
  description="Geschützter Kursbereich für BeyondBonus."
>
  <section class="py-20 md:py-28">
    <div class="container mx-auto px-5 md:px-6 max-w-5xl">
      <a href="/members" class="inline-flex items-center text-sm text-muted-foreground hover:text-primary transition-colors mb-6">
        ← Zurück zum Mitgliederbereich
      </a>

      <p class="text-sm uppercase tracking-[0.2em] text-muted-foreground mb-4">BeyondBonus</p>
      <h1 class="font-serif text-3xl md:text-4xl mb-4">Kursbereich</h1>
      <p class="text-base text-muted-foreground mb-8 leading-relaxed max-w-3xl">
        Das ist der erste strukturierte Einstieg für den BeyondBonus-Kurs. Als Nächstes hängen wir hier die echten Modul-Inhalte, Materialien und Fortschrittslogik an.
      </p>

      <div class="border border-border p-6 bg-secondary/40 space-y-2 mb-8">
        <p class="text-sm"><strong>Status:</strong> Kurszugang aktiv</p>
        <p class="text-sm text-muted-foreground">Dein Zugang für den Kursbereich ist freigeschaltet.</p>
      </div>

      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {beyondBonusModules.map((module) => (
          <a href={`/members/beyondbonus/${module.slug}`} class="border border-border p-5 bg-background space-y-4 hover:border-primary transition-colors block" data-module-card data-lesson-keys={module.lessons.map((lesson) => `${module.slug}::${lesson.slug}`).join('|')}>
            <div>
              <p class="text-xs uppercase tracking-[0.18em] text-muted-foreground">Modul {module.number}</p>
              <h2 class="font-serif text-xl mt-2">{module.title}</h2>
            </div>
            <p class="text-sm text-muted-foreground">{module.shortDescription}</p>
            <div class="space-y-2">
              <div class="h-2 bg-secondary overflow-hidden">
                <div class="h-full bg-primary w-0 transition-all" data-progress-bar></div>
              </div>
              <p class="text-xs text-muted-foreground" data-progress-label>0 von {module.lessons.length} Lektionen abgeschlossen</p>
            </div>
            <p class="text-xs text-primary">Modul öffnen →</p>
          </a>
        ))}

        <a href="/members/beyondbonus/workbook" class="border border-border p-5 bg-background space-y-4 hover:border-primary transition-colors block md:col-span-2 lg:col-span-3">
          <div>
            <p class="text-xs uppercase tracking-[0.18em] text-muted-foreground">Workbook</p>
            <h2 class="font-serif text-2xl mt-2">Zentrales BeyondBonus Workbook</h2>
          </div>
          <p class="text-sm text-muted-foreground">Ein zentrales Workbook für das gesamte Programm, statt einzelner Downloads pro Modul. Die finale Fassung hängen wir im nächsten Schritt an.</p>
          <p class="text-xs text-primary">Workbook öffnen →</p>
        </a>
      </div>
+
+      <script is:inline>
+        const readProgress = () => {
+          try {
+            return JSON.parse(localStorage.getItem('bb-progress-v1') || '{}');
+          } catch {
+            return {};
+          }
+        };
+
+        const progress = readProgress();
+        document.querySelectorAll('[data-module-card]').forEach((card) => {
+          const keys = (card.getAttribute('data-lesson-keys') || '').split('|').filter(Boolean);
+          const done = keys.filter((key) => progress[key]).length;
+          const percent = keys.length ? Math.round((done / keys.length) * 100) : 0;
+          const bar = card.querySelector('[data-progress-bar]');
+          const label = card.querySelector('[data-progress-label]');
+          if (bar) bar.style.width = `${percent}%`;
+          if (label) label.textContent = `${done} von ${keys.length} Lektionen abgeschlossen`;
+        });
+      </script>
    </div>
  </section>
</Layout>
