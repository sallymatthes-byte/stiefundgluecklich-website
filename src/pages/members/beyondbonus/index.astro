---
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import { getAccessSnapshot } from '../../../lib/auth/grants';
import { loadUserGrants } from '../../../lib/auth/load-grants';

const grants = await loadUserGrants(Astro);
const access = getAccessSnapshot(grants, 'beyondbonus');
---

<Layout
  title="BeyondBonus Kursbereich"
  canonical="https://stiefundgluecklich.de/members/beyondbonus/"
  description="Geschützter Kursbereich für BeyondBonus."
>
  <section class="py-20 md:py-28">
    <div class="container mx-auto px-5 md:px-6 max-w-3xl">
      <p class="text-sm uppercase tracking-[0.2em] text-muted-foreground mb-4">BeyondBonus</p>
      <h1 class="font-serif text-3xl md:text-4xl mb-4">Kursbereich</h1>
      <p class="text-base text-muted-foreground mb-8 leading-relaxed">
        Hier liegt später der eigentliche BeyondBonus-Kurs mit Modulen, Materialien und Fortschrittslogik.
      </p>

      <div class="border border-border p-6 bg-secondary/40 space-y-3">
        <p class="text-sm"><strong>Geplanter Grant:</strong> Produktrecht `beyondbonus` + Bereich `course`</p>
        <p class="text-sm text-muted-foreground">Der Kurszugang und der Livecall-Bereich bleiben bewusst getrennt modelliert.</p>
        <p class="text-sm"><strong>Aktueller DB-Stand:</strong> Kurszugang {access.course ? 'aktiv' : 'nicht aktiv'}</p>
      </div>
    </div>
  </section>
</Layout>
