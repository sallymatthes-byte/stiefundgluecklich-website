---
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import MembersSidebar from '../../../components/MembersSidebar.astro';
import { getAccessSnapshot } from '../../../lib/auth/grants';
import { loadUserGrants } from '../../../lib/auth/load-grants';
import { beyondBonusCourseMeta, beyondBonusModules, getBeyondBonusModuleCover } from '../../../lib/beyondbonus/content';

const grants = await loadUserGrants(Astro);
const access = getAccessSnapshot(grants, 'beyondbonus');

if (!access.course) {
  return Astro.redirect('/members?error=no-access');
}

const firstModule = beyondBonusModules[0];
---

<Layout
  title="BeyondBonus Kursbereich"
  canonical="https://stiefundgluecklich.de/members/beyondbonus/"
  description="Geschützter Kursbereich für BeyondBonus."
  noHeader={true}
>
  <section class="py-16 md:py-20">
    <div class="container mx-auto px-5 md:px-6 max-w-7xl">
      <div class="grid gap-8 xl:grid-cols-[260px,1fr] items-start">
        <MembersSidebar
          title="BeyondBonus"
          subtitle="Dein Kurs"
          currentPath={Astro.url.pathname}
          topItems={[
            { href: '/members', label: 'Dashboard' },
            { href: '/members/beyondbonus', label: 'Kursübersicht' },
            { href: '/members/beyondbonus/workbook', label: 'Workbook' },
            { href: '/livecalls/beyondbonus', label: 'Livecalls' },
          ]}
          bottomItems={[
            { href: '/members/settings/account', label: 'Account' },
            { href: '/members/settings/notifications', label: 'Benachrichtigungen' },
            { href: 'mailto:willkommen@sallymatthes.com?subject=Frage%20zu%20BeyondBonus', label: 'Support' },
          ]}
        />

        <div class="space-y-8">
          <section class="relative overflow-hidden border border-border min-h-[250px] bg-[#31372a] text-white">
            <img src={beyondBonusCourseMeta.coverImage} alt="BeyondBonus Cover" class="absolute inset-0 w-full h-full object-cover opacity-80" />
            <div class="absolute inset-0 bg-gradient-to-r from-black/55 via-black/30 to-transparent"></div>
            <div class="relative h-full p-8 md:p-10 flex flex-col justify-between gap-8">
              <div class="max-w-3xl space-y-3">
                <p class="text-xs uppercase tracking-[0.22em] text-white/70">Kurs</p>
                <h1 class="font-serif text-4xl md:text-5xl leading-none">{beyondBonusCourseMeta.title}</h1>
                <p class="text-base text-white/85 leading-relaxed">{beyondBonusCourseMeta.subtitle}</p>
              </div>

              <div class="flex flex-wrap items-end justify-between gap-6">
                <div class="flex flex-wrap gap-3">
                  <a href={`/members/beyondbonus/${firstModule.slug}/${firstModule.lessons[0]?.slug || 'einfuehrung'}`} class="inline-flex px-5 py-3 bg-[#3ed39f] text-[#1f3324] text-sm font-medium hover:opacity-90 transition-opacity">Direkt weitermachen</a>
                  <a href="/members/beyondbonus/workbook" class="inline-flex px-5 py-3 bg-white/10 border border-white/20 text-white text-sm font-medium hover:bg-white/15 transition-colors">Workbook öffnen</a>
                </div>
                <div class="w-24 h-24 rounded-full border-[6px] border-[#3ed39f] flex items-center justify-center text-2xl font-medium bg-black/25 backdrop-blur-sm" data-course-progress-circle>
                  0%
                </div>
              </div>
            </div>
          </section>

          <section class="border border-border bg-[#868b72] text-white px-6 py-4 flex flex-wrap items-center justify-between gap-4">
            <div>
              <p class="text-xs uppercase tracking-[0.18em] text-white/70">Mache direkt weiter</p>
              <p class="font-serif text-2xl" data-next-lesson-label>{firstModule.lessons[0]?.title || 'Einführung'}</p>
            </div>
            <a href={`/members/beyondbonus/${firstModule.slug}/${firstModule.lessons[0]?.slug || 'einfuehrung'}`} class="inline-flex px-5 py-3 bg-white/10 border border-white/25 text-white text-sm font-medium hover:bg-white/15 transition-colors" data-next-lesson-link>
              Fortsetzen
            </a>
          </section>

          <section class="space-y-5">
            <div class="space-y-1">
              <p class="text-xs uppercase tracking-[0.18em] text-muted-foreground">Module</p>
              <h2 class="font-serif text-3xl">Kursübersicht</h2>
            </div>

            <div class="space-y-4">
              {beyondBonusModules.map((module) => (
                <a href={`/members/beyondbonus/${module.slug}`} class="grid gap-0 md:grid-cols-[220px,1fr,110px] items-stretch border border-border bg-background hover:shadow-[0_10px_30px_rgba(0,0,0,0.08)] transition-shadow" data-module-card data-lesson-keys={module.lessons.map((lesson) => `${module.slug}::${lesson.slug}`).join('|')}>
                  <div class="aspect-[16/10] md:aspect-auto overflow-hidden bg-black min-h-[140px]">
                    <img src={getBeyondBonusModuleCover(module.slug)} alt={`Cover ${module.title}`} class="w-full h-full object-cover" />
                  </div>

                  <div class="p-6 md:p-7 space-y-4">
                    <div class="space-y-2">
                      <p class="text-xs uppercase tracking-[0.18em] text-muted-foreground">Modul {module.number}</p>
                      <h3 class="font-serif text-3xl leading-none">{module.title}</h3>
                      <p class="text-sm text-muted-foreground leading-relaxed max-w-2xl">{module.shortDescription}</p>
                    </div>

                    <div class="space-y-2">
                      <div class="h-1.5 bg-secondary overflow-hidden">
                        <div class="h-full bg-[#3ed39f] w-0 transition-all" data-progress-bar></div>
                      </div>
                      <p class="text-xs text-muted-foreground" data-progress-label>0 von {module.lessons.length} Lektionen abgeschlossen</p>
                    </div>
                  </div>

                  <div class="px-6 py-6 md:px-5 flex md:flex-col items-start md:items-end justify-between gap-4 text-sm text-muted-foreground">
                    <span>{module.lessons.length} Lektionen</span>
                    <span class="inline-flex px-3 py-2 border border-border text-foreground">Öffnen</span>
                  </div>
                </a>
              ))}
            </div>
          </section>
        </div>
      </div>

      <script is:inline>
        const readProgress = () => {
          try {
            return JSON.parse(localStorage.getItem('bb-progress-v1') || '{}');
          } catch {
            return {};
          }
        };

        const progress = readProgress();
        const moduleCards = [...document.querySelectorAll('[data-module-card]')];
        let totalLessons = 0;
        let doneLessons = 0;
        let firstOpenLink = null;
        let firstOpenTitle = null;

        moduleCards.forEach((card) => {
          const keys = (card.getAttribute('data-lesson-keys') || '').split('|').filter(Boolean);
          const done = keys.filter((key) => progress[key]).length;
          const percent = keys.length ? Math.round((done / keys.length) * 100) : 0;
          const bar = card.querySelector('[data-progress-bar]');
          const label = card.querySelector('[data-progress-label]');
          if (bar) bar.style.width = `${percent}%`;
          if (label) label.textContent = `${done} von ${keys.length} Lektionen abgeschlossen`;
          totalLessons += keys.length;
          doneLessons += done;

          if (!firstOpenLink) {
            const nextKey = keys.find((key) => !progress[key]) || keys[0];
            const href = card.getAttribute('href');
            const nextTitle = card.querySelector('h3')?.textContent?.trim();
            if (href && nextKey) {
              const lessonSlug = nextKey.split('::')[1];
              firstOpenLink = `${href}/${lessonSlug}`;
              firstOpenTitle = nextTitle;
            }
          }
        });

        const totalPercent = totalLessons ? Math.round((doneLessons / totalLessons) * 100) : 0;
        const circle = document.querySelector('[data-course-progress-circle]');
        if (circle) {
          circle.textContent = `${totalPercent}%`;
          circle.style.background = `conic-gradient(#3ed39f ${totalPercent}%, rgba(255,255,255,0.18) ${totalPercent}% 100%)`;
        }

        const nextLabel = document.querySelector('[data-next-lesson-label]');
        const nextLink = document.querySelector('[data-next-lesson-link]');
        if (firstOpenTitle && nextLabel) nextLabel.textContent = firstOpenTitle;
        if (firstOpenLink && nextLink) nextLink.setAttribute('href', firstOpenLink);
      </script>
    </div>
  </section>
</Layout>
