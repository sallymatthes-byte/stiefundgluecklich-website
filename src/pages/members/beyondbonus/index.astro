---
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import { getAccessSnapshot } from '../../../lib/auth/grants';
import { loadUserGrants } from '../../../lib/auth/load-grants';
import { beyondBonusModules } from '../../../lib/beyondbonus/content';

const grants = await loadUserGrants(Astro);
const access = getAccessSnapshot(grants, 'beyondbonus');

if (!access.course) {
  return Astro.redirect('/members?error=no-access');
}
---

<Layout
  title="BeyondBonus Kursbereich"
  canonical="https://stiefundgluecklich.de/members/beyondbonus/"
  description="Geschützter Kursbereich für BeyondBonus."
  noHeader={true}
>
  <section class="py-20 md:py-28">
    <div class="container mx-auto px-5 md:px-6 max-w-5xl">
      <a href="/members" class="inline-flex items-center text-sm text-muted-foreground hover:text-primary transition-colors mb-6">
        ← Zurück zum Mitgliederbereich
      </a>

      <p class="text-sm uppercase tracking-[0.2em] text-muted-foreground mb-4">BeyondBonus</p>
      <h1 class="font-serif text-3xl md:text-4xl mb-4">Kursbereich</h1>
      <p class="text-base text-muted-foreground mb-8 leading-relaxed max-w-3xl">
        Hier findest du alle Module von BeyondBonus an einem Ort und kannst direkt dort weitermachen, wo du zuletzt aufgehört hast.
      </p>

      <div class="grid gap-8 lg:grid-cols-[1.25fr,0.75fr]">
        <div class="space-y-4">
          {beyondBonusModules.map((module) => (
            <a href={`/members/beyondbonus/${module.slug}`} class="border border-border p-5 bg-background hover:border-primary transition-colors block" data-module-card data-lesson-keys={module.lessons.map((lesson) => `${module.slug}::${lesson.slug}`).join('|')}>
              <div class="grid gap-4 md:grid-cols-[auto,1fr,auto] md:items-center">
                <div class="w-20 h-20 border border-border bg-secondary/40 flex items-center justify-center text-xs uppercase tracking-[0.18em] text-muted-foreground">
                  Modul {module.number}
                </div>
                <div class="space-y-2">
                  <h2 class="font-serif text-2xl">{module.title}</h2>
                  <p class="text-sm text-muted-foreground">{module.shortDescription}</p>
                  <p class="text-xs text-muted-foreground">{module.lessons.length} Lektionen</p>
                </div>
                <div class="space-y-2 min-w-32">
                  <div class="h-2 bg-secondary overflow-hidden">
                    <div class="h-full bg-primary w-0 transition-all" data-progress-bar></div>
                  </div>
                  <p class="text-xs text-muted-foreground text-right" data-progress-label>0 von {module.lessons.length} abgeschlossen</p>
                  <p class="text-xs text-primary text-right">Öffnen →</p>
                </div>
              </div>
            </a>
          ))}
        </div>

        <aside class="space-y-6">
          <a href="/members/beyondbonus/workbook" class="border border-border p-5 bg-background space-y-4 hover:border-primary transition-colors block">
            <div>
              <p class="text-xs uppercase tracking-[0.18em] text-muted-foreground">Workbook</p>
              <h2 class="font-serif text-2xl mt-2">Zentrales BeyondBonus Workbook</h2>
            </div>
            <p class="text-sm text-muted-foreground">Ein zentrales Workbook für das gesamte Programm, statt einzelner Downloads pro Modul.</p>
            <p class="text-xs text-primary">Workbook öffnen →</p>
          </a>

          <section class="border border-border p-5 bg-secondary/40 space-y-3">
            <h2 class="font-serif text-xl">Support</h2>
            <p class="text-sm text-muted-foreground">Wenn du technische Fragen hast oder etwas mit deinem Zugang nicht stimmt, melde dich direkt bei Sally.</p>
            <a href="mailto:willkommen@sallymatthes.com?subject=Frage%20zu%20BeyondBonus" class="text-sm text-primary hover:opacity-80 transition-opacity">Support kontaktieren</a>
          </section>
        </aside>
      </div>

      <script is:inline>
        const readProgress = () => {
          try {
            return JSON.parse(localStorage.getItem('bb-progress-v1') || '{}');
          } catch {
            return {};
          }
        };

        const progress = readProgress();
        document.querySelectorAll('[data-module-card]').forEach((card) => {
          const keys = (card.getAttribute('data-lesson-keys') || '').split('|').filter(Boolean);
          const done = keys.filter((key) => progress[key]).length;
          const percent = keys.length ? Math.round((done / keys.length) * 100) : 0;
          const bar = card.querySelector('[data-progress-bar]');
          const label = card.querySelector('[data-progress-label]');
          if (bar) bar.style.width = `${percent}%`;
          if (label) label.textContent = `${done} von ${keys.length} Lektionen abgeschlossen`;
        });
      </script>
    </div>
  </section>
</Layout>
