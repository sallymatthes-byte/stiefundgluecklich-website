---
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import MembersSidebar from '../../../components/MembersSidebar.astro';
import { getAccessSnapshot } from '../../../lib/auth/grants';
import { loadUserGrants } from '../../../lib/auth/load-grants';
import { loadMemberProfile } from '../../../lib/auth/load-profile';
import { beyondBonusModules } from '../../../lib/beyondbonus/content';
import { getBeyondBonusCourseItems } from '../../../lib/members/navigation';

const profile = await loadMemberProfile(Astro);
const grants = await loadUserGrants(Astro);
const access = getAccessSnapshot(grants, 'beyondbonus');
const courseItems = getBeyondBonusCourseItems(access);

if (!access.course) {
  return Astro.redirect('/members?error=no-access');
}
---

<Layout
  title="BeyondBonus Kursbereich"
  canonical="https://stiefundgluecklich.de/members/beyondbonus/"
  description="Geschützter Kursbereich für BeyondBonus."
  noHeader={true}
>
  <section class="py-16 md:py-24">
    <div class="container mx-auto px-5 md:px-6 max-w-[1080px]">
      <div class="grid gap-10 lg:grid-cols-[224px_minmax(0,1fr)] lg:items-start">
        <MembersSidebar
          title="Mitgliederbereich"
          subtitle={profile.fullName || 'Dein Profil'}
          currentPath={Astro.url.pathname}
          primaryItems={[{ href: '/members', label: 'Dashboard' }]}
          courseItems={courseItems}
          bottomItems={[
            { href: '/members/settings/account', label: 'Account' },
            { href: '/members/settings/notifications', label: 'Benachrichtigungen' },
            { href: '/members/app', label: 'Als App nutzen' },
            { href: 'mailto:willkommen@sallymatthes.com?subject=Frage%20zu%20BeyondBonus', label: 'Support' },
          ]}
          avatarUrl={profile.avatarUrl}
        />

        <div class="max-w-[820px] space-y-12 min-w-0">
          <header class="space-y-4">
            <p class="text-sm uppercase tracking-[0.2em] text-muted-foreground">BeyondBonus</p>
            <div class="space-y-3">
              <h1 class="font-serif text-3xl md:text-[2.8rem] leading-none">Kursbereich</h1>
              <p class="text-base text-muted-foreground leading-relaxed max-w-2xl">
                Hier findest du alle Module von BeyondBonus in einer klaren Reihenfolge und kannst direkt dort weitermachen, wo du zuletzt aufgehört hast.
              </p>
            </div>
          </header>

          <div class="space-y-6">
            {beyondBonusModules.map((module) => (
              <a href={`/members/beyondbonus/${module.slug}`} class="block border border-border bg-background overflow-hidden hover:border-primary transition-colors shadow-[0_10px_24px_rgba(0,0,0,0.03)]" data-module-card data-lesson-keys={module.lessons.map((lesson) => `${module.slug}::${lesson.slug}`).join('|')}>
                <div class="grid lg:grid-cols-[220px_minmax(0,1fr)] items-stretch">
                  <div class="bg-secondary/15 min-h-[180px] p-4 flex items-center justify-center">
                    <img src={module.moduleCover} alt={`Titelbild ${module.title}`} class="w-full h-full object-contain" />
                  </div>
                  <div class="px-7 py-7 md:px-8 md:py-8">
                    <div class="flex items-start justify-between gap-6 mb-5">
                      <div class="space-y-2">
                        <p class="text-xs uppercase tracking-[0.18em] text-muted-foreground">Modul {module.number}</p>
                        <h2 class="font-serif text-2xl md:text-[2rem] leading-tight">{module.title}</h2>
                        <p class="text-[0.95rem] text-muted-foreground leading-relaxed max-w-2xl">{module.shortDescription}</p>
                      </div>
                      <p class="text-xs text-primary whitespace-nowrap pt-1">Öffnen →</p>
                    </div>

                    <div class="space-y-3 mb-6">
                      <div class="h-2 bg-secondary overflow-hidden">
                        <div class="h-full bg-primary w-0 transition-all" data-progress-bar></div>
                      </div>
                      <p class="text-xs text-muted-foreground" data-progress-label>0 von {module.lessons.length} abgeschlossen</p>
                    </div>

                    <div class="space-y-3 text-[0.95rem] text-foreground/75">
                      {module.lessons.slice(0, 4).map((lesson, index) => (
                        <div class="flex items-center justify-between gap-4 border-t border-border/70 pt-3 first:border-t-0 first:pt-0">
                          <span>{index + 1}. {lesson.title}</span>
                          <span class="shrink-0 text-xs text-muted-foreground">{lesson.workbookReference ? 'Workbook' : lesson.duration || '→'}</span>
                        </div>
                      ))}
                      {module.lessons.length > 4 && <p class="text-xs pt-1 text-muted-foreground">+ {module.lessons.length - 4} weitere Lektionen</p>}
                    </div>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>

      <script is:inline>
        const readProgress = () => {
          try {
            return JSON.parse(localStorage.getItem('bb-progress-v1') || '{}');
          } catch {
            return {};
          }
        };

        const renderProgress = (progress) => {
          document.querySelectorAll('[data-module-card]').forEach((card) => {
            const keys = (card.getAttribute('data-lesson-keys') || '').split('|').filter(Boolean);
            const done = keys.filter((key) => progress[key]).length;
            const percent = keys.length ? Math.round((done / keys.length) * 100) : 0;
            const bar = card.querySelector('[data-progress-bar]');
            const label = card.querySelector('[data-progress-label]');
            if (bar) bar.style.width = `${percent}%`;
            if (label) label.textContent = `${done} von ${keys.length} Lektionen abgeschlossen`;
          });
        };

        const syncProgress = async () => {
          const progress = readProgress();
          renderProgress(progress);
          try {
            const response = await fetch('/api/members/progress', { credentials: 'same-origin' });
            const payload = await response.json();
            if (!response.ok || !Array.isArray(payload.progress)) return;
            payload.progress.forEach((entry) => {
              if (entry.lesson_key) progress[entry.lesson_key] = Boolean(entry.completed);
            });
            localStorage.setItem('bb-progress-v1', JSON.stringify(progress));
            renderProgress(progress);
          } catch {}
        };

        syncProgress();
      </script>
    </div>
  </section>
</Layout>
