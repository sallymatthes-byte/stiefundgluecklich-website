---
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import MembersSidebar from '../../../components/MembersSidebar.astro';
import { getAccessSnapshot } from '../../../lib/auth/grants';
import { loadUserGrants } from '../../../lib/auth/load-grants';
import { loadMemberProfile } from '../../../lib/auth/load-profile';
import { workbookInfo } from '../../../lib/beyondbonus/content';

const profile = await loadMemberProfile(Astro);
const grants = await loadUserGrants(Astro);
const access = getAccessSnapshot(grants, 'beyondbonus');

if (!access.course) {
  return Astro.redirect('/members?error=no-access');
}
---

<Layout
  title="BeyondBonus Workbook"
  canonical="https://stiefundgluecklich.de/members/beyondbonus/workbook/"
  description="Zentrales Workbook für BeyondBonus."
  noHeader={true}
>
  <section class="py-16 md:py-24">
    <div class="container mx-auto px-5 md:px-6 max-w-[1080px]">
      <div class="grid gap-10 md:grid-cols-[224px_minmax(0,1fr)] md:items-start">
        <MembersSidebar
          title="Mitgliederbereich"
          subtitle={profile.fullName || 'Dein Profil'}
          currentPath={Astro.url.pathname}
          primaryItems={[{ href: '/members', label: 'Dashboard' }]}
          courseItems={[
            { href: '/members/beyondbonus', label: 'BeyondBonus' },
            { href: '/livecalls/beyondbonus', label: 'Livecalls' },
          ]}
          bottomItems={[
            { href: '/members/settings/account', label: 'Account' },
            { href: '/members/settings/notifications', label: 'Benachrichtigungen' },
            { href: 'mailto:willkommen@sallymatthes.com?subject=Frage%20zu%20BeyondBonus', label: 'Support' },
          ]}
          avatarUrl={profile.avatarUrl}
        />

        <div class="max-w-[820px] min-w-0 space-y-8">
          <div class="space-y-4">
            <p class="text-sm uppercase tracking-[0.2em] text-muted-foreground">BeyondBonus</p>
            <div class="space-y-3">
              <h1 class="font-serif text-3xl md:text-[2.8rem] leading-none">{workbookInfo.title}</h1>
              <p class="text-base text-muted-foreground leading-relaxed max-w-3xl">{workbookInfo.description}</p>
            </div>
          </div>

          <div class="border border-border bg-background p-3 shadow-[0_10px_24px_rgba(0,0,0,0.03)]">
            <iframe src={workbookInfo.embedUrl} class="w-full aspect-[4/3] bg-white" loading="lazy"></iframe>
          </div>

          <a href={workbookInfo.downloadUrl} target="_blank" rel="noreferrer" class="inline-flex px-5 py-3 bg-primary text-primary-foreground text-sm font-medium hover:opacity-90 transition-opacity">
            Workbook öffnen
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
