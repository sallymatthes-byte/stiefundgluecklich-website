---
export const prerender = false;

import Layout from '../../../../layouts/Layout.astro';
import MembersSidebar from '../../../../components/MembersSidebar.astro';
import { getAccessSnapshot } from '../../../../lib/auth/grants';
import { loadUserGrants } from '../../../../lib/auth/load-grants';
import { beyondBonusModules, getBeyondBonusLesson, getBeyondBonusLessonCover, getBeyondBonusModule, getLessonKey } from '../../../../lib/beyondbonus/content';

const grants = await loadUserGrants(Astro);
const access = getAccessSnapshot(grants, 'beyondbonus');

if (!access.course) {
  return Astro.redirect('/members?error=no-access');
}

const moduleSlug = Astro.params.module || '';
const lessonSlug = Astro.params.lesson || '';
const module = getBeyondBonusModule(moduleSlug);
const lesson = getBeyondBonusLesson(moduleSlug, lessonSlug);

if (!module || !lesson) {
  return Astro.redirect('/members/beyondbonus');
}

const lessonIndex = module.lessons.findIndex((entry) => entry.slug === lesson.slug);
const previousLesson = lessonIndex > 0 ? module.lessons[lessonIndex - 1] : null;
const nextLesson = lessonIndex < module.lessons.length - 1 ? module.lessons[lessonIndex + 1] : null;
const lessonKey = getLessonKey(module.slug, lesson.slug);
const mediaEndpoint = `/api/members/media/beyondbonus/${module.slug}/${lesson.slug}`;
---

<Layout
  title={`BeyondBonus – ${lesson.title}`}
  canonical={`https://stiefundgluecklich.de/members/beyondbonus/${module.slug}/${lesson.slug}/`}
  description={lesson.description}
  noHeader={true}
>
  <section class="py-16 md:py-20" data-lesson-key={lessonKey}>
    <div class="container mx-auto px-5 md:px-6 max-w-7xl">
      <div class="grid gap-8 lg:grid-cols-[260px,minmax(0,1fr)] items-start">
        <MembersSidebar
          title="BeyondBonus"
          subtitle={module.title}
          currentPath={Astro.url.pathname}
          topItems={[
            { href: '/members', label: 'Dashboard' },
            { href: '/members/beyondbonus', label: 'Kursübersicht' },
            ...beyondBonusModules.map((entry) => ({ href: `/members/beyondbonus/${entry.slug}`, label: `Modul ${entry.number}` })),
            { href: '/members/beyondbonus/workbook', label: 'Workbook' },
          ]}
          bottomItems={[
            { href: '/members/settings/account', label: 'Account' },
            { href: '/members/settings/notifications', label: 'Benachrichtigungen' },
            { href: 'mailto:willkommen@sallymatthes.com?subject=Frage%20zu%20BeyondBonus%20Lektion', label: 'Support' },
          ]}
        />

        <div class="space-y-8">
          <a href={`/members/beyondbonus/${module.slug}`} class="inline-flex items-center text-sm text-muted-foreground hover:text-primary transition-colors">← Zurück zu {module.title}</a>

          <section class="relative overflow-hidden border border-border min-h-[210px] bg-[#31372a] text-white">
            <img src={getBeyondBonusLessonCover(module.slug, lesson.slug)} alt={`Cover ${lesson.title}`} class="absolute inset-0 w-full h-full object-cover opacity-80" />
            <div class="absolute inset-0 bg-gradient-to-r from-black/60 via-black/35 to-transparent"></div>
            <div class="relative h-full p-8 md:p-10 flex flex-col justify-between gap-6">
              <div class="max-w-md space-y-3 bg-black/18 backdrop-blur-[1px] p-6 md:p-7">
                <p class="text-xs uppercase tracking-[0.22em] text-white/70">Modul {module.number} · Lektion {String(lessonIndex + 1).padStart(2, '0')}</p>
                <h1 class="font-serif text-4xl md:text-5xl leading-none">{lesson.title}</h1>
                <p class="text-base text-white/85 leading-relaxed">{lesson.description}</p>
              </div>
            </div>
          </section>

          <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr),280px] items-start">
            <div class="space-y-6">
              <section class="border border-border bg-background overflow-hidden">
                <div class="aspect-video border-b border-border overflow-hidden bg-black flex items-center justify-center" data-media-shell data-media-endpoint={mediaEndpoint}>
                  <div class="p-8 text-center text-sm text-white/80 leading-relaxed" data-media-status>
                    Video wird geladen ...
                  </div>
                </div>

                <div class="p-5 flex flex-wrap items-center justify-between gap-4">
                  <div class="space-y-1">
                    <p class="text-xs uppercase tracking-[0.18em] text-muted-foreground">Dein Fortschritt</p>
                    <p class="text-sm text-muted-foreground" data-lesson-state>Diese Lektion ist noch nicht abgeschlossen.</p>
                  </div>
                  <button type="button" class="inline-flex px-5 py-3 bg-primary text-primary-foreground text-sm font-medium hover:opacity-90 transition-opacity" data-toggle-complete>
                    Als erledigt markieren
                  </button>
                </div>
              </section>

              {nextLesson && (
                <a href={`/members/beyondbonus/${module.slug}/${nextLesson.slug}`} class="grid gap-0 md:grid-cols-[180px,1fr] items-stretch border border-border bg-background hover:shadow-[0_10px_30px_rgba(0,0,0,0.08)] transition-shadow">
                  <div class="aspect-[16/10] md:aspect-auto overflow-hidden bg-black min-h-[120px]">
                    <img src={getBeyondBonusLessonCover(module.slug, nextLesson.slug)} alt={`Cover ${nextLesson.title}`} class="w-full h-full object-cover" />
                  </div>
                  <div class="p-6 space-y-3 flex flex-col justify-center">
                    <p class="text-xs uppercase tracking-[0.18em] text-muted-foreground">Nächste Lektion</p>
                    <h2 class="font-serif text-3xl leading-none">{nextLesson.title}</h2>
                    <p class="text-sm text-muted-foreground">Wenn du soweit bist, geht es hier direkt weiter.</p>
                  </div>
                </a>
              )}

              <section class="border border-border bg-background p-6 md:p-7 space-y-4">
                <p class="text-xs uppercase tracking-[0.18em] text-muted-foreground">Deine Notizen</p>
                <h2 class="font-serif text-3xl">Was nimmst du aus dieser Lektion mit?</h2>
                <p class="text-sm text-muted-foreground">Halte hier Gedanken, Erkenntnisse oder nächste Schritte direkt fest.</p>
                <textarea data-lesson-notes class="w-full min-h-56 border border-border bg-white px-4 py-3 focus:outline-none focus:border-primary" placeholder="Deine Notizen zu dieser Lektion ..."></textarea>
                <p class="text-xs text-muted-foreground" data-notes-status>Deine Notizen werden nur auf diesem Gerät gespeichert.</p>
              </section>
            </div>

            <aside class="space-y-6">
              <section class="border border-border bg-background p-6 space-y-3">
                <p class="text-xs uppercase tracking-[0.18em] text-muted-foreground">Support</p>
                <h2 class="font-serif text-2xl">Frage zu dieser Lektion?</h2>
                <p class="text-sm text-muted-foreground">Wenn du an einer Stelle hängst, schreib uns direkt.</p>
                <a href="mailto:willkommen@sallymatthes.com?subject=Frage%20zu%20BeyondBonus%20Lektion" class="inline-flex px-4 py-2 border border-border hover:bg-secondary/40 transition-colors text-sm">Support kontaktieren</a>
              </section>
            </aside>
          </div>
        </div>
      </div>

      <script is:inline>
        const key = document.querySelector('[data-lesson-key]')?.getAttribute('data-lesson-key');
        const readProgress = () => {
          try {
            return JSON.parse(localStorage.getItem('bb-progress-v1') || '{}');
          } catch {
            return {};
          }
        };
        const writeProgress = (progress) => localStorage.setItem('bb-progress-v1', JSON.stringify(progress));

        const button = document.querySelector('[data-toggle-complete]');
        const state = document.querySelector('[data-lesson-state]');
        const mediaShell = document.querySelector('[data-media-shell]');
        const mediaStatus = document.querySelector('[data-media-status]');
        const notesField = document.querySelector('[data-lesson-notes]');
        const notesStatus = document.querySelector('[data-notes-status]');

        const refresh = () => {
          const progress = readProgress();
          const done = key && progress[key];
          if (state) state.textContent = done ? 'Diese Lektion ist abgeschlossen.' : 'Diese Lektion ist noch nicht abgeschlossen.';
          if (button) button.textContent = done ? 'Als nicht erledigt markieren' : 'Als erledigt markieren';
        };

        const renderMedia = async () => {
          const endpoint = mediaShell?.getAttribute('data-media-endpoint');
          if (!mediaShell || !endpoint) return;

          try {
            const response = await fetch(endpoint, { credentials: 'same-origin' });
            const payload = await response.json();
            if (!response.ok || !payload?.media?.url) {
              throw new Error(payload?.error || 'media-unavailable');
            }

            const media = payload.media;
            mediaShell.innerHTML = '';

            if (media.provider !== 'drive-preview') {
              if (media.kind === 'audio') {
                const wrapper = document.createElement('div');
                wrapper.className = 'w-full h-full flex items-center justify-center p-8 bg-background';
                const audio = document.createElement('audio');
                audio.src = media.url;
                audio.controls = true;
                audio.preload = 'metadata';
                audio.className = 'w-full';
                wrapper.appendChild(audio);
                mediaShell.appendChild(wrapper);
                return;
              }

              const video = document.createElement('video');
              video.src = media.url;
              video.controls = true;
              video.playsInline = true;
              video.preload = 'metadata';
              video.className = 'w-full h-full';
              mediaShell.appendChild(video);
              return;
            }

            const iframe = document.createElement('iframe');
            iframe.src = media.url;
            iframe.className = 'w-full h-full';
            iframe.setAttribute('allow', 'autoplay');
            iframe.setAttribute('allowfullscreen', 'true');
            iframe.setAttribute('loading', 'lazy');
            mediaShell.appendChild(iframe);
          } catch (_error) {
            if (mediaStatus) {
              mediaStatus.textContent = 'Diese Lektion ist angelegt, aber das Video ist gerade noch nicht verfügbar.';
            }
          }
        };

        const notesKey = key ? `bb-notes-v1::${key}` : null;
        if (notesField && notesKey) {
          try {
            notesField.value = localStorage.getItem(notesKey) || '';
          } catch {}

          notesField.addEventListener('input', () => {
            try {
              localStorage.setItem(notesKey, notesField.value);
              if (notesStatus) notesStatus.textContent = 'Notizen gespeichert.';
            } catch {
              if (notesStatus) notesStatus.textContent = 'Notizen konnten auf diesem Gerät gerade nicht gespeichert werden.';
            }
          });
        }

        button?.addEventListener('click', () => {
          if (!key) return;
          const progress = readProgress();
          progress[key] = !progress[key];
          writeProgress(progress);
          refresh();
        });

        refresh();
        renderMedia();
      </script>
    </div>
  </section>
</Layout>
