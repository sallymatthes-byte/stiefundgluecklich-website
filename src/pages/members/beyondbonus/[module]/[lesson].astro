---
export const prerender = false;

import Layout from '../../../../layouts/Layout.astro';
import MembersSidebar from '../../../../components/MembersSidebar.astro';
import { getAccessSnapshot } from '../../../../lib/auth/grants';
import { loadUserGrants } from '../../../../lib/auth/load-grants';
import { loadMemberProfile } from '../../../../lib/auth/load-profile';
import { getBeyondBonusLessonCover, getLessonKey, workbookInfo } from '../../../../lib/beyondbonus/content';
import { getBeyondBonusCourseItems } from '../../../../lib/members/navigation';
import { getLessonFromModules, getModuleFromModules, loadBeyondBonusModules } from '../../../../lib/beyondbonus/admin-content';

const runtimeEnv = (Astro.locals as any).runtime?.env;
const profile = await loadMemberProfile(Astro);
const grants = await loadUserGrants(Astro);
const access = getAccessSnapshot(grants, 'beyondbonus');
const courseItems = getBeyondBonusCourseItems(access);
const beyondBonusModules = await loadBeyondBonusModules(runtimeEnv);

if (!access.course) {
  return Astro.redirect('/members?error=no-access');
}

const moduleSlug = Astro.params.module || '';
const lessonSlug = Astro.params.lesson || '';
const module = getModuleFromModules(beyondBonusModules, moduleSlug);
const lesson = getLessonFromModules(beyondBonusModules, moduleSlug, lessonSlug);

if (!module || !lesson) {
  return Astro.redirect('/members/beyondbonus');
}

const moduleIndex = beyondBonusModules.findIndex((entry) => entry.slug === module.slug);
const previousModule = moduleIndex > 0 ? beyondBonusModules[moduleIndex - 1] : null;
const nextModule = moduleIndex < beyondBonusModules.length - 1 ? beyondBonusModules[moduleIndex + 1] : null;
const lessonIndex = module.lessons.findIndex((entry) => entry.slug === lesson.slug);
const nextLesson = lessonIndex < module.lessons.length - 1 ? module.lessons[lessonIndex + 1] : null;
const lessonKey = getLessonKey(module.slug, lesson.slug);
const mediaEndpoint = `/api/members/media/beyondbonus/${module.slug}/${lesson.slug}`;
---

<Layout
  title={`BeyondBonus – ${lesson.title}`}
  canonical={`https://stiefundgluecklich.de/members/beyondbonus/${module.slug}/${lesson.slug}/`}
  description={lesson.description}
  noHeader={true}
>
  <section class="py-16 md:py-24" data-lesson-key={lessonKey}>
    <div class="container mx-auto px-5 md:px-6 max-w-[1080px]">
      <div class="grid gap-10 lg:grid-cols-[224px_minmax(0,1fr)] lg:items-start">
        <MembersSidebar
          title="Mitgliederbereich"
          subtitle={profile.fullName || 'Dein Profil'}
          currentPath={Astro.url.pathname}
          primaryItems={[{ href: '/members', label: 'Dashboard' }]}
          courseItems={courseItems}
          bottomItems={[
            { href: '/members/settings/account', label: 'Account' },
            { href: '/members/settings/notifications', label: 'Benachrichtigungen' },
            { href: '/members/app', label: 'Als App nutzen' },
            { href: 'mailto:willkommen@sallymatthes.com?subject=Frage%20zu%20BeyondBonus%20Lektion', label: 'Support' },
          ]}
          avatarUrl={profile.avatarUrl}
        />

        <div class="max-w-[820px] space-y-10 min-w-0">
          <div class="space-y-5">
            <a href={`/members/beyondbonus/${module.slug}`} class="inline-flex items-center text-sm text-muted-foreground hover:text-primary transition-colors">← Zurück zu {module.title}</a>

            <nav class="grid gap-3 sm:grid-cols-2" aria-label="Modulnavigation">
              {previousModule && (
                <a href={`/members/beyondbonus/${previousModule.slug}`} class="border border-border/80 px-4 py-3 text-sm hover:bg-secondary/30 transition-colors">← Modul {previousModule.number}: {previousModule.title}</a>
              )}
              {nextModule && (
                <a href={`/members/beyondbonus/${nextModule.slug}`} class="border border-border/80 px-4 py-3 text-sm hover:bg-secondary/30 transition-colors sm:text-right">Modul {nextModule.number}: {nextModule.title} →</a>
              )}
            </nav>

            <header class="space-y-3 pb-2">
              <p class="text-xs uppercase tracking-[0.22em] text-muted-foreground">Modul {module.number} · Lektion {String(lessonIndex + 1).padStart(2, '0')}</p>
              <h1 class="font-serif text-3xl md:text-[2.8rem] leading-none">{lesson.title}</h1>
              <p class="text-base text-muted-foreground leading-relaxed max-w-2xl">{lesson.description}</p>
            </header>
          </div>

          <section class="space-y-5">
            {lesson.workbookReference ? (
              <div class="border border-border bg-secondary/20 p-6 md:p-8 space-y-4 shadow-[0_14px_36px_rgba(0,0,0,0.04)]">
                <p class="text-xs uppercase tracking-[0.18em] text-muted-foreground">Workbook-Übung</p>
                <h2 class="font-serif text-3xl leading-none">{lesson.workbookReference.title}</h2>
                <p class="text-sm text-muted-foreground leading-relaxed">{lesson.workbookReference.text}</p>
                <a href={workbookInfo.downloadUrl} target="_blank" rel="noreferrer" class="inline-flex px-5 py-3 bg-primary text-primary-foreground text-sm font-medium hover:opacity-90 transition-opacity">
                  Workbook öffnen (S. {lesson.workbookReference.pages})
                </a>
              </div>
            ) : (
              <div class="relative aspect-video overflow-hidden bg-secondary/20 shadow-[0_14px_36px_rgba(0,0,0,0.05)]" data-media-shell data-media-endpoint={mediaEndpoint} data-poster={getBeyondBonusLessonCover(module.slug, lesson.slug)} data-duration={lesson.duration || ''}>
                <img src={getBeyondBonusLessonCover(module.slug, lesson.slug)} alt="" class="absolute inset-0 h-full w-full object-cover" aria-hidden="true" />
                <div class="absolute inset-0 bg-black/15"></div>
                {lesson.duration && <span class="absolute bottom-3 right-3 z-20 bg-black/80 px-2 py-1 text-xs font-medium text-white">{lesson.duration}</span>}
                <div class="relative z-10 flex h-full items-center justify-center p-6 md:p-8">
                  <div class="max-w-sm space-y-4 bg-background/92 px-7 py-6 text-center shadow-[0_14px_36px_rgba(0,0,0,0.08)] backdrop-blur-sm">
                    <div class="mx-auto flex h-14 w-14 items-center justify-center border border-border/80 bg-white/75 text-foreground">
                      <svg width="18" height="18" viewBox="0 0 18 18" fill="currentColor" aria-hidden="true">
                        <path d="M5 3.5v11l8-5.5-8-5.5Z" />
                      </svg>
                    </div>
                    <div class="space-y-2">
                      <p class="text-xs uppercase tracking-[0.18em] text-muted-foreground">Video-Lektion{lesson.duration ? ` · ${lesson.duration}` : ''}</p>
                      <p class="text-sm text-muted-foreground leading-relaxed" data-media-status>
                        Video wird geladen ...
                      </p>
                      <p class="text-xs text-muted-foreground/90 leading-relaxed">
                        Wenn das Laden länger dauert, aktualisiere die Seite kurz.
                      </p>
                    </div>
                  </div>
                </div>
              </div>
            )}

            <div class="flex flex-wrap items-center justify-between gap-4 pb-2">
              <div class="space-y-1">
                <p class="text-xs uppercase tracking-[0.18em] text-muted-foreground">Dein Fortschritt</p>
                <p class="text-sm text-muted-foreground" data-lesson-state>Diese Lektion ist noch nicht abgeschlossen.</p>
              </div>
              <button type="button" class="inline-flex px-5 py-3 bg-primary text-primary-foreground text-sm font-medium hover:opacity-90 transition-opacity" data-toggle-complete>
                Als erledigt markieren
              </button>
            </div>
          </section>

          {nextLesson && (
            <a href={`/members/beyondbonus/${module.slug}/${nextLesson.slug}`} class="grid gap-0 md:grid-cols-[170px_1fr] items-stretch border-t border-b border-border/80 py-5 hover:bg-secondary/10 transition-colors">
              <div class="overflow-hidden bg-secondary/20 min-h-[126px] h-full p-3 flex items-center justify-center">
                <img src={getBeyondBonusLessonCover(module.slug, nextLesson.slug)} alt={`Titelbild ${nextLesson.title}`} class="w-full h-full object-contain object-center" />
              </div>
              <div class="p-6 space-y-3 flex flex-col justify-center">
                <p class="text-xs uppercase tracking-[0.18em] text-muted-foreground">Nächste Lektion</p>
                <h2 class="font-serif text-3xl leading-none">{nextLesson.title}</h2>
                <p class="text-sm text-muted-foreground leading-relaxed">Wenn du soweit bist, geht es hier direkt weiter.</p>
              </div>
            </a>
          )}

          <section class="space-y-4 pt-1">
            <div class="space-y-2">
              <p class="text-xs uppercase tracking-[0.18em] text-muted-foreground">Deine Notizen</p>
              <h2 class="font-serif text-3xl leading-none">Was nimmst du aus dieser Lektion mit?</h2>
              <p class="text-sm text-muted-foreground leading-relaxed">Halte hier Gedanken, Erkenntnisse oder nächste Schritte direkt fest.</p>
            </div>
            <textarea data-lesson-notes class="w-full min-h-56 border border-border/80 bg-white px-4 py-3 focus:outline-none focus:border-primary" placeholder="Deine Notizen zu dieser Lektion ..."></textarea>
            <p class="text-xs text-muted-foreground" data-notes-status>Deine Notizen werden nur auf diesem Gerät gespeichert.</p>
          </section>

          <section class="pt-3 border-t border-border/80 max-w-md space-y-3">
            <p class="text-xs uppercase tracking-[0.18em] text-muted-foreground">Support</p>
            <h2 class="font-serif text-2xl leading-tight">Frage zu dieser Lektion?</h2>
            <p class="text-sm text-muted-foreground leading-relaxed">Wenn du an einer Stelle hängst, schreib uns direkt.</p>
            <a href="mailto:willkommen@sallymatthes.com?subject=Frage%20zu%20BeyondBonus%20Lektion" class="inline-flex px-4 py-2 border border-border/80 hover:bg-secondary/40 transition-colors text-sm">Support kontaktieren</a>
          </section>
        </div>
      </div>

      <script is:inline>
        const key = document.querySelector('[data-lesson-key]')?.getAttribute('data-lesson-key');
        const readProgress = () => {
          try {
            return JSON.parse(localStorage.getItem('bb-progress-v1') || '{}');
          } catch {
            return {};
          }
        };
        const writeProgress = (progress) => localStorage.setItem('bb-progress-v1', JSON.stringify(progress));

        const button = document.querySelector('[data-toggle-complete]');
        const state = document.querySelector('[data-lesson-state]');
        const mediaShell = document.querySelector('[data-media-shell]');
        const mediaStatus = document.querySelector('[data-media-status]');
        const notesField = document.querySelector('[data-lesson-notes]');
        const notesStatus = document.querySelector('[data-notes-status]');

        const refresh = () => {
          const progress = readProgress();
          const done = key && progress[key];
          if (state) state.textContent = done ? 'Diese Lektion ist abgeschlossen.' : 'Diese Lektion ist noch nicht abgeschlossen.';
          if (button) button.textContent = done ? 'Als nicht erledigt markieren' : 'Als erledigt markieren';
        };

        const renderMedia = async () => {
          const endpoint = mediaShell?.getAttribute('data-media-endpoint');
          if (!mediaShell || !endpoint) return;

          try {
            const response = await fetch(endpoint, { credentials: 'same-origin' });
            const payload = await response.json();
            if (!response.ok || !payload?.media?.url) {
              throw new Error(payload?.error || 'media-unavailable');
            }

            const media = payload.media;
            const poster = mediaShell.getAttribute('data-poster') || '';
            const duration = mediaShell.getAttribute('data-duration') || '';
            mediaShell.innerHTML = '';

            if (media.provider === 'youtube') {
              const iframe = document.createElement('iframe');
              iframe.src = media.url;
              iframe.className = 'w-full h-full bg-black';
              iframe.setAttribute('allow', 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share');
              iframe.setAttribute('allowfullscreen', 'true');
              iframe.setAttribute('loading', 'lazy');
              mediaShell.appendChild(iframe);
              if (duration) {
                const badge = document.createElement('span');
                badge.className = 'absolute bottom-3 right-3 z-20 bg-black/80 px-2 py-1 text-xs font-medium text-white';
                badge.textContent = duration;
                mediaShell.appendChild(badge);
              }
              return;
            }

            if (media.provider !== 'drive-preview') {
              if (media.kind === 'audio') {
                const wrapper = document.createElement('div');
                wrapper.className = 'w-full h-full flex items-center justify-center p-8 bg-secondary/10';
                const audio = document.createElement('audio');
                audio.src = media.url;
                audio.controls = true;
                audio.preload = 'metadata';
                audio.className = 'w-full';
                wrapper.appendChild(audio);
                mediaShell.appendChild(wrapper);
                return;
              }

              const video = document.createElement('video');
              video.src = media.url;
              if (poster) video.poster = poster;
              video.controls = true;
              video.playsInline = true;
              video.preload = 'metadata';
              video.className = 'w-full h-full object-cover bg-black';
              mediaShell.appendChild(video);
              if (duration) {
                const badge = document.createElement('span');
                badge.className = 'absolute bottom-3 right-3 z-20 bg-black/80 px-2 py-1 text-xs font-medium text-white';
                badge.textContent = duration;
                mediaShell.appendChild(badge);
              }
              return;
            }

            const iframe = document.createElement('iframe');
            iframe.src = media.url;
            iframe.className = 'w-full h-full bg-white';
            iframe.setAttribute('allow', 'autoplay');
            iframe.setAttribute('allowfullscreen', 'true');
            iframe.setAttribute('loading', 'lazy');
            mediaShell.appendChild(iframe);
          } catch (_error) {
            if (mediaStatus) {
              mediaStatus.textContent = 'Diese Lektion ist angelegt, aber das Video ist gerade noch nicht verfügbar.';
            }
          }
        };

        const notesKey = key ? `bb-notes-v1::${key}` : null;
        if (notesField && notesKey) {
          try {
            notesField.value = localStorage.getItem(notesKey) || '';
          } catch {}

          notesField.addEventListener('input', () => {
            try {
              localStorage.setItem(notesKey, notesField.value);
              if (notesStatus) notesStatus.textContent = 'Notizen gespeichert.';
            } catch {
              if (notesStatus) notesStatus.textContent = 'Notizen konnten auf diesem Gerät gerade nicht gespeichert werden.';
            }
          });
        }

        const syncProgress = async () => {
          const progress = readProgress();
          refresh();
          try {
            const response = await fetch('/api/members/progress', { credentials: 'same-origin' });
            const payload = await response.json();
            if (!response.ok || !Array.isArray(payload.progress)) return;
            payload.progress.forEach((entry) => {
              if (entry.lesson_key) progress[entry.lesson_key] = Boolean(entry.completed);
            });
            writeProgress(progress);
            refresh();
          } catch {}
        };

        button?.addEventListener('click', async () => {
          if (!key) return;
          const progress = readProgress();
          progress[key] = !progress[key];
          writeProgress(progress);
          refresh();
          try {
            await fetch('/api/members/progress', {
              method: 'POST',
              credentials: 'same-origin',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ lessonKey: key, completed: Boolean(progress[key]) }),
            });
          } catch {}
        });

        syncProgress();
        renderMedia();
      </script>
    </div>
  </section>
</Layout>
