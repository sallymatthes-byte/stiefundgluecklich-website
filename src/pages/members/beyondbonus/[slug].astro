---
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import MembersSidebar from '../../../components/MembersSidebar.astro';
import { getAccessSnapshot } from '../../../lib/auth/grants';
import { loadUserGrants } from '../../../lib/auth/load-grants';
import { beyondBonusModules, getBeyondBonusModule, getBeyondBonusModuleCover, getLessonKey } from '../../../lib/beyondbonus/content';

const grants = await loadUserGrants(Astro);
const access = getAccessSnapshot(grants, 'beyondbonus');

if (!access.course) {
  return Astro.redirect('/members?error=no-access');
}

const slug = Astro.params.slug || '';
const module = getBeyondBonusModule(slug);

if (!module) {
  return Astro.redirect('/members/beyondbonus');
}
---

<Layout
  title={`BeyondBonus – ${module.title}`}
  canonical={`https://stiefundgluecklich.de/members/beyondbonus/${module.slug}/`}
  description={module.shortDescription}
  noHeader={true}
>
  <section class="py-16 md:py-20">
    <div class="container mx-auto px-5 md:px-6 max-w-7xl">
      <div class="grid gap-8 lg:grid-cols-[260px,minmax(0,1fr)] items-start">
        <MembersSidebar
          title="BeyondBonus"
          subtitle={module.title}
          currentPath={Astro.url.pathname}
          topItems={[
            { href: '/members', label: 'Dashboard' },
            { href: '/members/beyondbonus', label: 'Kursübersicht' },
            ...beyondBonusModules.map((entry) => ({ href: `/members/beyondbonus/${entry.slug}`, label: `Modul ${entry.number}` })),
            { href: '/members/beyondbonus/workbook', label: 'Workbook' },
          ]}
          bottomItems={[
            { href: '/members/settings/account', label: 'Account' },
            { href: '/members/settings/notifications', label: 'Benachrichtigungen' },
            { href: 'mailto:willkommen@sallymatthes.com?subject=Frage%20zu%20BeyondBonus%20Modul', label: 'Support' },
          ]}
        />

        <div class="space-y-8">
          <a href="/members/beyondbonus" class="inline-flex items-center text-sm text-muted-foreground hover:text-primary transition-colors">← Zurück zur Kursübersicht</a>

          <section class="relative overflow-hidden border border-border min-h-[240px] bg-[#31372a] text-white">
            <img src={getBeyondBonusModuleCover(module.slug)} alt={`Cover ${module.title}`} class="absolute inset-0 w-full h-full object-cover opacity-80" />
            <div class="absolute inset-0 bg-gradient-to-r from-black/55 via-black/30 to-transparent"></div>
            <div class="relative h-full p-8 md:p-10 flex flex-col justify-between gap-8">
              <div class="max-w-md space-y-3 bg-black/18 backdrop-blur-[1px] p-6 md:p-7">
                <p class="text-xs uppercase tracking-[0.22em] text-white/70">Modul {module.number}</p>
                <h1 class="font-serif text-4xl md:text-5xl leading-none">{module.title}</h1>
                <p class="text-base text-white/85 leading-relaxed">{module.intro}</p>
              </div>

              <div class="flex flex-wrap items-end justify-between gap-6">
                <div>
                  <p class="text-sm text-white/75">{module.lessons.length} Lektionen in diesem Modul</p>
                </div>
                <div class="w-24 h-24 rounded-full border-[6px] border-white/30 flex items-center justify-center text-2xl font-medium bg-black/25 backdrop-blur-sm" data-module-progress-circle>
                  0%
                </div>
              </div>
            </div>
          </section>

          <section class="border border-border bg-[#868b72] text-white px-6 py-4 flex flex-wrap items-center justify-between gap-4">
            <div>
              <p class="text-xs uppercase tracking-[0.18em] text-white/70">Mache direkt weiter</p>
              <p class="font-serif text-2xl" data-next-lesson-label>{module.lessons[0]?.title || 'Einführung'}</p>
            </div>
            <a href={`/members/beyondbonus/${module.slug}/${module.lessons[0]?.slug || ''}`} class="inline-flex px-5 py-3 bg-white/10 border border-white/25 text-white text-sm font-medium hover:bg-white/15 transition-colors" data-next-lesson-link>
              Fortsetzen
            </a>
          </section>

          <div class="grid gap-8 lg:grid-cols-[1fr,320px] items-start">
            <section class="space-y-4">
              <div class="space-y-1">
                <p class="text-xs uppercase tracking-[0.18em] text-muted-foreground">Lektionen</p>
                <h2 class="font-serif text-3xl">Dein Weg durch dieses Modul</h2>
              </div>

              <div class="space-y-4">
                {module.lessons.map((lesson, index) => (
                  <a href={`/members/beyondbonus/${module.slug}/${lesson.slug}`} class="grid gap-0 md:grid-cols-[180px,1fr,84px] items-stretch border border-border bg-background hover:shadow-[0_10px_30px_rgba(0,0,0,0.08)] transition-shadow" data-lesson-card data-lesson-key={getLessonKey(module.slug, lesson.slug)}>
                    <div class="aspect-[16/10] md:aspect-auto overflow-hidden bg-black min-h-[120px]">
                      <img src={getBeyondBonusModuleCover(module.slug)} alt={`Cover ${lesson.title}`} class="w-full h-full object-cover" />
                    </div>
                    <div class="p-6 space-y-3">
                      <p class="text-xs uppercase tracking-[0.18em] text-muted-foreground">Lektion {String(index + 1).padStart(2, '0')}</p>
                      <h3 class="font-serif text-2xl leading-none">{lesson.title}</h3>
                      <p class="text-sm text-muted-foreground leading-relaxed">{lesson.description}</p>
                    </div>
                    <div class="px-6 py-6 flex items-center md:justify-end">
                      <span class="w-12 h-12 rounded-full border border-border flex items-center justify-center text-sm text-muted-foreground bg-secondary/30" data-lesson-state>○</span>
                    </div>
                  </a>
                ))}
              </div>
            </section>

            <aside class="space-y-6">
              <section class="border border-border bg-background p-6 space-y-3">
                <p class="text-xs uppercase tracking-[0.18em] text-muted-foreground">Workbook</p>
                <h2 class="font-serif text-2xl">Alle Materialien gesammelt</h2>
                <p class="text-sm text-muted-foreground leading-relaxed">Im Workbook findest du die Übungen, Reflexionsfragen und Transferimpulse zu diesem Modul gebündelt an einem Ort.</p>
                <a href="/members/beyondbonus/workbook" class="inline-flex px-4 py-2 border border-border hover:bg-secondary/40 transition-colors text-sm">Workbook öffnen</a>
              </section>

              <section class="border border-border bg-background p-6 space-y-3">
                <p class="text-xs uppercase tracking-[0.18em] text-muted-foreground">Support</p>
                <h2 class="font-serif text-2xl">Frage zu diesem Modul?</h2>
                <p class="text-sm text-muted-foreground leading-relaxed">Wenn du an einer Stelle hängst, schreib uns direkt statt allein weiterzudrehen.</p>
                <a href="mailto:willkommen@sallymatthes.com?subject=Frage%20zu%20BeyondBonus%20Modul" class="inline-flex px-4 py-2 border border-border hover:bg-secondary/40 transition-colors text-sm">Support kontaktieren</a>
              </section>
            </aside>
          </div>
        </div>
      </div>

      <script is:inline>
        const readProgress = () => {
          try {
            return JSON.parse(localStorage.getItem('bb-progress-v1') || '{}');
          } catch {
            return {};
          }
        };

        const progress = readProgress();
        const lessonCards = [...document.querySelectorAll('[data-lesson-card]')];
        let done = 0;
        let nextHref = null;
        let nextTitle = null;
        lessonCards.forEach((card) => {
          const key = card.getAttribute('data-lesson-key');
          const isDone = key && progress[key];
          const state = card.querySelector('[data-lesson-state]');
          if (isDone) {
            done += 1;
            if (state) state.textContent = '✓';
            if (state) state.className = 'w-12 h-12 rounded-full border border-primary flex items-center justify-center text-sm text-primary bg-secondary/40';
          } else if (!nextHref) {
            nextHref = card.getAttribute('href');
            nextTitle = card.querySelector('h3')?.textContent?.trim();
          }
        });
        const total = lessonCards.length;
        const percent = total ? Math.round((done / total) * 100) : 0;
        const circle = document.querySelector('[data-module-progress-circle]');
        if (circle) {
          circle.textContent = `${percent}%`;
          circle.style.background = `conic-gradient(#3ed39f ${percent}%, rgba(255,255,255,0.18) ${percent}% 100%)`;
        }
        const nextLabel = document.querySelector('[data-next-lesson-label]');
        const nextLink = document.querySelector('[data-next-lesson-link]');
        if (nextTitle && nextLabel) nextLabel.textContent = nextTitle;
        if (nextHref && nextLink) nextLink.setAttribute('href', nextHref);
      </script>
    </div>
  </section>
</Layout>
