---
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import MembersSidebar from '../../../components/MembersSidebar.astro';
import { getAccessSnapshot } from '../../../lib/auth/grants';
import { loadUserGrants } from '../../../lib/auth/load-grants';
import { loadMemberProfile } from '../../../lib/auth/load-profile';
import { beyondBonusModules, getBeyondBonusModule, getBeyondBonusLessonCover, getLessonKey } from '../../../lib/beyondbonus/content';
import { getBeyondBonusCourseItems } from '../../../lib/members/navigation';

const profile = await loadMemberProfile(Astro);
const grants = await loadUserGrants(Astro);
const access = getAccessSnapshot(grants, 'beyondbonus');
const courseItems = getBeyondBonusCourseItems(access);

if (!access.course) {
  return Astro.redirect('/members?error=no-access');
}

const slug = Astro.params.slug || '';
const module = getBeyondBonusModule(slug);

if (!module) {
  return Astro.redirect('/members/beyondbonus');
}

const moduleIndex = beyondBonusModules.findIndex((entry) => entry.slug === module.slug);
const previousModule = moduleIndex > 0 ? beyondBonusModules[moduleIndex - 1] : null;
const nextModule = moduleIndex < beyondBonusModules.length - 1 ? beyondBonusModules[moduleIndex + 1] : null;
---

<Layout
  title={`BeyondBonus – ${module.title}`}
  canonical={`https://stiefundgluecklich.de/members/beyondbonus/${module.slug}/`}
  description={module.shortDescription}
  noHeader={true}
>
  <section class="py-16 md:py-24">
    <div class="container mx-auto px-5 md:px-6 max-w-[1080px]">
      <div class="grid gap-10 lg:grid-cols-[224px_minmax(0,1fr)] lg:items-start">
        <MembersSidebar
          title="Mitgliederbereich"
          subtitle={profile.fullName || 'Dein Profil'}
          currentPath={Astro.url.pathname}
          primaryItems={[{ href: '/members', label: 'Dashboard' }]}
          courseItems={courseItems}
          bottomItems={[
            { href: '/members/settings/account', label: 'Account' },
            { href: '/members/settings/notifications', label: 'Benachrichtigungen' },
            { href: '/members/app', label: 'Als App nutzen' },
            { href: 'mailto:willkommen@sallymatthes.com?subject=Frage%20zu%20BeyondBonus%20Modul', label: 'Support' },
          ]}
          avatarUrl={profile.avatarUrl}
        />

        <div class="max-w-[820px] min-w-0 space-y-8">
          <header class="space-y-4">
            <p class="text-sm uppercase tracking-[0.2em] text-muted-foreground">BeyondBonus · Modul {module.number}</p>
            <div class="space-y-4">
              <div class="bg-secondary/15 p-4 flex items-center justify-center">
                <img src={module.moduleCover} alt={`Titelbild ${module.title}`} class="w-full max-h-[240px] object-contain" />
              </div>
              <div class="space-y-3">
                <h1 class="font-serif text-3xl md:text-[2.8rem] leading-none">{module.title}</h1>
                <p class="text-base text-muted-foreground leading-relaxed max-w-3xl">{module.intro}</p>
              </div>
            </div>
          </header>

          <nav class="grid gap-3 sm:grid-cols-2" aria-label="Modulnavigation">
            {previousModule && (
              <a href={`/members/beyondbonus/${previousModule.slug}`} class="border border-border/80 px-4 py-3 text-sm hover:bg-secondary/30 transition-colors">← Modul {previousModule.number}: {previousModule.title}</a>
            )}
            {nextModule && (
              <a href={`/members/beyondbonus/${nextModule.slug}`} class="border border-border/80 px-4 py-3 text-sm hover:bg-secondary/30 transition-colors sm:text-right">Modul {nextModule.number}: {nextModule.title} →</a>
            )}
          </nav>

          <section class="border border-border bg-background p-6 shadow-[0_10px_24px_rgba(0,0,0,0.02)]">
            <div class="flex items-center justify-between gap-4 mb-4">
              <h2 class="font-serif text-2xl">Lektionen in diesem Modul</h2>
              <span class="text-xs text-muted-foreground" data-module-progress-label>0 von {module.lessons.length} abgeschlossen</span>
            </div>

            <div class="h-2 bg-secondary overflow-hidden mb-6">
              <div class="h-full bg-primary w-0 transition-all" data-module-progress-bar></div>
            </div>

            <div class="space-y-3">
              {module.lessons.map((lesson, index) => (
                <a href={`/members/beyondbonus/${module.slug}/${lesson.slug}`} class="block border border-border p-4 bg-secondary/12 hover:border-primary transition-colors" data-lesson-card data-lesson-key={getLessonKey(module.slug, lesson.slug)}>
                  <div class="grid gap-4 lg:grid-cols-[130px_minmax(0,1fr)_auto] items-start">
                    <div class="overflow-hidden bg-secondary/20 min-h-[88px] p-2 flex items-center justify-center">
                      <img src={getBeyondBonusLessonCover(module.slug, lesson.slug)} alt={`Titelbild ${lesson.title}`} class="w-full h-full object-contain" />
                    </div>
                    <div class="space-y-2">
                      <p class="text-xs uppercase tracking-[0.18em] text-muted-foreground">Lektion {String(index + 1).padStart(2, '0')}</p>
                      <h3 class="font-serif text-xl">{lesson.title}</h3>
                      <p class="text-sm text-muted-foreground leading-relaxed">{lesson.description}</p>
                    </div>
                    <div class="flex flex-wrap gap-2 lg:justify-end">
                      <span class="text-xs px-2 py-1 bg-background border border-border whitespace-nowrap">{lesson.workbookReference ? `Workbook S. ${lesson.workbookReference.pages}` : lesson.duration || 'Video'}</span>
                      <span class="text-xs px-2 py-1 bg-background border border-border whitespace-nowrap" data-lesson-state>Nicht gestartet</span>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </section>
        </div>
      </div>

      <script is:inline>
        const readProgress = () => {
          try {
            return JSON.parse(localStorage.getItem('bb-progress-v1') || '{}');
          } catch {
            return {};
          }
        };

        const progress = readProgress();
        const lessonCards = [...document.querySelectorAll('[data-lesson-card]')];
        let done = 0;
        lessonCards.forEach((card) => {
          const key = card.getAttribute('data-lesson-key');
          const isDone = key && progress[key];
          const state = card.querySelector('[data-lesson-state]');
          if (isDone) {
            done += 1;
            if (state) state.textContent = 'Erledigt';
          }
        });
        const total = lessonCards.length;
        const percent = total ? Math.round((done / total) * 100) : 0;
        const bar = document.querySelector('[data-module-progress-bar]');
        const label = document.querySelector('[data-module-progress-label]');
        if (bar) bar.style.width = `${percent}%`;
        if (label) label.textContent = `${done} von ${total} abgeschlossen`;
      </script>
    </div>
  </section>
</Layout>
