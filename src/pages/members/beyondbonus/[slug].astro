---
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import { getAccessSnapshot } from '../../../lib/auth/grants';
import { loadUserGrants } from '../../../lib/auth/load-grants';
import { beyondBonusModules, getBeyondBonusModule, getLessonKey } from '../../../lib/beyondbonus/content';

const grants = await loadUserGrants(Astro);
const access = getAccessSnapshot(grants, 'beyondbonus');

if (!access.course) {
  return Astro.redirect('/members?error=no-access');
}

const slug = Astro.params.slug || '';
const module = getBeyondBonusModule(slug);

if (!module) {
  return Astro.redirect('/members/beyondbonus');
}
---

<Layout
  title={`BeyondBonus – ${module.title}`}
  canonical={`https://stiefundgluecklich.de/members/beyondbonus/${module.slug}/`}
  description={module.shortDescription}
>
  <section class="py-20 md:py-28">
    <div class="container mx-auto px-5 md:px-6 max-w-5xl">
      <a href="/members/beyondbonus" class="inline-flex items-center text-sm text-muted-foreground hover:text-primary transition-colors mb-6">
        ← Zurück zum Kursbereich
      </a>

      <p class="text-sm uppercase tracking-[0.2em] text-muted-foreground mb-4">BeyondBonus · Modul {module.number}</p>
      <h1 class="font-serif text-3xl md:text-4xl mb-4">{module.title}</h1>
      <p class="text-base text-muted-foreground mb-10 leading-relaxed max-w-3xl">{module.intro}</p>

      <div class="grid gap-8 lg:grid-cols-[1.2fr,0.8fr]">
        <div class="space-y-8">
          <section class="border border-border p-6 bg-background">
            <div class="flex items-center justify-between gap-4 mb-4">
              <h2 class="font-serif text-2xl">Lektionen in diesem Modul</h2>
              <span class="text-xs text-muted-foreground" data-module-progress-label>0 von {module.lessons.length} abgeschlossen</span>
            </div>
            <div class="h-2 bg-secondary overflow-hidden mb-6">
              <div class="h-full bg-primary w-0 transition-all" data-module-progress-bar></div>
            </div>
            <div class="space-y-3">
              {module.lessons.map((lesson, index) => (
                <a href={`/members/beyondbonus/${module.slug}/${lesson.slug}`} class="border border-border p-4 bg-secondary/30 hover:border-primary transition-colors block" data-lesson-card data-lesson-key={getLessonKey(module.slug, lesson.slug)}>
                  <div class="flex items-start justify-between gap-4">
                    <div>
                      <p class="text-xs uppercase tracking-[0.18em] text-muted-foreground mb-2">Lektion {String(index + 1).padStart(2, '0')}</p>
                      <h3 class="font-serif text-xl mb-2">{lesson.title}</h3>
                      <p class="text-sm text-muted-foreground leading-relaxed">{lesson.description}</p>
                    </div>
                    <span class="text-xs px-2 py-1 bg-background border border-border whitespace-nowrap" data-lesson-state>Nicht gestartet</span>
                  </div>
                </a>
              ))}
            </div>
          </section>

          <section class="border border-border p-6 bg-background">
            <h2 class="font-serif text-2xl mb-4">Workbook</h2>
            <p class="text-sm text-muted-foreground leading-relaxed">
              BeyondBonus bekommt ein zentrales Workbook für das gesamte Programm. Die finale Fassung hängen wir als Nächstes hier an, statt Einzel-Downloads pro Modul zu verteilen.
            </p>
          </section>
        </div>

        <aside class="space-y-6">
          <section class="border border-border p-6 bg-secondary/40">
            <h2 class="font-serif text-xl mb-3">Modulübersicht</h2>
            <div class="space-y-2 text-sm">
              {beyondBonusModules.map((entry) => (
                <a
                  href={`/members/beyondbonus/${entry.slug}`}
                  class={`block transition-colors ${entry.slug === module.slug ? 'text-primary font-medium' : 'text-muted-foreground hover:text-primary'}`}
                >
                  Modul {entry.number} · {entry.title}
                </a>
              ))}
            </div>
          </section>

          <section class="border border-border p-6 bg-secondary/40">
            <h2 class="font-serif text-xl mb-3">Videoquelle</h2>
            <p class="text-sm text-muted-foreground leading-relaxed">
              Die Rohvideos liegen im Google-Drive-Ordner <strong>Videos BeyondBonus</strong>. Die Lektionsseiten greifen in diesem Build auf diese Quelle als Zwischenstand zurück, bis die geschützte Auslieferung über R2 hängt.
            </p>
          </section>
        </aside>
      </div>

      <script is:inline>
        const readProgress = () => {
          try {
            return JSON.parse(localStorage.getItem('bb-progress-v1') || '{}');
          } catch {
            return {};
          }
        };

        const progress = readProgress();
        const lessonCards = [...document.querySelectorAll('[data-lesson-card]')];
        let done = 0;
        lessonCards.forEach((card) => {
          const key = card.getAttribute('data-lesson-key');
          const isDone = key && progress[key];
          const state = card.querySelector('[data-lesson-state]');
          if (isDone) {
            done += 1;
            if (state) state.textContent = 'Erledigt';
          }
        });
        const total = lessonCards.length;
        const percent = total ? Math.round((done / total) * 100) : 0;
        const bar = document.querySelector('[data-module-progress-bar]');
        const label = document.querySelector('[data-module-progress-label]');
        if (bar) bar.style.width = `${percent}%`;
        if (label) label.textContent = `${done} von ${total} abgeschlossen`;
      </script>
    </div>
  </section>
</Layout>
