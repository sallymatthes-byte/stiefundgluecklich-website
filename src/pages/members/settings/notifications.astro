---
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import MembersSidebar from '../../../components/MembersSidebar.astro';
import { getAccessSnapshot } from '../../../lib/auth/grants';
import { loadUserGrants } from '../../../lib/auth/load-grants';
import { loadMemberProfile } from '../../../lib/auth/load-profile';
import { getBeyondBonusCourseItems } from '../../../lib/members/navigation';

const profile = await loadMemberProfile(Astro);
const grants = await loadUserGrants(Astro);
const beyondBonus = getAccessSnapshot(grants, 'beyondbonus');
const courseItems = getBeyondBonusCourseItems(beyondBonus);
const settings = [
  ['Neue Inhalte', 'Wenn neue Inhalte für dich freigeschaltet werden, informieren wir dich direkt.'],
  ['Antwort von Sally', 'Wenn du Support brauchst, läuft die Rückmeldung aktuell direkt per E-Mail.'],
  ['Dranbleiben', 'Erinnerungen und Kursimpulse ergänzen wir erst, wenn der Mitgliederbereich im Alltag getestet ist.'],
];
---

<Layout
  title="Benachrichtigungen"
  canonical="https://stiefundgluecklich.de/members/settings/notifications/"
  description="Benachrichtigungseinstellungen im Mitgliederbereich."
  noHeader={true}
>
  <section class="py-16 md:py-24">
    <div class="container mx-auto px-5 md:px-6 max-w-[1080px]">
      <div class="grid gap-10 lg:grid-cols-[224px_minmax(0,1fr)] lg:items-start">
        <MembersSidebar
          title="Mitgliederbereich"
          subtitle={profile.fullName || 'Dein Profil'}
          currentPath={Astro.url.pathname}
          primaryItems={[{ href: '/members', label: 'Dashboard' }]}
          courseItems={courseItems}
          bottomItems={[
            { href: '/members/settings/account', label: 'Account' },
            { href: '/members/settings/notifications', label: 'Benachrichtigungen' },
            { href: 'mailto:willkommen@sallymatthes.com?subject=Frage%20zum%20Mitgliederbereich', label: 'Support' },
          ]}
          avatarUrl={profile.avatarUrl}
        />

        <div class="max-w-[820px] min-w-0 space-y-8">
          <div class="space-y-4">
            <p class="text-sm uppercase tracking-[0.2em] text-muted-foreground">Einstellungen</p>
            <div class="space-y-3">
              <h1 class="font-serif text-3xl md:text-[2.8rem] leading-none">Benachrichtigungen</h1>
              <p class="text-base text-muted-foreground leading-relaxed max-w-3xl">
                Hier siehst du, welche Benachrichtigungen für den Mitgliederbereich vorgesehen sind. Aktuell musst du hier nichts einstellen.
              </p>
            </div>
          </div>

          <section class="border border-border p-6 bg-background space-y-4 shadow-[0_10px_24px_rgba(0,0,0,0.02)]">
            {settings.map(([title, description]) => (
              <div class="flex items-center justify-between gap-6 border-b border-border pb-4 last:border-b-0 last:pb-0">
                <div>
                  <h2 class="font-serif text-xl mb-1">{title}</h2>
                  <p class="text-sm text-muted-foreground">{description}</p>
                </div>
                <span class="whitespace-nowrap border border-border bg-secondary/30 px-4 py-2 text-sm text-muted-foreground">Vorgesehen</span>
              </div>
            ))}
          </section>
        </div>
      </div>
    </div>
  </section>
</Layout>
