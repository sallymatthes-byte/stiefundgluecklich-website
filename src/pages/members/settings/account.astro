---
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';

const userEmail = Astro.locals.user?.email ?? '';
---

<Layout
  title="Account-Einstellungen"
  canonical="https://stiefundgluecklich.de/members/settings/account/"
  description="Account-Einstellungen im Mitgliederbereich."
  noHeader={true}
>
  <section class="py-20 md:py-28">
    <div class="container mx-auto px-5 md:px-6 max-w-5xl">
      <a href="/members" class="inline-flex items-center text-sm text-muted-foreground hover:text-primary transition-colors mb-6">
        ← Zurück zum Mitgliederbereich
      </a>

      <p class="text-sm uppercase tracking-[0.2em] text-muted-foreground mb-4">Einstellungen</p>
      <h1 class="font-serif text-3xl md:text-4xl mb-4">Account-Einstellungen</h1>
      <p class="text-base text-muted-foreground mb-8 leading-relaxed max-w-3xl">
        Hier findest du die wichtigsten Einstellungen rund um deinen Zugang, dein Passwort und deine Sprache.
      </p>

      <div class="grid gap-8 md:grid-cols-[240px_minmax(0,1fr)] md:items-start">
        <section class="border border-border p-6 bg-background space-y-4">
          <h2 class="font-serif text-2xl">Dein Zugang</h2>
          <p class="text-sm text-muted-foreground">Angemeldete E-Mail-Adresse</p>
          <p class="text-base">{userEmail}</p>
          <a href="/login" class="text-sm text-primary hover:opacity-80 transition-opacity">Passwort über Login-Seite zurücksetzen</a>
        </section>

        <section class="border border-border p-6 bg-background space-y-5">
          <h2 class="font-serif text-2xl">Persönliche Einstellungen</h2>
          <div class="grid gap-4 md:grid-cols-2">
            <label class="block">
              <span class="block text-sm mb-2">Anzeigesprache</span>
              <select class="w-full border border-border bg-white px-4 py-3 focus:outline-none focus:border-primary">
                <option>Deutsch</option>
                <option>English</option>
                <option>Français</option>
              </select>
            </label>
            <label class="block">
              <span class="block text-sm mb-2">Zeitzone</span>
              <select class="w-full border border-border bg-white px-4 py-3 focus:outline-none focus:border-primary">
                <option>Europe/Paris</option>
                <option>Europe/Berlin</option>
                <option>UTC</option>
              </select>
            </label>
          </div>
          <p class="text-sm text-muted-foreground">Die Sprachumschaltung ist als Vorbereitung schon angelegt. Als Nächstes können die Inhalte dafür vollständig mehrsprachig aufgebaut werden.</p>
        </section>
      </div>
    </div>
  </section>
</Layout>
