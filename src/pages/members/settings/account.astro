---
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import MembersSidebar from '../../../components/MembersSidebar.astro';
import { loadMemberProfile } from '../../../lib/auth/load-profile';

const profile = await loadMemberProfile(Astro);
const userEmail = profile.email || Astro.locals.user?.email || '';
const firstName = (profile.fullName || userEmail).split(/[._@-]/)[0] || '';
const profileName = profile.fullName || (firstName ? firstName.charAt(0).toUpperCase() + firstName.slice(1) : '');
const saved = Astro.url.searchParams.get('saved') === '1';
const error = Astro.url.searchParams.get('error');
---

<Layout
  title="Account-Einstellungen"
  canonical="https://stiefundgluecklich.de/members/settings/account/"
  description="Account-Einstellungen im Mitgliederbereich."
  noHeader={true}
>
  <section class="py-16 md:py-20">
    <div class="container mx-auto px-5 md:px-6 max-w-7xl">
      <div class="grid gap-8 md:grid-cols-[240px,minmax(0,1fr)] items-start">
        <MembersSidebar
          title="Mitgliederbereich"
          subtitle={profileName ? `Hallo ${profileName}` : 'Dein Account'}
          currentPath={Astro.url.pathname}
          topItems={[
            { href: '/members', label: 'Dashboard' },
            { href: '/members/beyondbonus', label: 'BeyondBonus' },
            { href: '/livecalls/beyondbonus', label: 'Livecalls' },
          ]}
          bottomItems={[
            { href: '/members/settings/account', label: 'Account' },
            { href: '/members/settings/notifications', label: 'Benachrichtigungen' },
            { href: 'mailto:willkommen@sallymatthes.com?subject=Frage%20zu%20meinem%20Account', label: 'Support' },
          ]}
        />

        <div class="space-y-8">
          <a href="/members" class="inline-flex items-center text-sm text-muted-foreground hover:text-primary transition-colors">← Zurück zum Mitgliederbereich</a>

          <section class="border border-border bg-[#8b8d79] text-white p-8 md:p-10 space-y-3">
            <p class="text-xs uppercase tracking-[0.22em] text-white/70">Einstellungen</p>
            <h1 class="font-serif text-4xl md:text-5xl leading-none">Account-Einstellungen</h1>
            <p class="text-base text-white/85 leading-relaxed max-w-3xl">Ändere hier deine Informationen, dein Profilbild und alles, was zu deinem persönlichen Bereich gehört.</p>
          </section>

          {saved && (
            <div class="border border-border bg-secondary/35 p-4 text-sm leading-relaxed">
              Deine Angaben wurden gespeichert.
            </div>
          )}

          {error && (
            <div class="border border-red-200 bg-red-50 p-4 text-sm leading-relaxed">
              Die Angaben konnten gerade nicht gespeichert werden: {error}
            </div>
          )}

          <div class="inline-flex flex-wrap border border-border bg-background text-sm">
            <a href="/members/settings/account" class="px-5 py-3 border-r border-border bg-background text-foreground">Allgemein</a>
            <a href="/members/settings/notifications" class="px-5 py-3 border-r border-border text-muted-foreground hover:text-foreground transition-colors">Benachrichtigungen</a>
            <span class="px-5 py-3 text-muted-foreground">Geräte</span>
          </div>

          <form method="POST" action="/api/account/update-profile" class="grid gap-8 lg:grid-cols-[360px,1fr] items-start">
            <section class="border border-border bg-background p-6 md:p-8 space-y-6">
              <div class="space-y-2">
                <h2 class="font-serif text-3xl">Dein Profilbild</h2>
                <p class="text-sm text-muted-foreground">Ein persönliches Bild macht deinen Bereich sofort wärmer und wiedererkennbar.</p>
              </div>

              <div class="flex flex-col items-center text-center gap-5">
                <div class="w-56 h-56 rounded-full overflow-hidden border-4 border-white shadow-[0_10px_30px_rgba(0,0,0,0.12)] bg-secondary/20 flex items-center justify-center">
                  {profile.avatarUrl ? (
                    <img src={profile.avatarUrl} alt={`Profilbild von ${profileName || 'Mitglied'}`} class="w-full h-full object-cover" />
                  ) : (
                    <div class="px-6">
                      <p class="font-serif text-3xl">{profileName || 'Dein Bild'}</p>
                    </div>
                  )}
                </div>
                <p class="text-sm text-muted-foreground">Füge hier einfach eine Bild-URL ein, damit dein Profilbild direkt sichtbar wird.</p>
              </div>
            </section>

            <section class="border border-border bg-background p-6 md:p-8 space-y-6">
              <div class="space-y-2">
                <h2 class="font-serif text-3xl">Persönliche Informationen</h2>
                <p class="text-sm text-muted-foreground">Alles, was zu deinem Account im Mitgliederbereich gehört.</p>
              </div>

              <div class="grid gap-4 md:grid-cols-2">
                <label class="block md:col-span-2">
                  <span class="block text-sm mb-2">Profilbild-URL</span>
                  <input type="url" name="avatar_url" value={profile.avatarUrl} placeholder="https://..." class="w-full border border-border bg-white px-4 py-3 focus:outline-none focus:border-primary" />
                </label>
                <label class="block">
                  <span class="block text-sm mb-2">Vorname / Name</span>
                  <input type="text" name="full_name" value={profile.fullName} placeholder="Dein Name" class="w-full border border-border bg-white px-4 py-3 focus:outline-none focus:border-primary" />
                </label>
                <label class="block">
                  <span class="block text-sm mb-2">Telefonnummer</span>
                  <input type="text" name="phone" value={profile.phone} placeholder="Telefonnummer" class="w-full border border-border bg-white px-4 py-3 focus:outline-none focus:border-primary" />
                </label>
                <label class="block md:col-span-2">
                  <span class="block text-sm mb-2">E-Mail-Adresse</span>
                  <input type="email" value={userEmail} readonly class="w-full border border-border bg-secondary/20 px-4 py-3 text-muted-foreground focus:outline-none" />
                  <span class="block text-xs text-muted-foreground mt-2">Diese E-Mail ist aktuell dein Login. Wenn sie geändert werden soll, machen wir das im nächsten Schritt sauber über den Auth-Flow.</span>
                </label>
                <label class="block md:col-span-2">
                  <span class="block text-sm mb-2">Straße und Hausnummer</span>
                  <input type="text" name="address_line1" value={profile.addressLine1} placeholder="Straße und Hausnummer" class="w-full border border-border bg-white px-4 py-3 focus:outline-none focus:border-primary" />
                </label>
                <label class="block">
                  <span class="block text-sm mb-2">PLZ</span>
                  <input type="text" name="postal_code" value={profile.postalCode} placeholder="PLZ" class="w-full border border-border bg-white px-4 py-3 focus:outline-none focus:border-primary" />
                </label>
                <label class="block">
                  <span class="block text-sm mb-2">Stadt</span>
                  <input type="text" name="city" value={profile.city} placeholder="Stadt" class="w-full border border-border bg-white px-4 py-3 focus:outline-none focus:border-primary" />
                </label>
                <label class="block md:col-span-2">
                  <span class="block text-sm mb-2">Land</span>
                  <input type="text" name="country" value={profile.country} placeholder="Land" class="w-full border border-border bg-white px-4 py-3 focus:outline-none focus:border-primary" />
                </label>
              </div>

              <div class="flex flex-wrap gap-3 pt-2">
                <button type="submit" class="inline-flex px-5 py-3 bg-[#8b8d79] text-white font-medium hover:opacity-90 transition-opacity">Änderungen speichern</button>
                <a href="mailto:willkommen@sallymatthes.com?subject=Frage%20zu%20meinem%20Account" class="inline-flex px-5 py-3 border border-border hover:bg-secondary/40 transition-colors text-sm">E-Mail ändern</a>
                <a href="#passwort" class="inline-flex px-5 py-3 border border-border hover:bg-secondary/40 transition-colors text-sm">Passwort ändern</a>
              </div>
            </section>
          </form>

          <section id="passwort" class="border border-border bg-background p-6 md:p-8 space-y-6 max-w-3xl">
            <div class="space-y-2">
              <h2 class="font-serif text-3xl">Passwort ändern</h2>
              <p class="text-sm text-muted-foreground">Wenn du dein Passwort ändern möchtest, kannst du das direkt hier tun.</p>
            </div>

            <form method="POST" action="/api/auth/update-password" class="grid gap-4 md:grid-cols-2">
              <label class="block md:col-span-2">
                <span class="block text-sm mb-2">Neues Passwort</span>
                <input type="password" name="password" required autocomplete="new-password" placeholder="Neues Passwort" class="w-full border border-border bg-white px-4 py-3 focus:outline-none focus:border-primary" />
              </label>
              <label class="block md:col-span-2">
                <span class="block text-sm mb-2">Neues Passwort wiederholen</span>
                <input type="password" name="password_repeat" required autocomplete="new-password" placeholder="Passwort wiederholen" class="w-full border border-border bg-white px-4 py-3 focus:outline-none focus:border-primary" />
              </label>
              <div class="flex flex-wrap gap-3 pt-2 md:col-span-2">
                <button type="submit" class="inline-flex px-5 py-3 bg-[#8b8d79] text-white font-medium hover:opacity-90 transition-opacity">Passwort speichern</button>
                <a href="/login" class="inline-flex px-5 py-3 border border-border hover:bg-secondary/40 transition-colors text-sm">Lieber per Reset-Link ändern</a>
              </div>
            </form>
          </section>
        </div>
      </div>
    </div>
  </section>
</Layout>
