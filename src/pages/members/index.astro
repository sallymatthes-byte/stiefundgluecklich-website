---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import MembersSidebar from '../../components/MembersSidebar.astro';
import { getAccessSnapshot } from '../../lib/auth/grants';
import { loadUserGrants } from '../../lib/auth/load-grants';

const firstName = Astro.locals.user?.email?.split('@')[0]?.split(/[._-]/)[0] || 'du';
const firstNameLabel = firstName.charAt(0).toUpperCase() + firstName.slice(1);
const grants = await loadUserGrants(Astro);
const beyondBonus = getAccessSnapshot(grants, 'beyondbonus');
const error = Astro.url.searchParams.get('error');
const passwordUpdated = Astro.url.searchParams.get('password-updated') === '1';
---

<Layout
  title="Mitgliederbereich"
  canonical="https://stiefundgluecklich.de/members/"
  description="Geschützter Mitgliederbereich von Stief und Glücklich."
  noHeader={true}
>
  <section class="py-20 md:py-28">
    <div class="container mx-auto px-5 md:px-6 max-w-6xl">
      <div class="grid gap-8 lg:grid-cols-[280px,1fr]">
        <MembersSidebar
          title="Mitgliederbereich"
          subtitle={`Hey ${firstNameLabel}`}
          currentPath={Astro.url.pathname}
          topItems={[
            { href: '/members', label: 'Dashboard' },
            { href: '/members/beyondbonus', label: 'BeyondBonus' },
            { href: '/livecalls/beyondbonus', label: 'Livecalls' },
          ]}
          bottomItems={[
            { href: '/members/settings/account', label: 'Account' },
            { href: '/members/settings/notifications', label: 'Benachrichtigungen' },
            { href: 'mailto:willkommen@sallymatthes.com?subject=Frage%20zum%20Mitgliederbereich', label: 'Support' },
          ]}
        />

        <div>
          <p class="text-sm uppercase tracking-[0.2em] text-muted-foreground mb-4">Dashboard</p>
          <h1 class="font-serif text-3xl md:text-4xl mb-4">Deine Inhalte</h1>
          <p class="text-base text-muted-foreground mb-8 leading-relaxed max-w-3xl">
            Schön, dass du da bist. Hier findest du alle Inhalte, auf die du aktuell Zugriff hast.
          </p>

      {passwordUpdated && (
        <div class="mb-6 border border-border bg-secondary/40 p-4 text-sm leading-relaxed">
          Dein neues Passwort wurde gespeichert.
        </div>
      )}

      {error === 'no-access' && (
        <div class="mb-6 border border-red-200 bg-red-50 p-4 text-sm leading-relaxed">
          Für diesen Bereich ist aktuell noch kein freigeschalteter Zugang hinterlegt.
        </div>
      )}

      <div class="border border-border p-6 bg-secondary/40 space-y-2 mb-8">
        <p class="text-sm">Willkommen zurück. Schön, dass du wieder da bist.</p>
        <p class="text-sm text-muted-foreground">Wenn etwas mit deinem Zugang nicht stimmt, melde dich einfach direkt bei Sally.</p>
      </div>

      <div class="grid gap-8 lg:grid-cols-[1.25fr,0.75fr]">
        <div class="space-y-8">
          <section class="space-y-4">
            <h2 class="font-serif text-2xl">Für dich freigeschaltet</h2>
            <div class="grid gap-6 md:grid-cols-2">
              <div class="border border-border p-6 bg-background space-y-4">
                <div>
                  <p class="text-sm uppercase tracking-[0.18em] text-muted-foreground mb-2">BeyondBonus</p>
                  <h3 class="font-serif text-2xl">Kursbereich</h3>
                </div>
                <p class="text-sm text-muted-foreground leading-relaxed">
                  Alle Kursinhalte, Module und das zentrale Workbook für BeyondBonus.
                </p>
                <a
                  href="/members/beyondbonus"
                  class={`inline-flex px-5 py-3 text-sm font-medium transition-opacity ${beyondBonus.course ? 'bg-primary text-primary-foreground hover:opacity-90' : 'bg-secondary text-muted-foreground pointer-events-none opacity-70'}`}
                >
                  Kurs öffnen
                </a>
              </div>

              <div class="border border-border p-6 bg-background space-y-4">
                <div>
                  <p class="text-sm uppercase tracking-[0.18em] text-muted-foreground mb-2">BeyondBonus</p>
                  <h3 class="font-serif text-2xl">Livecalls & Aufzeichnungen</h3>
                </div>
                <p class="text-sm text-muted-foreground leading-relaxed">
                  Deine Livecalls und Aufzeichnungen an einem Ort.
                </p>
                <a
                  href="/livecalls/beyondbonus"
                  class={`inline-flex px-5 py-3 text-sm font-medium transition-opacity ${beyondBonus.livecalls ? 'bg-primary text-primary-foreground hover:opacity-90' : 'bg-secondary text-muted-foreground pointer-events-none opacity-70'}`}
                >
                  Livecalls öffnen
                </a>
              </div>
            </div>
          </section>

          <section class="space-y-4">
            <h2 class="font-serif text-2xl">Gerade noch nicht freigeschaltet</h2>
            <div class="grid gap-6 md:grid-cols-2">
              <div class="border border-border p-6 bg-background space-y-4 opacity-95">
                <div>
                  <p class="text-sm uppercase tracking-[0.18em] text-muted-foreground mb-2">ITS Bundle</p>
                  <h3 class="font-serif text-2xl">Dein Einstieg</h3>
                </div>
                <p class="text-sm text-muted-foreground leading-relaxed">
                  Drei kompakte Kernbereiche für Zugehörigkeit, Kommunikation und Grenzen im Patchworkalltag.
                </p>
                <a href="/its-bundle" class="inline-flex px-5 py-3 text-sm font-medium bg-secondary hover:bg-secondary/80 transition-colors">
                  Jetzt entdecken
                </a>
              </div>
            </div>
          </section>

          <section class="border border-border p-6 space-y-3">
            <p class="text-sm font-medium">Dein Zugang im Überblick</p>
            {grants.length > 0 ? (
              <ul class="space-y-2 text-sm text-muted-foreground">
                {grants.map((grant) => (
                  <li>
                    {grant.area === 'course' ? 'BeyondBonus Kurszugang' : 'BeyondBonus Livecalls'}
                    {grant.endsAt ? ` · verfügbar bis ${new Date(grant.endsAt).toLocaleDateString('de-DE')}` : ''}
                  </li>
                ))}
              </ul>
            ) : (
              <p class="text-sm text-muted-foreground">Noch kein aktiver Zugang hinterlegt.</p>
            )}
          </section>
        </div>

        <aside class="space-y-6">
          <section class="border border-border p-6 bg-secondary/40 space-y-3">
            <h2 class="font-serif text-xl">Account</h2>
            <p class="text-sm text-muted-foreground">Verwalte deine persönlichen Einstellungen, dein Passwort und deine Benachrichtigungen.</p>
            <div class="flex flex-col gap-3">
              <a href="/members/settings/account" class="text-sm text-primary hover:opacity-80 transition-opacity">Account-Einstellungen öffnen</a>
              <a href="/members/settings/notifications" class="text-sm text-primary hover:opacity-80 transition-opacity">Benachrichtigungen öffnen</a>
            </div>
          </section>

          <section class="border border-border p-6 bg-secondary/40 space-y-3">
            <h2 class="font-serif text-xl">Support</h2>
            <p class="text-sm text-muted-foreground">Wenn du eine Frage hast oder etwas mit deinem Zugang nicht klappt, melde dich direkt bei Sally.</p>
            <a href="mailto:willkommen@sallymatthes.com?subject=Frage%20zum%20Mitgliederbereich" class="text-sm text-primary hover:opacity-80 transition-opacity">willkommen@sallymatthes.com</a>
          </section>
        </aside>
      </div>

      <form method="POST" action="/api/auth/sign-out" class="mt-6">
        <button type="submit" class="border border-border px-4 py-2 text-sm hover:bg-secondary/40 transition-colors">
          Logout
        </button>
      </form>
        </div>
      </div>
    </div>
  </section>
</Layout>
