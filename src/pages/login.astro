---
import Layout from '../layouts/Layout.astro';

const nextPath = Astro.url.searchParams.get('next') || '/members';
const signedOut = Astro.url.searchParams.get('signed-out') === '1';
const resetSent = Astro.url.searchParams.get('reset') === 'sent';
const error = Astro.url.searchParams.get('error');
const hasSupabaseConfig = Boolean(import.meta.env.PUBLIC_SUPABASE_URL && import.meta.env.PUBLIC_SUPABASE_PUBLISHABLE_KEY);
---

<Layout
  title="Login – Mitgliederbereich"
  canonical="https://stiefundgluecklich.de/login/"
  description="Login für den geschützten Mitgliederbereich von Stief und Glücklich."
  noHeader={true}
>
  <section class="py-20 md:py-28">
    <div class="container mx-auto px-5 md:px-6 max-w-xl">
      <div class="bg-background border border-border p-8 md:p-10">
        <p class="text-sm uppercase tracking-[0.2em] text-muted-foreground mb-4">Mitgliederbereich</p>
        <h1 class="font-serif text-4xl md:text-5xl mb-4 leading-none">Dein Zugang zu BeyondBonus</h1>
        <p class="text-base text-muted-foreground mb-8 leading-relaxed max-w-lg">
          Logge dich mit deiner E-Mail-Adresse und deinem Passwort ein. Wenn dein Zugang schon freigeschaltet ist und etwas nicht klappt, melde dich direkt bei uns.
        </p>

        {signedOut && (
          <div class="mb-6 border border-border p-4 bg-secondary/40 text-sm">
            Du bist ausgeloggt.
          </div>
        )}

        {resetSent && (
          <div class="mb-6 border border-border p-4 bg-secondary/40 text-sm leading-relaxed">
            Wenn die E-Mail-Adresse bei uns freigeschaltet ist, haben wir dir gerade einen Link geschickt, über den du ein neues Passwort vergeben kannst.
          </div>
        )}

        {error && (
          <div class="mb-6 border border-red-200 p-4 bg-red-50 text-sm leading-relaxed">
            {error === 'missing-email'
              ? 'Bitte gib deine E-Mail-Adresse ein.'
              : error === 'missing-password'
                ? 'Bitte gib dein Passwort ein.'
                : error === 'invalid-credentials'
                  ? 'Diese Kombination aus E-Mail und Passwort passt gerade nicht.'
                  : error === 'supabase-config'
                    ? 'Der Login ist gerade noch nicht vollständig verbunden. Bitte versuche es gleich nochmal.'
                    : `Login gerade nicht sauber möglich: ${error}`}
          </div>
        )}

        <form method="POST" action="/api/auth/sign-in" class="space-y-4">
          <input type="hidden" name="next" value={nextPath} />
          <label class="block">
            <span class="block text-sm mb-2">E-Mail</span>
            <input
              type="email"
              name="email"
              required
              autocomplete="email"
              placeholder="deine@email.de"
              class="w-full border border-border bg-white px-4 py-3 focus:outline-none focus:border-primary"
              disabled={!hasSupabaseConfig}
            />
          </label>

          <label class="block">
            <span class="block text-sm mb-2">Passwort</span>
            <input
              type="password"
              name="password"
              required
              autocomplete="current-password"
              placeholder="Dein Passwort"
              class="w-full border border-border bg-white px-4 py-3 focus:outline-none focus:border-primary"
              disabled={!hasSupabaseConfig}
            />
          </label>

          <button
            type="submit"
            class="w-full bg-primary text-primary-foreground px-6 py-3 font-medium hover:opacity-90 transition-opacity disabled:opacity-50"
            disabled={!hasSupabaseConfig}
          >
            Einloggen
          </button>
        </form>

        <form method="POST" action="/api/auth/reset-password" class="mt-8 border-t border-border pt-6">
          <label class="block text-sm text-muted-foreground mb-3">Passwort vergessen?</label>
          <input
            type="email"
            name="email"
            required
            autocomplete="email"
            placeholder="Deine E-Mail-Adresse für den Reset"
            class="w-full border border-border bg-white px-4 py-3 focus:outline-none focus:border-primary mb-3"
            disabled={!hasSupabaseConfig}
          />
          <button
            type="submit"
            class="text-sm text-primary hover:opacity-80 transition-opacity disabled:opacity-50"
            disabled={!hasSupabaseConfig}
          >
            Link zum Zurücksetzen anfordern
          </button>
        </form>

        <div class="mt-6 space-y-4 border border-border p-5 bg-secondary/35 text-sm leading-relaxed">
          <div>
            <p class="font-medium">Du kommst nicht rein, obwohl dein Zugang schon freigeschaltet ist?</p>
            <p class="text-muted-foreground mt-1">Dann schreib uns einfach kurz, damit wir deinen Zugang mit dir prüfen können.</p>
          </div>
          <a href="mailto:willkommen@sallymatthes.com?subject=Hilfe%20beim%20Login%20zum%20Mitgliederbereich" class="inline-flex px-5 py-3 bg-primary text-primary-foreground font-medium hover:opacity-90 transition-opacity">Uns zum Login schreiben</a>
          {!hasSupabaseConfig && (
            <p class="text-muted-foreground">
              Der Login ist gerade noch nicht vollständig verbunden. Bitte versuche es gleich nochmal.
            </p>
          )}
        </div>
      </div>
    </div>
  </section>
</Layout>
