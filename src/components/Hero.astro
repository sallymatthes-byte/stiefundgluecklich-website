---
---

<section class="relative min-h-screen flex items-center pt-20">
  <!-- Background Image with Overlay -->
  <div class="absolute inset-0 z-0">
    <img
      src="/images/sally-hero.jpeg"
      alt="Sally Matthes — Coach für Bonusmamas in Patchworkfamilien"
      class="w-full h-full object-cover object-right-top"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-background/95 via-background/80 to-background/40"></div>
  </div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="max-w-2xl">
      <!-- Tagline -->
      <p class="text-primary font-medium mb-4 animate-fade-in opacity-0" style="animation-delay: 0.2s">
        Für Bonusmamas, die mehr wollen als nur funktionieren
      </p>

      <!-- Main Headline -->
      <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl text-foreground leading-tight mb-6 animate-fade-in opacity-0" style="animation-delay: 0.4s">
        Du gibst alles –
        <span class="italic text-primary">und fühlst dich trotzdem unsichtbar.</span>
      </h1>

      <!-- Subheadline -->
      <p class="text-lg md:text-xl text-muted-foreground mb-8 leading-relaxed animate-fade-in opacity-0" style="animation-delay: 0.6s">
        Er sagt der Ex zu, dass das Wochenende getauscht wird – ohne dich zu fragen. 
        Du schluckst es runter, wieder mal. Ich zeig dir, wie du sagst, was du brauchst – 
        und wie ihr als Paar anfangt, Entscheidungen gemeinsam zu treffen.
      </p>

      <!-- CTA Button -->
      <div class="flex flex-col sm:flex-row gap-4 animate-fade-in opacity-0" style="animation-delay: 0.8s">
        <a href="/quiz"
          class="inline-flex items-center justify-center bg-primary hover:bg-primary/90 text-primary-foreground px-8 py-4 text-lg font-medium transition-colors group">
          Finde deinen nächsten Schritt
          <svg class="ml-2 h-5 w-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>

      <!-- Trust Indicators -->
      <div class="mt-12 pt-8 border-t border-border/50 animate-fade-in opacity-0" style="animation-delay: 1s">
        <p class="text-sm text-muted-foreground mb-3">Gehört von über 800 Bonusmamas</p>
        <div class="flex items-center gap-1">
          {Array.from({length: 5}).map(() => (
            <svg class="w-5 h-5 text-gold-bright fill-current" viewBox="0 0 24 24">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
            </svg>
          ))}
          <span class="ml-2 text-sm text-muted-foreground">4.8/5 | #1 Bonusmama-Podcast</span>
        </div>
      </div>
    </div>
  </div>
</section>
