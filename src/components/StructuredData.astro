---
interface Props {
  type: 'article' | 'website' | 'breadcrumb';
  title?: string;
  description?: string;
  date?: Date;
  updated?: Date;
  image?: string;
  slug?: string;
  category?: string;
}

const { type, title, description, date, updated, image, slug, category } = Astro.props;

const siteUrl = 'https://stiefundgluecklich.de';

const personSchema = {
  "@type": "Person",
  "@id": `${siteUrl}/#author`,
  "name": "Sally Matthes",
  "url": `${siteUrl}/about/`,
  "jobTitle": "Patchwork-Coach & Erziehungswissenschaftlerin",
  "description": "Systemischer Coach für Bonusmamas in Patchworkfamilien. M.A. Erziehungswissenschaft, B.A. Angewandte Kindheitswissenschaften, zertifizierter Systemischer Coach, EFT-Weiterbildung. Über 100 Bonusmamas begleitet.",
  "hasCredential": [
    { "@type": "EducationalOccupationalCredential", "credentialCategory": "degree", "name": "Master of Arts — Erziehungswissenschaft" },
    { "@type": "EducationalOccupationalCredential", "credentialCategory": "degree", "name": "Bachelor of Arts — Angewandte Kindheitswissenschaften" },
    { "@type": "EducationalOccupationalCredential", "credentialCategory": "certificate", "name": "Zertifizierter Systemischer Coach" },
    { "@type": "EducationalOccupationalCredential", "credentialCategory": "certificate", "name": "Weiterbildung EFT (Emotionsfokussierte Therapie)" }
  ],
  "knowsAbout": ["Patchworkfamilie", "Stiefmutter", "Bonusmama", "Systemisches Coaching", "Erziehungswissenschaft", "Bonuskinder", "Stieffamilien"],
  "alumniOf": [
    { "@type": "CollegeOrUniversity", "name": "Universität — M.A. Erziehungswissenschaft" },
    { "@type": "CollegeOrUniversity", "name": "Hochschule — B.A. Angewandte Kindheitswissenschaften" }
  ],
  "sameAs": [
    "https://www.instagram.com/stiefundgluecklich/",
    "https://open.spotify.com/show/5wNKGzYsF6PMxuCRmUu5Pm"
  ]
};

// Category-based about/mentions for AEO
const categoryTopics: Record<string, { about: string; aboutDesc: string; mentions: string[] }> = {
  'rolle-identitaet': {
    about: 'Bonusmama',
    aboutDesc: 'Eine Bonusmama (auch Stiefmutter) ist eine Frau, die mit einem Partner zusammenlebt, der Kinder aus einer früheren Beziehung hat.',
    mentions: ['Stiefmutter', 'Patchworkfamilie', 'Identität']
  },
  'partnerschaft': {
    about: 'Paarbeziehung in der Patchworkfamilie',
    aboutDesc: 'Die Paarbeziehung in einer Patchworkfamilie steht vor besonderen Herausforderungen durch Kinder, Ex-Partner und unterschiedliche Familiengeschichten.',
    mentions: ['Patchworkfamilie', 'Bonusmama', 'Kommunikation']
  },
  'ex-und-system': {
    about: 'Ex-Partner-Dynamik in Patchworkfamilien',
    aboutDesc: 'Die Beziehung zum Ex-Partner des eigenen Partners ist eine der größten Herausforderungen in Patchworkfamilien.',
    mentions: ['Patchworkfamilie', 'Bonusmama', 'Loyalitätskonflikt']
  },
  'kinder-bindung': {
    about: 'Beziehung zu Bonuskindern',
    aboutDesc: 'Der Aufbau einer Beziehung zu den Kindern des Partners (Bonuskinder/Stiefkinder) erfordert Geduld, Respekt und klare Grenzen.',
    mentions: ['Bonuskind', 'Stiefkind', 'Patchworkfamilie']
  }
};

const orgSchema = {
  "@type": "Organization",
  "@id": `${siteUrl}/#organization`,
  "name": "StiefundGlücklich",
  "url": siteUrl,
  "logo": `${siteUrl}/logo.png`,
  "founder": { "@id": `${siteUrl}/#author` },
  "description": "Coaching und Ressourcen für Bonusmamas in Patchworkfamilien"
};

let schema: any;

if (type === 'article' && title) {
  schema = {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "BlogPosting",
        "headline": title,
        "description": description,
        "author": { "@id": `${siteUrl}/#author` },
        "publisher": { "@id": `${siteUrl}/#organization` },
        "datePublished": date?.toISOString().split('T')[0],
        "dateModified": (updated || date)?.toISOString().split('T')[0],
        "mainEntityOfPage": `${siteUrl}/blog/${slug}/`,
        "image": image ? `${siteUrl}${image}` : undefined,
        "inLanguage": "de-DE",
        "isPartOf": { "@id": `${siteUrl}/#website` },
        ...(category && categoryTopics[category] ? {
          "about": {
            "@type": "Thing",
            "name": categoryTopics[category].about,
            "description": categoryTopics[category].aboutDesc
          },
          "mentions": categoryTopics[category].mentions.map(m => ({
            "@type": "Thing",
            "name": m
          }))
        } : {})
      },
      personSchema,
      orgSchema,
      {
        "@type": "WebSite",
        "@id": `${siteUrl}/#website`,
        "name": "StiefundGlücklich",
        "url": siteUrl,
        "inLanguage": "de-DE",
        "publisher": { "@id": `${siteUrl}/#organization` }
      }
    ]
  };
} else if (type === 'breadcrumb' && title && slug) {
  const categoryLabels: Record<string, string> = {
    'rolle-identitaet': 'Rolle & Identität',
    'partnerschaft': 'Partnerschaft',
    'ex-und-system': 'Die Ex & das System',
    'kinder-bindung': 'Kinder & Bindung'
  };
  schema = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Start", "item": siteUrl },
      { "@type": "ListItem", "position": 2, "name": "Blog", "item": `${siteUrl}/blog/` },
      ...(category ? [{ "@type": "ListItem", "position": 3, "name": categoryLabels[category] || category, "item": `${siteUrl}/blog/?kategorie=${category}` }] : []),
      { "@type": "ListItem", "position": category ? 4 : 3, "name": title }
    ]
  };
} else {
  schema = {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "WebSite",
        "@id": `${siteUrl}/#website`,
        "name": "StiefundGlücklich",
        "url": siteUrl,
        "inLanguage": "de-DE",
        "publisher": { "@id": `${siteUrl}/#organization` }
      },
      orgSchema,
      personSchema
    ]
  };
}
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
