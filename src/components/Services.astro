---
const services = [
  {
    badge: "Dein Einstieg",
    iconSvg: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1.5M12 19.5V21M4.22 4.22l1.06 1.06M17.72 17.72l1.06 1.06M3 12h1.5M19.5 12H21M4.22 19.78l1.06-1.06M17.72 6.28l1.06-1.06" /><circle cx="12" cy="12" r="4" /></svg>`,
    title: "ITS Bundle",
    price: "59 €",
    description: "Für die Nächte, in denen du dich fragst: Bin ich hier richtig? Drei Impulse, die dir sofort helfen — Zugehörigkeit, Kommunikation und Grenzen.",
    features: [
      "I belong (Empowernde Affirmationen)",
      "Talk like a team (Deine Tools für eure Kommunikation)",
      "Setting limits (Übungen mit denen du lernst Grenzen zu setzen)",
      "Sofort verfügbar",
    ],
    link: "/its-bundle",
    linkLabel: "Starte jetzt",
  },
  {
    badge: "Das Intensivprogramm",
    iconSvg: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048 6.51 6.51 0 009 11.5a3 3 0 105.618-1.49A4.49 4.49 0 0015.362 5.214z" /></svg>`,
    title: "BeyondBonus",
    price: "497 €",
    description: "Du willst nicht nur verstehen, sondern wirklich etwas verändern? In 10 Wochen findest du deinen Platz in der Patchworkfamilie — mit Begleitung, nicht allein.",
    features: ["10 Wochen Programm", "12 Monate Zugang", "Video-Module & Worksheets"],
    link: "/beyondbonus",
    linkLabel: "Mehr erfahren",
  },
  {
    badge: "Persönliche Begleitung",
    iconSvg: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" /></svg>`,
    title: "1:1 Coaching",
    price: "Warteliste",
    description: "Für Bonusmamas, die bereit sind, in die Tiefe zu gehen. Du und ich, deine Situation, dein Weg — kein Schema F.",
    features: ["6 intensive Sessions", "Telegram-Betreuung dazwischen", "100% auf dich zugeschnitten"],
    link: "/warteliste",
    linkLabel: "Auf die Warteliste",
  },
];
---

<section id="services" class="py-14 md:py-24">
  <div class="container mx-auto px-5 md:px-6">
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <p class="text-primary font-medium mb-4">Für dich</p>
      <h2 class="font-serif text-xl md:text-3xl lg:text-4xl text-foreground mb-5 md:mb-7">
        Dein Weg zu mehr <span class="italic text-primary">Leichtigkeit</span>
      </h2>
      <p class="text-lg text-muted-foreground">
        Nicht sicher, was zu dir passt? Das Quiz findet es für dich heraus — in 2 Minuten.
      </p>
    </div>

    <!-- Services Grid -->
    <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">
      {services.map((service) => (
        <div class="relative overflow-hidden transition-all duration-300 hover:shadow-xl hover:-translate-y-1 border border-border bg-card p-6 flex flex-col">

          <span class="text-xs font-medium text-primary uppercase tracking-wider mb-3">
            {service.badge}
          </span>

          <div class="w-12 h-12 flex items-center justify-center mb-4 bg-secondary text-primary">
            <Fragment set:html={service.iconSvg} />
          </div>

          <h3 class="font-serif text-xl font-semibold text-foreground mb-1">
            {service.title}
          </h3>

          <p class="font-serif text-xl text-primary font-semibold mb-3">
            {service.price}
          </p>

          <p class="text-muted-foreground text-sm mb-4 leading-relaxed">
            {service.description}
          </p>

          <ul class="space-y-2 mb-6">
            {service.features.map((feature) => (
              <li class="text-sm text-muted-foreground flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-primary shrink-0"></span>
                {feature}
              </li>
            ))}
          </ul>

          <div class="mt-auto pt-2">
            <a href={service.link}
              class="text-sm text-primary hover:text-primary/80 underline underline-offset-4 transition-colors">
              {service.linkLabel} →
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- Quiz Banner -->
    <div class="max-w-5xl mx-auto mt-16">
      <div class="bg-primary text-primary-foreground py-10 px-8 md:px-12 flex flex-col sm:flex-row items-center justify-between gap-6 shadow-lg">
        <div class="text-center sm:text-left">
          <p class="font-serif text-xl md:text-2xl font-semibold mb-1">
            Du weißt noch nicht, was zu dir passt?
          </p>
          <p class="text-primary-foreground/80 text-sm md:text-base">
            Finde es in 2 Minuten heraus — kostenlos.
          </p>
        </div>
        <a href="/quiz" class="shrink-0">
          <span class="inline-flex items-center justify-center bg-background text-foreground hover:bg-background/90 font-semibold px-6 py-3 shadow-md transition-colors group">
            Zum Quiz
            <svg class="ml-2 h-4 w-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </span>
        </a>
      </div>
    </div>
  </div>
</section>
