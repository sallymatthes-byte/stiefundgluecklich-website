---
const services = [
  {
    badge: "Dein erster Schritt",
    iconSvg: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0Z" /></svg>`,
    title: "Break the Cycle",
    price: "Kostenlos",
    description: "Finde heraus, welches Muster dich in deiner Patchworkbeziehung gerade blockiert — und was dein sinnvoller nächster Schritt ist.",
    features: [
      "in wenigen Minuten mehr Klarheit",
      "persönliches Ergebnis direkt auf der Seite",
      "konkrete nächste Schritte per Mail",
    ],
    link: "/bonusmama-check?source=website_internal",
    linkLabel: "Bonusmama-Check starten",
  },
  {
    badge: "Für deinen Alltag",
    iconSvg: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 0 0 6-6v-1.5m-6 7.5a6 6 0 0 1-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 0 1-3-3V6.75a3 3 0 1 1 6 0v6a3 3 0 0 1-3 3Z" /></svg>`,
    title: "Bonusgeflüster Podcast",
    price: "Wöchentlich",
    description: "Konkrete Impulse, echte Geschichten und klare Einordnung für deinen Patchwork-Alltag — auch während meiner Babypause.",
    features: [
      "Bonusmama-Themen ohne Schönreden",
      "Expertinnen-Interviews und echte Geschichten",
      "kostenlos auf Spotify & Co.",
    ],
    link: "/podcast",
    linkLabel: "Podcast hören",
  },
  {
    badge: "Persönliche Begleitung",
    iconSvg: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 0 0-2.455 2.456Z" /></svg>`,
    title: "1:1 Warteliste",
    price: "Ab Herbst 2026",
    description: "Wenn du persönliche Begleitung möchtest, trag dich unverbindlich ein. Ich melde mich, sobald nach der Babypause wieder Plätze möglich sind.",
    features: [
      "unverbindlich eintragen",
      "früher Bescheid bekommen",
      "für 1:1 Coaching und passende Startfenster",
    ],
    link: "/warteliste",
    linkLabel: "Auf die Warteliste",
  },
]
---

<section id="services" class="py-14 md:py-24">
  <div class="container mx-auto px-5 md:px-6">
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <p class="text-primary font-medium mb-4">Für dich</p>
      <h2 class="font-serif text-xl md:text-3xl lg:text-4xl text-foreground mb-5 md:mb-7">
        So findest du gerade <span class="italic text-primary">weiter</span>
      </h2>
      <p class="text-lg text-muted-foreground">
        Starte mit Klarheit statt mit Kaufdruck: erst verstehen, was bei dir gerade wirkt — dann den nächsten passenden Schritt wählen.
      </p>
    </div>

    <!-- Services Grid -->
    <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">
      {services.map((service) => (
        <div class="relative overflow-hidden transition-all duration-300 hover:shadow-xl hover:-translate-y-1 border border-border bg-card p-6 flex flex-col">

          <span class="text-xs font-medium text-primary uppercase tracking-wider mb-3">
            {service.badge}
          </span>

          <div class="w-12 h-12 flex items-center justify-center mb-4 bg-secondary text-primary">
            <Fragment set:html={service.iconSvg} />
          </div>

          <h3 class="font-serif text-xl font-semibold text-foreground mb-1">
            {service.title}
          </h3>

          <p class="font-serif text-xl text-primary font-semibold mb-3">
            {service.price}
          </p>

          <p class="text-muted-foreground text-sm mb-4 leading-relaxed">
            {service.description}
          </p>

          <ul class="space-y-2 mb-6">
            {service.features.map((feature) => (
              <li class="text-sm text-muted-foreground flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-primary shrink-0"></span>
                {feature}
              </li>
            ))}
          </ul>

          <div class="mt-auto pt-2">
            <a href={service.link}
              class="text-sm text-primary hover:text-primary/80 underline underline-offset-4 transition-colors">
              {service.linkLabel} →
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- Quiz Banner -->
    <div class="max-w-5xl mx-auto mt-16">
      <div class="bg-primary text-primary-foreground py-10 px-8 md:px-12 flex flex-col sm:flex-row items-center justify-between gap-6 shadow-lg">
        <div class="text-center sm:text-left">
          <p class="font-serif text-xl md:text-2xl font-semibold mb-1">
            Du willst wissen, woran es gerade wirklich hängt?
          </p>
          <p class="text-primary-foreground/80 text-sm md:text-base">
            Mach den Bonusmama-Check und hol dir sofort mehr Klarheit.
          </p>
        </div>
        <a href="/bonusmama-check?source=website_internal" class="shrink-0">
          <span class="inline-flex items-center justify-center bg-background text-foreground hover:bg-background/90 font-semibold px-6 py-3 shadow-md transition-colors group">
            Zum Bonusmama-Check
            <svg class="ml-2 h-4 w-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </span>
        </a>
      </div>
    </div>
  </div>
</section>
