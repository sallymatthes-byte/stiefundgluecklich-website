---
const navLinks = [
  { label: "Über mich", href: "/about" },
  { label: "Podcast", href: "https://open.spotify.com/show/5wNKGzYsF6PMxuCRmUu5Pm", external: true },
  { label: "Blog", href: "/blog" },
];

const currentYear = new Date().getFullYear();
---

<footer class="bg-[#1a1a1a] text-cream py-16">
  <div class="container mx-auto px-6">
    <div class="grid md:grid-cols-3 gap-12 mb-12">
      <!-- Brand -->
      <div class="md:col-span-2">
        <h3 class="font-serif text-2xl font-semibold mb-4 text-[hsl(45,48%,91%)]">Stief & Glücklich</h3>
        <p class="text-[hsl(45,48%,91%)]/70 max-w-md mb-6">
          Coaching und Begleitung für Bonusmamas auf dem Weg zu einem erfüllten Leben 
          in der Patchwork-Familie.
        </p>
        <div class="flex gap-4">
          <a href="https://www.instagram.com/stiefundgluecklich/"
            target="_blank" rel="noopener noreferrer"
            class="w-10 h-10 rounded-full bg-[hsl(45,48%,91%)]/10 flex items-center justify-center hover:bg-[hsl(45,48%,91%)]/20 transition-colors"
            aria-label="Instagram">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C16.67.014 16.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
          <a href="https://open.spotify.com/show/5wNKGzYsF6PMxuCRmUu5Pm"
            target="_blank" rel="noopener noreferrer"
            class="w-10 h-10 rounded-full bg-[hsl(45,48%,91%)]/10 flex items-center justify-center hover:bg-[hsl(45,48%,91%)]/20 transition-colors"
            aria-label="Podcast auf Spotify">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.114 5.636a9 9 0 010 12.728M16.463 8.288a5.25 5.25 0 010 7.424M6 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h2l4-4v14l-4-4z" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="font-semibold mb-4 text-[hsl(45,48%,91%)]">Navigation</h4>
        <ul class="space-y-3">
          {navLinks.map((item) => (
            <li>
              <a href={item.href}
                {...(item.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
                class="text-[hsl(45,48%,91%)]/70 hover:text-[hsl(45,48%,91%)] transition-colors">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-[hsl(45,48%,91%)]/10 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-sm text-[hsl(45,48%,91%)]/50">
        © {currentYear} Sally Matthes. Alle Rechte vorbehalten.
      </p>
      <div class="flex gap-6 text-sm text-[hsl(45,48%,91%)]/50">
        <a href="/impressum" class="hover:text-[hsl(45,48%,91%)] transition-colors">Impressum</a>
        <a href="/datenschutz" class="hover:text-[hsl(45,48%,91%)] transition-colors">Datenschutz</a>
        <a href="/agb" class="hover:text-[hsl(45,48%,91%)] transition-colors">AGB</a>
      </div>
      <p class="text-sm text-[hsl(45,48%,91%)]/50 flex items-center gap-1">
        Made with <span class="text-gold-bright">♥</span> für Bonusmamas
      </p>
    </div>
  </div>
</footer>
