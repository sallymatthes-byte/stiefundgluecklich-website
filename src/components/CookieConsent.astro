---
// Minimal cookie consent banner — opt-out model
// Tracks by default (DSGVO: legitimate interest for analytics)
// User can opt out → localStorage flag disables all tracking
---

<div id="cookie-banner" class="cookie-banner" style="display:none;">
  <div class="cookie-inner">
    <p>
      Wir nutzen Cookies und Analyse-Tools, um diese Website zu verbessern. 
      <a href="/datenschutz/">Mehr erfahren</a>
    </p>
    <div class="cookie-buttons">
      <button id="cookie-accept" class="cookie-btn cookie-btn-accept">Okay</button>
      <button id="cookie-reject" class="cookie-btn cookie-btn-reject">Ablehnen</button>
    </div>
  </div>
</div>

<script is:inline>
(function() {
  var consent = localStorage.getItem('cookie-consent');
  
  // Show banner only if no choice made yet
  if (consent === null) {
    var banner = document.getElementById('cookie-banner');
    if (banner) banner.style.display = 'flex';
  }

  // If user rejected, update consent mode
  if (consent === 'rejected') {
    if (typeof gtag === 'function') {
      gtag('consent', 'update', {
        'analytics_storage': 'denied',
        'ad_storage': 'denied',
        'ad_user_data': 'denied',
        'ad_personalization': 'denied'
      });
    }
  }

  document.addEventListener('DOMContentLoaded', function() {
    var acceptBtn = document.getElementById('cookie-accept');
    var rejectBtn = document.getElementById('cookie-reject');
    var banner = document.getElementById('cookie-banner');

    if (acceptBtn) {
      acceptBtn.addEventListener('click', function() {
        localStorage.setItem('cookie-consent', 'accepted');
        if (banner) banner.style.display = 'none';
      });
    }

    if (rejectBtn) {
      rejectBtn.addEventListener('click', function() {
        localStorage.setItem('cookie-consent', 'rejected');
        if (banner) banner.style.display = 'none';
        // Update consent mode to denied
        if (typeof gtag === 'function') {
          gtag('consent', 'update', {
            'analytics_storage': 'denied',
            'ad_storage': 'denied',
            'ad_user_data': 'denied',
            'ad_personalization': 'denied'
          });
        }
        // Disable PostHog
        if (typeof posthog !== 'undefined') {
          posthog.opt_out_capturing();
        }
      });
    }
  });
})();
</script>

<style>
  .cookie-banner {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 9999;
    display: flex;
    justify-content: center;
    padding: 0 1rem 1rem;
    pointer-events: none;
  }
  .cookie-inner {
    pointer-events: auto;
    background: hsl(0, 0%, 15%);
    color: hsl(0, 0%, 90%);
    padding: 1rem 1.5rem;
    border-radius: 12px;
    display: flex;
    align-items: center;
    gap: 1rem;
    max-width: 720px;
    width: 100%;
    font-size: 0.875rem;
    line-height: 1.4;
    box-shadow: 0 4px 20px rgba(0,0,0,0.3);
    font-family: var(--font-sans, 'Raleway', sans-serif);
  }
  .cookie-inner p {
    margin: 0;
    flex: 1;
  }
  .cookie-inner a {
    color: hsl(42, 62%, 58%);
    text-decoration: underline;
  }
  .cookie-buttons {
    display: flex;
    gap: 0.5rem;
    flex-shrink: 0;
  }
  .cookie-btn {
    padding: 0.5rem 1rem;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-size: 0.875rem;
    font-weight: 500;
    font-family: inherit;
    transition: opacity 0.2s;
  }
  .cookie-btn:hover {
    opacity: 0.85;
  }
  .cookie-btn-accept {
    background: hsl(107, 57%, 21%);
    color: white;
  }
  .cookie-btn-reject {
    background: transparent;
    color: hsl(0, 0%, 70%);
    border: 1px solid hsl(0, 0%, 40%);
  }
  @media (max-width: 600px) {
    .cookie-inner {
      flex-direction: column;
      text-align: center;
    }
    .cookie-buttons {
      width: 100%;
      justify-content: center;
    }
  }
</style>
