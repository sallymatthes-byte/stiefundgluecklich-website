---
interface NavItem {
  href: string;
  label: string;
}

interface Props {
  title?: string;
  subtitle?: string;
  currentPath?: string;
  primaryItems?: NavItem[];
  courseItems?: NavItem[];
  bottomItems?: NavItem[];
  avatarUrl?: string;
}

const {
  title = 'Mitgliederbereich',
  subtitle = 'Schön, dass du da bist.',
  currentPath = '',
  primaryItems = [],
  courseItems = [],
  bottomItems = [],
  avatarUrl = '',
} = Astro.props;

const isActive = (href: string) => currentPath === href || currentPath.startsWith(`${href}/`);
const initials = subtitle
  .split(' ')
  .map((part: string) => part.trim()[0])
  .filter(Boolean)
  .slice(0, 2)
  .join('')
  .toUpperCase();
---

<aside class="self-start lg:sticky lg:top-10 w-full lg:w-[224px] min-w-0 lg:border-r border-border/70 lg:pr-8">
  <details class="group border border-border/80 bg-background lg:hidden">
    <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-4 py-3 [&::-webkit-details-marker]:hidden">
      <div class="min-w-0">
        <p class="text-[10px] uppercase tracking-[0.2em] text-muted-foreground">{title}</p>
        <p class="font-serif text-xl leading-tight truncate text-foreground">{subtitle}</p>
      </div>
      <span class="flex h-9 w-9 shrink-0 items-center justify-center border border-border text-xl leading-none text-foreground" aria-hidden="true">
        <span class="group-open:hidden">☰</span>
        <span class="hidden group-open:inline">×</span>
      </span>
    </summary>

    <div class="border-t border-border/70 px-4 py-3 space-y-5">
      {primaryItems.length > 0 && (
        <nav class="space-y-1">
          {primaryItems.map((item) => (
            <a
              href={item.href}
              class={`block py-3 text-sm transition-colors border-b ${isActive(item.href) ? 'border-primary text-foreground font-medium pl-2' : 'border-border/70 text-muted-foreground hover:text-foreground'}`}
            >
              {item.label}
            </a>
          ))}
        </nav>
      )}

      {courseItems.length > 0 && (
        <div class="space-y-1">
          <p class="text-[11px] uppercase tracking-[0.2em] text-muted-foreground pb-2">Meine Kurse</p>
          {courseItems.map((item) => (
            <a
              href={item.href}
              class={`block py-3 text-sm transition-colors border-b ${isActive(item.href) ? 'border-primary text-foreground font-medium pl-2' : 'border-border/70 text-muted-foreground hover:text-foreground'}`}
            >
              {item.label}
            </a>
          ))}
        </div>
      )}

      {bottomItems.length > 0 && (
        <div class="pt-2 border-t border-border/70 space-y-1">
          {bottomItems.map((item) => (
            <a
              href={item.href}
              class={`block py-3 text-sm transition-colors border-b ${isActive(item.href) ? 'border-primary text-foreground font-medium pl-2' : 'border-border/70 text-muted-foreground hover:text-foreground'}`}
            >
              {item.label}
            </a>
          ))}
        </div>
      )}
    </div>
  </details>

  <div class="hidden lg:block space-y-7">
    <div class="space-y-4 pb-1">
      <p class="text-[11px] uppercase tracking-[0.2em] text-muted-foreground">{title}</p>
      <div class="flex items-center gap-3">
        {avatarUrl ? (
          <img src={avatarUrl} alt={subtitle} class="h-12 w-12 rounded-full object-cover border border-border/70 bg-secondary/20" />
        ) : (
          <div class="flex h-12 w-12 items-center justify-center rounded-full border border-border/70 bg-secondary/20 text-sm font-medium text-foreground/80">
            {initials || 'S'}
          </div>
        )}
        <p class="font-serif text-[1.65rem] leading-tight break-words text-foreground">{subtitle}</p>
      </div>
    </div>

    {primaryItems.length > 0 && (
      <nav class="space-y-1">
        {primaryItems.map((item) => (
          <a
            href={item.href}
            class={`block py-3 text-sm transition-colors border-b ${isActive(item.href) ? 'border-primary text-foreground font-medium pl-2' : 'border-border/70 text-muted-foreground hover:text-foreground'}`}
          >
            {item.label}
          </a>
        ))}
      </nav>
    )}

    {courseItems.length > 0 && (
      <div class="space-y-1 pt-2">
        <p class="text-[11px] uppercase tracking-[0.2em] text-muted-foreground pb-2">Meine Kurse</p>
        {courseItems.map((item) => (
          <a
            href={item.href}
            class={`block py-3 text-sm transition-colors border-b ${isActive(item.href) ? 'border-primary text-foreground font-medium pl-2' : 'border-border/70 text-muted-foreground hover:text-foreground'}`}
          >
            {item.label}
          </a>
        ))}
      </div>
    )}

    {bottomItems.length > 0 && (
      <div class="pt-5 mt-6 border-t border-border/70 space-y-1">
        {bottomItems.map((item) => (
          <a
            href={item.href}
            class={`block py-3 text-sm transition-colors border-b ${isActive(item.href) ? 'border-primary text-foreground font-medium pl-2' : 'border-border/70 text-muted-foreground hover:text-foreground'}`}
          >
            {item.label}
          </a>
        ))}
      </div>
    )}
  </div>
</aside>
