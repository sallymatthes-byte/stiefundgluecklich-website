---
interface NavItem {
  href: string;
  label: string;
}

interface Props {
  title?: string;
  subtitle?: string;
  currentPath?: string;
  topItems?: NavItem[];
  bottomItems?: NavItem[];
}

const {
  title = 'Mitgliederbereich',
  subtitle = 'Schön, dass du da bist.',
  currentPath = '',
  topItems = [],
  bottomItems = [],
} = Astro.props;

const isActive = (href: string) => currentPath === href || currentPath.startsWith(`${href}/`);
---

<aside class="self-start md:sticky md:top-8 bg-[#f3f1ec] p-6 md:p-7 space-y-8 min-w-0 w-full md:w-[240px]">
  <div class="space-y-3 px-1">
    <p class="text-xs uppercase tracking-[0.18em] text-muted-foreground">{title}</p>
    <h2 class="font-serif text-3xl leading-none break-words">{subtitle}</h2>
  </div>

  <nav class="space-y-1 pr-2">
    {topItems.map((item) => (
      <a
        href={item.href}
        class={`block px-0 py-3 text-base transition-colors border-b ${isActive(item.href) ? 'border-primary text-foreground' : 'border-border text-muted-foreground hover:text-foreground'}`}
      >
        {item.label}
      </a>
    ))}
  </nav>

  {bottomItems.length > 0 && (
    <div class="pt-4 mt-4 border-t border-border space-y-1 pr-2">
      {bottomItems.map((item) => (
        <a
          href={item.href}
          class={`block px-0 py-3 text-base transition-colors border-b ${isActive(item.href) ? 'border-primary text-foreground' : 'border-border text-muted-foreground hover:text-foreground'}`}
        >
          {item.label}
        </a>
      ))}
    </div>
  )}
</aside>
